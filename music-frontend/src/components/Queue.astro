---
const { showControls = true, showHeader = true } = Astro.props;
---

<div data-queue-root>
    {showHeader ? (
        <div class="flex justify-between items-center mb-2 border-b border-yellow-700 pb-1">
            <p class="font-bold text-sm">Sıradaki Şarkılar</p>
            {showControls ? (
                <button data-queue-refresh class="text-xs hover:underline cursor-pointer">[Yenile]</button>
            ) : null}
        </div>
    ) : null}

    <div data-queue-container class="text-xs flex flex-col gap-2">
        <span class="italic text-gray-600">Yükleniyor...</span>
    </div>
</div>

<script>
    import { API_URL } from '../lib/constants';

    const token = localStorage.getItem("jwt_token");

    function initQueue(root) {
        if (!root || root.dataset.queueReady) return;
        root.dataset.queueReady = 'true';

        const container = root.querySelector('[data-queue-container]');
        const refreshBtn = root.querySelector('[data-queue-refresh]');

        async function updateQueue() {
            if (!container) return;

            try {
                const res = await fetch(`${API_URL}/list-queue`, {
                    headers: { 'X-Session-ID': token || '' }
                });

                if (!res.ok) throw new Error();

                const data = await res.json();
                const queue = data.queue || [];

                if (queue.length === 0) {
                    container.innerHTML = "Sıra boş. Şarkı ekle!";
                    return;
                }

                container.innerHTML = "";

                queue.slice(0, 5).forEach((track, index) => {
                    const item = document.createElement('div');
                    item.className = "flex gap-2 opacity-80";
                    item.innerHTML = `
          <span class="font-mono text-yellow-800">${index + 1}.</span>
          <span class="truncate"><b>${track.name}</b> - ${track.artists[0].name}</span>
        `;
                    container.appendChild(item);
                });

            } catch (e) {
                container.innerHTML = "<span class='text-red-600'>Sıra alınamadı.</span>";
            }
        }

        updateQueue();
        refreshBtn?.addEventListener('click', updateQueue);
        setInterval(updateQueue, 10000);
    }

    function initAllQueues() {
        document.querySelectorAll('[data-queue-root]:not([data-queue-ready])').forEach(initQueue);
    }

    initAllQueues();
    setInterval(initAllQueues, 1000);
</script>
