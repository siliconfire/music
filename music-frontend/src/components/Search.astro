---
---

<div class="flex gap-2">
    <input
            type="text"
            id="inp-search"
            class="bg-transparent border-b board-theme-border outline-none w-32 board-theme-text-primary board-theme-input"
            placeholder="<...>"
    >
    <button id="btn-search" class="font-medium text-sm board-theme-text-primary hover:opacity-80">[Ara]</button>
</div>
<div id="search-results" class="mt-2 text-xs flex flex-col gap-1"></div>
<script>
    import { API_URL } from '../lib/constants';

    const token = localStorage.getItem("jwt_token");
    const searchInput = document.getElementById("inp-search") as HTMLInputElement;
    const searchBtn = document.getElementById("btn-search");
    const resultsDiv = document.getElementById("search-results");

    searchBtn?.addEventListener("click", async () => {
        const query = searchInput.value;
        if (!query) return;

        resultsDiv.innerHTML = "<span class='italic board-theme-text-secondary'>Aranıyor...</span>";

        try {
            const res = await fetch(`${API_URL}/search?q=${encodeURIComponent(query)}`, {
                headers: { 'X-Session-ID': token || '' }
            });
            const data = await res.json();

            resultsDiv.innerHTML = "";
            // slice down to 3
            const results = data.tracks.items.slice(0, 3);
            window.posthog?.capture('music_searched', { query, result_count: results.length });
            results.forEach(track => {
                const row = document.createElement("div");
                row.className = "flex justify-between items-center gap-4 border-t board-theme-border pt-1 board-theme-text-secondary";
                row.innerHTML = `
          <span class="truncate w-32 board-theme-text-primary">${track.name}</span>
          <button class="play-btn font-semibold board-theme-action-btn" data-uri="${track.uri}" data-name="${track.name}">[şimdi çal]</button>
          <button class="add-btn font-bold board-theme-action-btn" data-uri="${track.uri}" data-name="${track.name}">[sıraya ekle]</button>
        `;
                resultsDiv.appendChild(row);
            });
        } catch (e) {
            window.posthog?.captureException(e);
            resultsDiv.innerHTML = "<span class='board-theme-text-error'>Hata." +
                "<br><br>normalde yetkin yok derdim ama yetkin olmasa bu sayfaya zaten gelemezdin ki...?" +
                "<br>acaba ben mi hatalıyım?" +
                "<br>yada sunucu mu kapalı?" +
                "<br>bence mantıklısı sunucunun kapalı olması." +
                "<br><br>Eğer kısa süre içinde düzelmez ise, yardım için <a href='/help' class='board-theme-inline-link'>BURAYA</a> tıklayın.</span>";
        }
    });

    // Event Delegation for the [+] buttons
    resultsDiv?.addEventListener("click", async (e) => {
        const target = e.target as HTMLElement;
        const uri = target.getAttribute("data-uri");
        if (!uri) return;

        const trackName = target.getAttribute("data-name") || undefined;

        let res: Response;
        if (target.classList.contains("play-btn")) {
            res = await fetch(`${API_URL}/play?uri=${encodeURIComponent(uri)}`, {
                headers: {'X-Session-ID': token || ''},
                method: 'POST'
            });
            if (res.ok) {
                window.posthog?.capture('track_played', { track_uri: uri, track_name: trackName });
            }
        } else {
            res = await fetch(`${API_URL}/add?uri=${encodeURIComponent(uri)}`, {
                headers: {'X-Session-ID': token || ''},
                method: 'POST'
            });
            if (res.ok) {
                window.posthog?.capture('track_added_to_queue', { track_uri: uri, track_name: trackName });
            }
        }

        if (res.ok) {
            target.innerText = "[OK]";
            (target as HTMLButtonElement).disabled = true;
        }
    });
</script>
