---
import BoardThemeLoader from './BoardThemeLoader.astro';

interface Props {
    size?: number;
}

const { size = 5 } = Astro.props;
const gridArray = Array.from({ length: size * size });
---

<BoardThemeLoader />

<div class="lights-out-grid" data-size={size}>
    {gridArray.map((_, i) => (
            <button
                    type="button"
                    class="light"
                    data-index={i}
                    data-on="false"
            ></button>
    ))}
</div>
<div class="lights-out-score board-theme-text-secondary text-sm mt-2" data-lights-score>Skor: 0</div>

<style>
  .lights-out-grid {
    --grid-size: 5;
    display: grid;
    /* Grid size set via JS/Prop */
    grid-template-columns: repeat(var(--grid-size, 5), 1fr);
    gap: 2px;
    padding: 10px;
    width: fit-content;
    /* No background on container */
    background: none;
  }

  .light {
    width: 45px;
    height: 45px;
    padding: 0;
    cursor: pointer;
    border: 1px solid var(--board-card-border);
    /* 'Off' state uses secondary text color */
    background-color: var(--board-text-secondary);
  }

  /* 'On' state uses the Card Background value */
  .light[data-on="true"] {
    background-color: var(--board-card-bg);
  }

  .light:focus {
    outline: none;
    border-color: var(--board-card-pinned-border);
  }
</style>

<script>
    import { API_URL } from '../lib/constants';

    function initGame() {
        const grid = document.querySelector('.lights-out-grid') as HTMLElement;
        if (!grid) return;
        const scoreEl = document.querySelector('[data-lights-score]') as HTMLElement | null;

        const size = parseInt(grid.dataset.size || '5');
        const lights = grid.querySelectorAll('.light') as NodeListOf<HTMLButtonElement>;
        const pendingTimers: number[] = [];
        const syncTimers: number[] = [];
        let isAnimatingWin = false;
        const token = localStorage.getItem('jwt_token') || '';

        function parseJwtPayload(rawToken: string) {
            try {
                const parts = String(rawToken || '').split('.');
                if (parts.length < 2) return null;
                let payload = parts[1].replace(/-/g, '+').replace(/_/g, '/');
                while (payload.length % 4) payload += '=';
                const decoded = atob(payload);
                const json = decodeURIComponent(Array.from(decoded).map((c) => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join(''));
                return JSON.parse(json);
            } catch (e) {
                return null;
            }
        }

        function getScoreStorageKey() {
            const payload = parseJwtPayload(token);
            const userId = String(payload?.sub ?? payload?.user_id ?? payload?.id ?? '').trim();
            return userId ? `lightsOutScore:${userId}` : 'lightsOutScore';
        }

        const scoreStorageKey = getScoreStorageKey();

        function normalizeScore(value: unknown) {
            const num = Number(value);
            if (!Number.isFinite(num)) return 0;
            if (num < 0) return 0;
            return Math.floor(num);
        }

        function getLocalScore() {
            return normalizeScore(localStorage.getItem(scoreStorageKey));
        }

        function setLocalScore(score: number) {
            localStorage.setItem(scoreStorageKey, String(normalizeScore(score)));
        }

        function renderScore(score: number) {
            if (!scoreEl) return;
            scoreEl.textContent = `Skor: ${normalizeScore(score)}`;
        }

        async function syncScoreWithServer() {
            if (!token) return;
            const localScore = getLocalScore();
            try {
                const res = await fetch(`${API_URL}/me/lights-out/score/sync`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Session-ID': token
                    },
                    body: JSON.stringify({ score: localScore })
                });
                if (!res.ok) return;
                const data = await res.json();
                const serverScore = normalizeScore(data?.score);
                if (serverScore !== localScore) {
                    setLocalScore(serverScore);
                }
                renderScore(serverScore);
            } catch (e) {
                // Keep local score if sync fails.
            }
        }

        function scheduleTopOfHourSync() {
            const now = new Date();
            const nextHour = new Date(now.getTime());
            nextHour.setMinutes(0, 0, 0);
            nextHour.setHours(now.getHours() + 1);
            const jitterMs = Math.floor(Math.random() * 60000);
            const delayMs = Math.max(1000, nextHour.getTime() - now.getTime() + jitterMs);

            const timer = window.setTimeout(async () => {
                await syncScoreWithServer();
                scheduleTopOfHourSync();
            }, delayMs);
            syncTimers.push(timer);
        }

        function clearPendingTimers() {
            while (pendingTimers.length > 0) {
                const timer = pendingTimers.pop();
                if (timer !== undefined) {
                    clearTimeout(timer);
                }
            }
        }

        function setAllLights(on: boolean) {
            for (const light of lights) {
                light.setAttribute('data-on', on.toString());
            }
        }

        function toggle(index: number) {
            if (index < 0 || index >= lights.length) return;
            const light = lights[index];
            const isCurrentlyOn = light.getAttribute('data-on') === 'true';
            light.setAttribute('data-on', (!isCurrentlyOn).toString());
        }

        function handlePress(index: number, isInitial = false) {
            if (!isInitial && isAnimatingWin) return;

            const row = Math.floor(index / size);
            const col = index % size;

            toggle(index);
            if (row > 0) toggle(index - size);
            if (row < size - 1) toggle(index + size);
            if (col > 0) toggle(index - 1);
            if (col < size - 1) toggle(index + 1);

            if (!isInitial) checkWin();
        }

        function checkWin() {
            const allOff = Array.from(lights).every(l => l.getAttribute('data-on') === 'false');
            if (allOff) {
                startWinSequence();
            }
        }

        function resetBoard() {
            clearPendingTimers();
            isAnimatingWin = false;
            grid.style.pointerEvents = '';
            setAllLights(false);

            // Rebuild into a solvable random board.
            for (let i = 0; i < size * 2; i++) {
                handlePress(Math.floor(Math.random() * lights.length), true);
            }
        }

        function buildPresetMapString(preset: string): string {
            // 5x5 presets are intentionally kept as text maps so they can be edited quickly.
            if (size === 5) {
                const presets: Record<string, string> = {
                    smiley: [
                        '#####',
                        '#.#.#',
                        '#####',
                        '.###.',
                        '#...#'
                    ].join('\n'),
                    dot: [
                        '.....',
                        '.....',
                        '..#..',
                        '.....',
                        '.....'
                    ].join('\n'),
                    border: [
                        '#####',
                        '#...#',
                        '#...#',
                        '#...#',
                        '#####'
                    ].join('\n'),
                    checker: [
                        '#.#.#',
                        '.#.#.',
                        '#.#.#',
                        '.#.#.',
                        '#.#.#'
                    ].join('\n'),
                    empty: [
                        '.....',
                        '.....',
                        '.....',
                        '.....',
                        '.....'
                    ].join('\n'),
                    easywin: [
                        '...#.',
                        '..###',
                        '...#.',
                        '.....',
                        '.....'
                    ].join('\n'),
                    hashtag: [
                        '#.#.#',
                        '.....',
                        '#.#.#',
                        '.....',
                        '#.#.#'
                    ].join('\n'),

                };
                return presets[preset] || '';
            }

            // Fallback generator for non-5x5 boards.
            const rows: string[] = [];
            const mid = Math.floor(size / 2);
            for (let row = 0; row < size; row += 1) {
                let line = '';
                for (let col = 0; col < size; col += 1) {
                    let on = false;
                    if (preset === 'plus') on = row === mid || col === mid;
                    if (preset === 'x') on = row === col || row + col === size - 1;
                    if (preset === 'border') on = row === 0 || col === 0 || row === size - 1 || col === size - 1;
                    if (preset === 'checker') on = (row + col) % 2 === 0;
                    line += on ? '#' : '.';
                }
                rows.push(line);
            }
            return rows.join('\n');
        }

        function loadPresetBoard(preset: string) {
            const map = buildPresetMapString(String(preset || '').toLowerCase());
            applyManualMap(map);
        }

        function applyManualMap(input: string) {
            clearPendingTimers();
            isAnimatingWin = false;
            grid.style.pointerEvents = '';
            setAllLights(false);

            const raw = String(input || '').trim();
            if (!raw) return;

            // Strict grid mode: rows separated by newline or '/'.
            // '#' means ON, '.' means OFF.
            const lines = (raw.includes('/') ? raw.split('/') : raw.split(/\r?\n/))
                .map((line) => line.trim())
                .filter(Boolean);

            for (let row = 0; row < Math.min(lines.length, size); row += 1) {
                const line = lines[row];
                for (let col = 0; col < Math.min(line.length, size); col += 1) {
                    const ch = line[col];
                    const index = row * size + col;
                    const light = lights[index];
                    if (!light) continue;
                    if (ch === '#') {
                        light.setAttribute('data-on', 'true');
                    } else if (ch === '.') {
                        light.setAttribute('data-on', 'false');
                    }
                }
            }
        }

        function startWinSequence() {
            if (isAnimatingWin) return;

            isAnimatingWin = true;
            grid.style.pointerEvents = 'none';

            const nextScore = getLocalScore() + 1;
            setLocalScore(nextScore);
            renderScore(nextScore);
            syncScoreWithServer();

            let step = 0;
            const totalSteps = 6; // on/off repeated 3 times

            const tick = () => {
                if (step >= totalSteps) {
                    const restartTimer = window.setTimeout(() => {
                        resetBoard();
                    }, 180);
                    pendingTimers.push(restartTimer);
                    return;
                }

                setAllLights(step % 2 === 0);
                step += 1;

                const nextTimer = window.setTimeout(tick, 140);
                pendingTimers.push(nextTimer);
            };

            tick();
        }

        window.addEventListener('boardDebugLightsOutWin', () => {
            startWinSequence();
        });

        window.addEventListener('boardDebugLightsOutReset', () => {
            resetBoard();
        });

        window.addEventListener('boardDebugLightsOutPreset', (event) => {
            const custom = event as CustomEvent<{ preset?: string }>;
            const preset = custom?.detail?.preset;
            if (!preset) return;
            loadPresetBoard(preset);
        });

        window.addEventListener('boardDebugLightsOutManualMap', (event) => {
            const custom = event as CustomEvent<{ input?: string }>;
            const input = custom?.detail?.input;
            if (typeof input !== 'string') return;
            applyManualMap(input);
        });

        resetBoard();
        renderScore(getLocalScore());
        syncScoreWithServer();
        scheduleTopOfHourSync();

        grid.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            if (target.classList.contains('light')) {
                handlePress(parseInt(target.dataset.index || '0'));
            }
        });

        grid.style.setProperty('--grid-size', size.toString());
    }

    initGame();
</script>