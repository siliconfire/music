---
const { mode = "normal", title = "Şifre değiştir", dismissHref = "/", showSave = true, themed = false } = Astro.props;
---

<div
    class={`set-password-panel my-4 p-4 inline-block ${themed ? 'board-theme-card board-theme-border board-theme-text-primary' : 'border-slate-300 border rounded'}`}
    data-mode={mode}
    data-dismiss-href={dismissHref}
    data-show-save={showSave ? 'true' : 'false'}
>
    <div class="font-medium" data-title>{title}</div>
    <div class={`mt-2 text-sm ${themed ? 'board-theme-text-secondary' : 'text-slate-600'}`} data-message></div>
    <div class="mt-2" id="password-notice"></div>
    <label class="block mt-2">
        Yeni şifre
        <input data-password type="password" class={`border ${themed ? 'board-theme-border bg-transparent px-2 py-1' : 'border-slate-200'}`} />
    </label>
    <label class="block mt-2">
        Yeni şifre (tekrar)
        <input data-confirm type="password" class={`border ${themed ? 'board-theme-border bg-transparent px-2 py-1' : 'border-slate-200'}`} />
    </label>
    <button data-save class={`mt-3 border px-3 py-2${themed ? ' board-theme-border' : ' border-slate-300 bg-green-100'}${showSave ? '' : ' hidden'}`}>
        Şifreyi Kaydet
    </button>
    <div class="mt-4">
        <button data-dismiss class={`hidden text-sm underline ${themed ? 'board-theme-text-secondary' : 'text-slate-600'}`}>Şimdilik istemiyorum</button>
    </div>
</div>

<script>
    import { API_URL } from '../lib/constants';

    const panels = document.querySelectorAll('.set-password-panel');

    panels.forEach((panel) => {
        const messageEl = panel.querySelector('[data-message]');
        const noticeEl = panel.querySelector('#password-notice');
        const passwordInput = panel.querySelector('[data-password]');
        const confirmInput = panel.querySelector('[data-confirm]');
        const saveBtn = panel.querySelector('[data-save]');
        const dismissBtn = panel.querySelector('[data-dismiss]');

        if (!messageEl || !noticeEl || !passwordInput || !confirmInput || !saveBtn || !dismissBtn) {
            return;
        }

        if (panel.getAttribute('data-show-save') === 'false') {
            saveBtn.classList.add('hidden');
        }

        let mode = panel.getAttribute('data-mode') || 'normal';
        if (mode === 'query') {
            const params = new URLSearchParams(window.location.search);
            mode = params.get('mode') || 'normal';
        }

        function setMessage(text) {
            messageEl.textContent = text || '';
        }

        function showNotice(msg, type = 'info') {
            noticeEl.innerHTML = `<div class="p-2 rounded border ${type === 'error' ? 'bg-red-100 border-red-300 text-red-700' : 'bg-green-100 border-green-300 text-green-700'}">${msg}</div>`;
            setTimeout(() => { if (noticeEl.innerHTML) noticeEl.innerHTML = ''; }, 5000);
        }

        function applyMode() {
            dismissBtn.classList.add('hidden');
            if (mode === 'forced') {
                setMessage('Devam etmek için şifre belirlemeniz gerekiyor.');
            } else if (mode === 'nudge') {
                setMessage('İsterseniz şimdi bir şifre belirleyebilirsiniz.');
                dismissBtn.classList.remove('hidden');
            } else if (mode === 'silent') {
                setMessage('');
            } else {
                setMessage('');
            }
        }

        async function submitPassword() {
            const token = localStorage.getItem('jwt_token');
            const password = passwordInput.value.trim();
            const confirm = confirmInput.value.trim();

            if (!password) {
                showNotice('Şifre boş olamaz.', 'error');
                return false;
            }
            if (password !== confirm) {
                showNotice('Şifreler eşleşmiyor.', 'error');
                return false;
            }

            try {
                const res = await fetch(`${API_URL}/me/password`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Session-ID': token
                    },
                    body: JSON.stringify({ password, confirm })
                });

                const data = await res.json().catch(() => ({}));
                if (!res.ok) {
                    showNotice(data.detail || 'Şifre kaydedilemedi.', 'error');
                    return false;
                }

                passwordInput.value = '';
                confirmInput.value = '';
                showNotice('Şifre kaydedildi.');
                return true;
            } catch (err) {
                showNotice('Sunucu hatası.', 'error');
                return false;
            }
        }

        function handleDismiss() {
            const href = panel.getAttribute('data-dismiss-href') || '/';
            window.location.href = href;
        }

        saveBtn.addEventListener('click', submitPassword);
        dismissBtn.addEventListener('click', handleDismiss);

        panel.addEventListener('set-password:submit', async () => {
            const ok = await submitPassword();
            panel.dispatchEvent(new CustomEvent(ok ? 'set-password:success' : 'set-password:error'));
        });

        applyMode();
    });
</script>
