<div id="board-restart-pane" class="hidden fixed top-6 right-6 z-60 p-4 board-theme-text-primary" style="max-width:40rem; width:calc(100% - 3rem); background: rgba(255,255,255,0.04); backdrop-filter: blur(20px) saturate(120%); -webkit-backdrop-filter: blur(20px) saturate(120%); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 6px 18px rgba(2,6,23,0.06);">
    <button id="board-restart-close" class="absolute top-2 right-2 border px-2 py-1 text-sm" aria-label="Kapat" style="border-color: var(--board-card-pinned-border, var(--board-card-pinned-border, #b45309));">X</button>
    <div id="board-debug-pin" class="hidden mb-3">
        <!-- pin display: transparent so underlying page shows through; text uses theme color -->
        <div id="board-debug-pin-display" class="mt-1 px-3 py-2 text-xl tracking-wide min-h-8 board-theme-text-primary" style="background: transparent; border: none; font-family: inherit;"><i>bin dört yüz elli üç? ve ardından kare?</i></div>
        <div id="board-debug-pin-error" class="mt-1 text-xs text-red-600 hidden">PIN hatalı.</div>
        <div class="mt-2 flex flex-wrap gap-4 items-start">
            <div>
                <div class="grid grid-cols-3 gap-2 max-w-40">
                    <button class="board-pin-btn px-2 p-1 text-xl debug-btn" data-pin="1">1</button>
                    <button class="board-pin-btn px-2 p-1 text-xl debug-btn" data-pin="2">2</button>
                    <button class="board-pin-btn px-2 p-1 text-xl debug-btn" data-pin="3">3</button>
                    <button class="board-pin-btn px-2 p-1 text-xl debug-btn" data-pin="4">4</button>
                    <button class="board-pin-btn px-2 p-1 text-xl debug-btn" data-pin="5">5</button>
                    <button class="board-pin-btn px-2 p-1 text-xl debug-btn" data-pin="6">6</button>
                </div>
                <div class="mt-2 flex gap-2">
                    <button id="board-pin-clear" class="px-2 p-1 text-2xl debug-btn">*</button>
                    <button id="board-pin-submit" class="px-2 p-1 text-2xl debug-btn">#</button>
                </div>
            </div>
            <div class="hidden sm:block w-px self-stretch" style="background-color: var(--board-card-pinned-border, var(--board-card-pinned-bg-rgba, #b45309));"></div>
            <div class="flex flex-col gap-2">
                <label for="board-pin-freeform" class="sr-only">Serbest giriş</label>
                <textarea id="board-pin-freeform" class="board-debug-freeform debug-input text-2xl font-mono" placeholder="Serbest giriş" style="min-width:0; width:100%; min-height:6rem; resize:vertical;"></textarea>
                <button id="board-pin-freeform-send" class="debug-btn">Gönder</button>
            </div>
        </div>
    </div>
    <div id="board-restart-controls" class="flex flex-wrap gap-2 hidden">
        <button id="board-restart-btn-manual" class="debug-btn">Yeniden başlat</button>
        <button id="board-fullscreen-enter" class="debug-btn">Tam ekrana gir</button>
        <button id="board-fullscreen-exit" class="debug-btn">Tam ekrandan çık</button>
        <button id="board-auth-start" class="debug-btn">Doğrulamayı başlat</button>
        <button id="board-auth-logout-debug" class="debug-btn">Çıkış yap</button>
        <button id="board-browser-toggle" class="debug-btn">cihaz bilgisini göster</button>
        <details class="debug-btn">
            <summary>Debug</summary>
            <a class="debug-btn" href="/debug/posthog">Posthog</a>
            <a class="debug-btn" href="/debug/events">Events</a>
            <a class="debug-btn" href="/debug/screen">Screen</a>
            <a class="debug-btn" href="/debug/spinner">spinner</a>

        </details>
        <div id="board-browser-info" class="mt-2 text-sm hidden" aria-live="polite"></div>
        <div class="flex items-center gap-2 text-sm">
            <input id="board-hide-qr-btn" type="checkbox" class="border" style="border-color: var(--board-warning-border, var(--board-card-pinned-border, #b45309));" />
            <label for="board-hide-qr-btn">QR butonunu gizle</label>
        </div>
    </div>
    <div id="board-auth-panel" class="hidden mt-3 border p-3 relative" style="max-width:40rem; width:calc(100% - 3rem); background: rgba(255,255,255,0.04); backdrop-filter: blur(20px) saturate(120%); -webkit-backdrop-filter: blur(20px) saturate(120%); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 6px 18px rgba(2,6,23,0.06); border-color: var(--board-warning-border, var(--board-card-pinned-border, #b45309));">
        <button id="board-auth-close" class="absolute top-2 right-2 debug-btn" aria-label="Kapat">Kapat</button>
        <div class="text-lg">Oturumun doğrulanabilmesi ve cihaza bir JWT anahtarı verilebilmesi için, lütfen "admin" yada daha yüksek yetkiye sahip bir cihazdan bu QR kodu okutun.</div>
        <div class="text-slate-600 mt-2" id="board-auth-status">Onay gelince otomatik olarak güncellenecek.</div>
        <div class="mt-2 inline-block">
            <img id="board-auth-qr" alt="QR" class="w-56 h-56 border border-slate-200" />
            <div class="text-xs text-slate-500 mt-2" id="board-auth-link"></div>
        </div>
    </div>
</div>

<div id="board-secret-photo" class="hidden fixed inset-0 z-40 bg-black/90 flex items-center justify-center">
    <img id="board-secret-photo-img" data-photo-src="/special.jpg" alt="Foto" class="max-w-[90vw] max-h-[90vh] object-contain" />
</div>

<script>
    import { API_URL } from '../lib/constants';

    const tapFirstEl = document.getElementById('tap-bartin');
    const tapSecondEl = document.getElementById('tap-lisesi');
    const restartPaneEl = document.getElementById('board-restart-pane');
    const restartBtnEl = document.getElementById('board-restart-btn-manual');
    const restartCloseEl = document.getElementById('board-restart-close');
    const restartSplashEl = document.getElementById('board-restart-splash');
    const fullscreenEnterEl = document.getElementById('board-fullscreen-enter');
    const fullscreenExitEl = document.getElementById('board-fullscreen-exit');
    const debugPinEl = document.getElementById('board-debug-pin');
    const debugPinDisplayEl = document.getElementById('board-debug-pin-display');
    const debugPinErrorEl = document.getElementById('board-debug-pin-error');
    const debugPinButtons = document.querySelectorAll('.board-pin-btn');
    const debugPinClearEl = document.getElementById('board-pin-clear');
    const debugPinSubmitEl = document.getElementById('board-pin-submit');
    const debugPinFreeformEl = document.getElementById('board-pin-freeform');
    const debugPinFreeformSendEl = document.getElementById('board-pin-freeform-send');
    const debugControlsEl = document.getElementById('board-restart-controls');
    const secretPhotoEl = document.getElementById('board-secret-photo');
    const secretPhotoImgEl = document.getElementById('board-secret-photo-img');
    const authStartEl = document.getElementById('board-auth-start');
    const authLogoutEl = document.getElementById('board-auth-logout-debug');
    const authPanelEl = document.getElementById('board-auth-panel');
    const authQrEl = document.getElementById('board-auth-qr');
    const authLinkEl = document.getElementById('board-auth-link');
    const authStatusEl = document.getElementById('board-auth-status');
    const hideQrButtonEl = document.getElementById('board-hide-qr-btn');
    const browserInfoEl = document.getElementById('board-browser-info');
    const browserToggleEl = document.getElementById('board-browser-toggle');

    const tapPattern = [1];
    let tapHistory = [];
    let restartPaneTimer = null;
    let pinUnlocked = false;
    let enteredPin = '';
    const debugPinValue = '64531221';
    const debugPinTwoValue = '91732847848741294632217461239374';
    const debugTotpSecret = localStorage.getItem('board_debug_totp') || '';
    let secretPhotoTimer = null;
    let freeformRaw = '';
    let authPollTimer = null;
    let authQrReady = false;
    const hideQrButtonKey = 'board.hideQrButton';

    function showRestartSplash(delayMs) {
        if (restartSplashEl) {
            restartSplashEl.classList.remove('hidden');
        }
        setTimeout(() => {
            location.reload();
        }, delayMs);
    }

    window['boardShowRestartSplash'] = showRestartSplash;

    function showSecretPhoto() {
        if (!secretPhotoEl) return;
        if (secretPhotoImgEl) {
            const src = secretPhotoImgEl.getAttribute('data-photo-src');
            if (src) {
                secretPhotoImgEl.setAttribute('src', src);
            }
        }
        secretPhotoEl.classList.remove('hidden');
        if (secretPhotoTimer) {
            clearTimeout(secretPhotoTimer);
        }
        secretPhotoTimer = setTimeout(hideSecretPhoto, 5000);
    }

    function hideSecretPhoto() {
        if (!secretPhotoEl) return;
        secretPhotoEl.classList.add('hidden');
        if (secretPhotoTimer) {
            clearTimeout(secretPhotoTimer);
            secretPhotoTimer = null;
        }
    }

    function updatePinDisplay() {
        if (!debugPinDisplayEl) return;
        const masked = enteredPin ? buildPixelMask(enteredPin.length) : 'bin dört yüz elli üç? ve ardından kare?';
        debugPinDisplayEl.textContent = masked;
    }

    function setPinError(show) {
        if (!debugPinErrorEl) return;
        debugPinErrorEl.classList.toggle('hidden', !show);
    }

    function buildPixelMask(length) {
        // const symbols = ['▣', '▤', '▥', '▦', '▧', '▨', '▩', '■'];
        // const symbols = ['←', '↑', '→', '↓']
        const symbols = ['←', '↑', '→', '↓', '↔', '↕', '↖', '↗', '↘', '↙', '↚', '↛', '↜', '↝', '↞', '↟', '↠', '↡', '↢', '↣', '↤', '↥', '↦', '↧', '↨', '↩', '↪', '↫', '↬', '↭', '↮', '↯', '↰', '↱', '↲', '↳', '↴', '↵', '↶', '↷', '↸', '↹', '↺', '↻', '↼', '↽', '↾', '↿', '⇀', '⇁', '⇂', '⇃', '⇄', '⇅', '⇆', '⇇', '⇈', '⇉', '⇊', '⇋', '⇌', '⇍', '⇎', '⇏', '⇐', '⇑', '⇒', '⇓', '⇔', '⇕', '⇖', '⇗', '⇘', '⇙', '⇚', '⇛', '⇜', '⇝', '⇞', '⇟', '⇠', '⇡', '⇢', '⇣', '⇤', '⇥', '⇦', '⇧', '⇨', '⇩', '⇪', '⇫', '⇬', '⇭', '⇮', '⇯', '⇰', '⇱', '⇲', '⇳', '⇴', '⇵', '⇶', '⇷', '⇸', '⇹', '⇺', '⇻', '⇼', '⇽', '⇾', '⇿']
        let result = '';
        for (let i = 0; i < length; i += 1) {
            result += symbols[Math.floor(Math.random() * symbols.length)];
        }
        return result;
    }

    function renderFreeform() {
        if (!debugPinFreeformEl) return;
        const masked = freeformRaw.length <= 1
            ? freeformRaw
            : `${buildPixelMask(freeformRaw.length - 1)}${freeformRaw.slice(-1)}`;
        if (debugPinFreeformEl instanceof HTMLTextAreaElement) {
            debugPinFreeformEl.value = masked;
        }
    }

    function applyFreeformInput(inputType, data) {
        if (pinUnlocked) return;
        if (inputType === 'insertText') {
            freeformRaw += data ?? '';
            renderFreeform();
            return;
        }
        if (inputType === 'insertFromPaste') {
            freeformRaw += data ?? '';
            renderFreeform();
            return;
        }
        if (inputType === 'deleteContentBackward') {
            freeformRaw = freeformRaw.slice(0, -1);
            renderFreeform();
            return;
        }
        if (inputType === 'deleteContentForward') {
            freeformRaw = freeformRaw.slice(1);
            renderFreeform();
            return;
        }
        if (inputType === 'insertLineBreak') {
            freeformRaw += '\n';
            renderFreeform();
        }
    }

    function base32ToBytes(input) {
        const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ234567';
        const clean = String(input || '').toUpperCase().replace(/=+$/g, '').replace(/\s+/g, '');
        let bits = '';
        for (let i = 0; i < clean.length; i += 1) {
            const idx = alphabet.indexOf(clean[i]);
            if (idx === -1) continue;
            bits += idx.toString(2).padStart(5, '0');
        }
        const bytes = [];
        for (let i = 0; i + 8 <= bits.length; i += 8) {
            bytes.push(parseInt(bits.slice(i, i + 8), 2));
        }
        return new Uint8Array(bytes);
    }

    async function hotp(secretBytes, counter) {
        const counterBuf = new ArrayBuffer(8);
        const view = new DataView(counterBuf);
        const high = Math.floor(counter / 0x100000000);
        const low = counter >>> 0;
        view.setUint32(0, high);
        view.setUint32(4, low);
        const key = await crypto.subtle.importKey(
            'raw',
            secretBytes,
            { name: 'HMAC', hash: 'SHA-1' },
            false,
            ['sign']
        );
        const sig = new Uint8Array(await crypto.subtle.sign('HMAC', key, counterBuf));
        const offset = sig[sig.length - 1] & 0x0f;
        const code = ((sig[offset] & 0x7f) << 24)
            | ((sig[offset + 1] & 0xff) << 16)
            | ((sig[offset + 2] & 0xff) << 8)
            | (sig[offset + 3] & 0xff);
        return String(code % 1000000).padStart(6, '0');
    }

    async function verifyTotp(code) {
        if (!debugTotpSecret) return false;
        const secretBytes = base32ToBytes(debugTotpSecret);
        const cleanCode = String(code || '').trim();
        if (!cleanCode) return false;
        const counter = Math.floor(Date.now() / 1000 / 30);
        for (let offset = -1; offset <= 1; offset += 1) {
            const expected = await hotp(secretBytes, counter + offset);
            if (expected === cleanCode) {
                return true;
            }
        }
        return false;
    }

    async function submitPin(value) {
        if (pinUnlocked) return;
        const nextValue = value ? String(value).trim() : '';
        enteredPin = nextValue;
        updatePinDisplay();
        if (!nextValue) {
            setPinError(true);
            return;
        }
        if (nextValue === debugPinValue) {
            showDebugControls();
            return;
        }
        if (nextValue === debugPinTwoValue) {
            showDebugControls();
            return;
        }
        if (await verifyTotp(nextValue)) {
            showDebugControls();
            return;
        }
        if (nextValue === '1453') {
            showSecretPhoto();
            return;
        }
        setPinError(true);
    }

    function collectBrowserInfo() {
        const nav = window.navigator;
        const screenEl = window.screen;
        // connection may be vendor-prefixed or not present — use `any` to avoid type errors
        const conn = (nav as any).connection || (nav as any).mozConnection || (nav as any).webkitConnection || {};
        return {
            userAgent: nav.userAgent || '',
            platform: nav.platform || '',
            language: nav.language || (nav.languages && nav.languages[0]) || '',
            cookieEnabled: Boolean((nav as any).cookieEnabled),
            doNotTrack: (nav as any).doNotTrack || (navigator as any).msDoNotTrack || '',
            vendor: (nav as any).vendor || '',
            appVersion: (nav as any).appVersion || '',
            deviceMemory: (nav as any).deviceMemory || null,
            hardwareConcurrency: (nav as any).hardwareConcurrency || null,
            screenWidth: screenEl?.width || null,
            screenHeight: screenEl?.height || null,
            viewportWidth: Math.max(document.documentElement.clientWidth || 0, window.innerWidth || 0),
            viewportHeight: Math.max(document.documentElement.clientHeight || 0, window.innerHeight || 0),
            connection: {
                effectiveType: (conn && (conn as any).effectiveType) || '',
                downlink: (conn && (conn as any).downlink) || null,
                rtt: (conn && (conn as any).rtt) || null
            }
        };
    }

    function renderBrowserInfo() {
        if (!browserInfoEl) return;
        const info = collectBrowserInfo();
        // Render as simple preformatted JSON so styles are untouched
        browserInfoEl.innerHTML = '<pre style="margin:0; white-space:pre-wrap;">' + escapeHtml(JSON.stringify(info, null, 2)) + '</pre>';
    }

    function escapeHtml(str) {
        return String(str).replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    function showDebugControls() {
        pinUnlocked = true;
        if (debugPinEl) debugPinEl.classList.add('hidden');
        if (debugControlsEl) debugControlsEl.classList.remove('hidden');
        // Update browser info when controls are shown only if visible
        if (browserInfoEl && !browserInfoEl.classList.contains('hidden')) {
            renderBrowserInfo();
        }
    }

    function resetPinpad() {
        pinUnlocked = false;
        enteredPin = '';
        updatePinDisplay();
        setPinError(false);
        freeformRaw = '';
        renderFreeform();
        if (debugPinEl) debugPinEl.classList.remove('hidden');
        if (debugControlsEl) debugControlsEl.classList.add('hidden');
    }

    function hideRestartPane() {
        if (restartPaneEl) {
            restartPaneEl.classList.add('hidden');
        }
        if (restartPaneTimer) {
            clearTimeout(restartPaneTimer);
            restartPaneTimer = null;
        }
        // ensure auth panel closes when whole debug pane is closed
        hideAuthPanel();
        resetPinpad();
    }

    function showRestartPane() {
        if (restartPaneEl) {
            restartPaneEl.classList.remove('hidden');
        }
        if (restartPaneTimer) {
            clearTimeout(restartPaneTimer);
        }
        resetPinpad();
        // start the auto-hide timeout (60s)
        restartPaneTimer = setTimeout(hideRestartPane, 60000);
    }

    function recordTap(value) {
        tapHistory.push(value);
        if (tapHistory.length > tapPattern.length) {
            tapHistory = tapHistory.slice(-tapPattern.length);
        }
        if (tapHistory.length !== tapPattern.length) {
            return;
        }
        for (let i = 0; i < tapPattern.length; i += 1) {
            if (tapHistory[i] !== tapPattern[i]) {
                return;
            }
        }
        tapHistory = [];
        showRestartPane();
    }

    if (tapFirstEl) {
        tapFirstEl.addEventListener('click', () => recordTap(1));
    }

    if (tapSecondEl) {
        tapSecondEl.addEventListener('click', () => recordTap(2));
    }

    if (restartBtnEl) {
        restartBtnEl.addEventListener('click', () => showRestartSplash(500));
    }

    if (restartCloseEl) {
        restartCloseEl.addEventListener('click', hideRestartPane);
    }

    if (hideQrButtonEl) {
        initHideQrButtonSetting();
        hideQrButtonEl.addEventListener('change', () => {
            syncHideQrButtonSetting(hideQrButtonEl instanceof HTMLInputElement ? hideQrButtonEl.checked : false);
        });
    }

    // Initialize browser toggle button state and handler (safe runtime checks)
    if (browserToggleEl instanceof HTMLButtonElement) {
        // Set initial label based on whether the info container is hidden
        const initiallyHidden = browserInfoEl ? browserInfoEl.classList.contains('hidden') : true;
        browserToggleEl.textContent = initiallyHidden ? 'cihaz bilgisini göster' : '...gizle';
        browserToggleEl.addEventListener('click', () => {
            if (!browserInfoEl) return;
            const isHidden = browserInfoEl.classList.toggle('hidden');
            browserToggleEl.textContent = isHidden ? 'cihaz bilgisini göster' : '...gizle';
            if (!isHidden) {
                renderBrowserInfo();
            }
        });
    }

    async function enterFullscreen() {
        if (document.fullscreenElement) return;
        try {
            await document.documentElement.requestFullscreen();
        } catch (err) {
            // ignore
        }
    }

    async function exitFullscreen() {
        if (!document.fullscreenElement) return;
        try {
            await document.exitFullscreen();
        } catch (err) {
            // ignore
        }
    }

    if (fullscreenEnterEl) {
        fullscreenEnterEl.addEventListener('click', enterFullscreen);
    }

    if (fullscreenExitEl) {
        fullscreenExitEl.addEventListener('click', exitFullscreen);
    }

    function getDeviceId() {
        const key = 'board_device_id';
        const existing = localStorage.getItem(key);
        if (existing) return existing;
        const generated = `board-${crypto.randomUUID()}`;
        localStorage.setItem(key, generated);
        return generated;
    }

    async function renderBoardQr() {
        if (!authQrEl) return;
        const params = new URLSearchParams({
            board_id: '100000',
            board_name: 'board',
            device_id: getDeviceId()
        });
        const url = `${location.origin}/boardlogin?${params.toString()}`;
        try {
            const { default: QRCode } = await import('qrcode');
            const dataUri = await QRCode.toDataURL(url);
            authQrEl.setAttribute('src', dataUri);
        } catch (err) {
            authQrEl.removeAttribute('src');
        }
        if (authLinkEl) {
            authLinkEl.innerHTML = `<a class="underline" href="${url}">${url}</a>`;
        }
        authQrReady = true;
    }

    async function pollBoardApproval() {
        const deviceId = getDeviceId();
        try {
            const res = await fetch(`${API_URL}/boardlogin/pending?device_id=${encodeURIComponent(deviceId)}`);
            const data = await res.json().catch(() => ({}));
            if (data?.ready && data?.access_token) {
                localStorage.setItem('jwt_token', data.access_token);
                location.href = '/board';
                return;
            }
            if (authStatusEl) {
                authStatusEl.textContent = 'Onay bekleniyor...';
            }
        } catch (err) {
            if (authStatusEl) {
                authStatusEl.textContent = 'Sunucuya bağlanılamadı.';
            }
        }
    }

    function showAuthPanel() {
        if (authPanelEl) {
            authPanelEl.classList.remove('hidden');
        }
        // ensure QR is rendered when panel opens
        if (!authQrReady) {
            renderBoardQr();
        }
        // start poll only if not already running
        if (!authPollTimer) {
            authPollTimer = setInterval(pollBoardApproval, 2000);
            pollBoardApproval();
        }
    }

    function hideAuthPanel() {
        // hide UI
        if (authPanelEl) {
            authPanelEl.classList.add('hidden');
        }
        // stop poll
        if (authPollTimer) {
            clearInterval(authPollTimer);
            authPollTimer = null;
        }
        // clear QR image to release memory
        try {
            if (authQrEl) {
                authQrEl.removeAttribute('src');
            }
        } catch (e) {}
        authQrReady = false;
    }

    function logoutBoard() {
        localStorage.removeItem('jwt_token');
        location.href = '/board/auth';
    }

    if (authStartEl) {
        authStartEl.addEventListener('click', showAuthPanel);
    }

    if (authLogoutEl) {
        authLogoutEl.addEventListener('click', logoutBoard);
    }

    // auth panel close button (inside the panel)
    const authCloseEl = document.getElementById('board-auth-close');
    if (authCloseEl) {
        authCloseEl.addEventListener('click', hideAuthPanel);
    }

    if (debugPinButtons) {
        debugPinButtons.forEach((btn) => {
            btn.addEventListener('click', () => {
                if (pinUnlocked) return;
                const value = btn.getAttribute('data-pin');
                if (!value) return;
                if (enteredPin.length >= 8) return;
                enteredPin += value;
                updatePinDisplay();
                setPinError(false);
            });
        });
    }

    if (debugPinClearEl) {
        debugPinClearEl.addEventListener('click', () => {
            if (pinUnlocked) return;
            enteredPin = '';
            updatePinDisplay();
            setPinError(false);
        });
    }

    if (debugPinSubmitEl) {
        debugPinSubmitEl.addEventListener('click', () => {
            void submitPin(enteredPin);
          });
      }

    if (debugPinFreeformSendEl) {
        debugPinFreeformSendEl.addEventListener('click', () => {
            if (pinUnlocked) return;
            void submitPin(freeformRaw);
        });
    }

    if (debugPinFreeformEl) {
        debugPinFreeformEl.addEventListener('beforeinput', (event) => {
            if (!event || !event.inputType) {
                return;
            }
            event.preventDefault();
            applyFreeformInput(event.inputType, event.data);
        });
        debugPinFreeformEl.addEventListener('input', () => {
            // Fallback path for browsers without beforeinput/inputType support.
            if (debugPinFreeformEl instanceof HTMLTextAreaElement) {
                freeformRaw = debugPinFreeformEl.value || '';
            } else {
                freeformRaw = '';
            }
            renderFreeform();
        });
        debugPinFreeformEl.addEventListener('keydown', (event) => {
            if (event.key !== 'Enter') return;
            event.preventDefault();
            void submitPin(freeformRaw);
        });
    }

    function emitQrButtonVisibility(hidden) {
        window.dispatchEvent(new CustomEvent('boardQrButtonVisibilityChange', {
            detail: { hidden: Boolean(hidden) }
        }));
    }

    function syncHideQrButtonSetting(value) {
        const nextValue = Boolean(value);
        localStorage.setItem(hideQrButtonKey, nextValue ? 'true' : 'false');
        emitQrButtonVisibility(nextValue);
    }

    function initHideQrButtonSetting() {
        const stored = localStorage.getItem(hideQrButtonKey) === 'true';
        if (hideQrButtonEl instanceof HTMLInputElement) {
            hideQrButtonEl.checked = stored;
        }
    }
</script>

