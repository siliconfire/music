---
import Layout from '../../layouts/Layout.astro';
import NowPlaying from '../../components/NowPlaying.astro';
import Queue from '../../components/Queue.astro';
import BoardDebugPanel from '../../components/BoardDebugPanel.astro';
import LightsOut from '../../components/LightsOut.astro';
---

<Layout title="Bartın Lisesi (/board)">
    <h1 class="text-2xl m-10 board-theme-text-primary" id="title"><span id="tap-bartin">Bartın</span> <span id="tap-lisesi">Lisesi</span></h1>
    <BoardDebugPanel />
    <div id="board-theme-backdrop" class="fixed inset-0 -z-10"></div>

    <button id="board-qr-toggle" data-action="board-qr-toggle" class="fixed bottom-4 right-4 z-40 board-qr-button px-3 py-2 text-sm">QR kodu göster</button>
    <div id="board-qr-overlay" class="hidden fixed bottom-16 right-4 z-50" style="background: transparent;">
        <div class="board-qr-card p-4 text-center shadow-lg board-theme-text-primary" style="background: rgba(255,255,255,0.04); backdrop-filter: blur(18px) saturate(120%); -webkit-backdrop-filter: blur(18px) saturate(120%); border: 1px solid rgba(255,255,255,0.08);">
            <div class="text-sm board-theme-text-secondary">Telefonunuz ile tarayın:</div>
            <img id="board-qr-img" alt="QR" class="mt-2 h-64 w-64" style="border: 1px solid var(--board-card-border); background: transparent;" />
            <div id="board-qr-label" class="mt-2 text-sm board-theme-text-secondary"></div>
        </div>
    </div>

    <div class="m-5 lg:m-10">
        <div id="board-auth-warning" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70">
            <div class="border border-yellow-700 bg-yellow-50 p-4 text-sm max-w-xl">
                <p>Bu sayfa tahtada kullanılması için var. Eğer kendi cihazınızdan buraya geldiyseniz lütfen ana sayfaya dönün. Eğer bu ekran tahta ise lütfen çıkış yapıp tekrar deneyin.</p>
                <div class="mt-2 flex flex-wrap gap-2">
                    <a class="underline" href="/">Ana sayfaya dön</a>
                    <button id="board-auth-logout" class="border border-yellow-700 px-2 py-1">Çıkış yap</button>
                </div>
            </div>
        </div>
         <div id="board-status" class="hidden border border-slate-300 bg-slate-50 p-3 text-sm"></div>
         <!-- Transparent overlay so the page doesn't darken; the inner card itself is the frosted glass -->
         <div id="board-restart-splash" class="hidden fixed inset-0 z-40 flex items-center justify-center p-6" style="background: transparent;">
             <div class="max-w-xl w-full p-6 rounded-lg border" style="background: rgba(255,255,255,0.04); backdrop-filter: blur(20px) saturate(120%); -webkit-backdrop-filter: blur(20px) saturate(120%); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 6px 18px rgba(2,6,23,0.06); transition: opacity 240ms ease, transform 240ms ease;">
                 <div class="flex items-start justify-between">
                     <div>
                         <p class="text-4xl font-semibold board-theme-text-primary">Yeniden başlatılıyor...</p>
                         <p class="mt-2 text-sm board-theme-text-secondary">Eğer bu ekranda takılıp kalırsa lütfen yardım isteyin.</p>
                   </div>
                   <img src="/loading.svg" alt="loading" class="ml-4 h-12 w-12" />
                 </div>
             </div>
         </div>
         <!-- Floating frosted-glass error overlay -->
         <div id="board-error" class="fixed inset-0 z-50 flex items-center justify-center" style="pointer-events:none;">
             <div id="board-error-card" class="hidden w-full max-w-3xl p-6 rounded-lg relative" style="pointer-events:auto; background: rgba(255,255,255,0.03); backdrop-filter: blur(18px) saturate(120%); -webkit-backdrop-filter: blur(18px) saturate(120%); border: 1px solid rgba(255,255,255,0.06); box-shadow: 0 12px 36px rgba(2,6,23,0.36);">
                 <!-- Floating 'fixed' notification styled as a pill so it doesn't clash with card padding -->
                 <div id="board-error-fixed" class="hidden" style="position:absolute; top:-0.75rem; right:0.75rem; background: rgba(16,185,129,0.95); color: #fff; border: 1px solid rgba(6,95,70,0.9); padding: 0.35rem 0.65rem; border-radius: 0.5rem; box-shadow: 0 6px 18px rgba(2,6,23,0.15); font-weight:600;">
                     <span>Birazdan yeniden başlatılacak...</span>
                 </div>

                 <div class="mb-4 flex items-start justify-between gap-4">
                     <div>
                         <p class="text-3xl font-semibold board-theme-text-primary">Sunucu neredesin?</p>
                         <p class="mt-2 text-lg board-theme-text-secondary">Sunucu kapalı yada bana yanıt vermiyor.</p>
                     </div>

                     <!-- retrying indicator restored so showLonelyText() updates it correctly -->
                     <div id="div-retrying" class="flex items-center gap-3 text-sm board-theme-text-primary">
                         <img src="/loading.svg" alt="loading" class="h-6 w-6" />
                         <span>Tekrar deneniyor...</span>
                     </div>
                 </div>

                 <div class="mb-4 flex items-center justify-center">
                     <!-- Make QR large enough to scan -->
                     <img id="error-qr" class="h-56 w-56 border rounded" alt="Scan me!" src="/loading.svg" style="border-color: rgba(255,255,255,0.12); background: transparent;" />
                 </div>

                 <div class="mb-4 text-sm board-theme-text-primary text-center">
                     <p>Lütfen bu hatayı karekodu okutarak bana bildirin.</p>
                     <p>Çınar Mert Çeçen - cinar@cinarcecen.dev</p>
                 </div>

                 <div class="mb-4 text-xs board-theme-text-secondary">
                     <p>Kurulum ile sorumlu iseniz önce sayfayı yenilemeyi deneyin. Eğer olmaz ise sunucunun çalıştığından (daha yeni açtıysanız sunucu kendini açmamış olabilir, biraz bekleyin), güvenlik duvarının frontend-backend arasındaki bağlantıya karışmadığından ve <code>board.json</code> dosyasının geçerli olduğundan emin olun. (Tereddüt ederseniz <code>board.json</code> dosyasını önce yedekleyip sonra silebilirsiniz; sunucu yeniden oluşturacaktır.)</p>
                 </div>

                 <div id="board-error-info" class="rounded p-3" style="background: rgba(250,204,21,0.12); border: 1px solid rgba(250,204,21,0.22);">
                     <span id="error-info" class="board-theme-text-primary">(hata bilgileri...)</span>
                 </div>
             </div>
         </div>
        <!-- show the small "connecting..." text, before we go wild -->
        <div id="board-error-mini" class="hidden fixed inset-0 z-50 flex items-center justify-center pointer-events-none">
            <div class="h-20 flex flex-row items-center justify-center rounded-md p-3" style="background: rgba(255,255,255,0.03); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); border: 1px solid rgba(255,255,255,0.06);">
                <img src="/loading.svg" alt="loading" class="h-8 w-8 mr-2" />
                <div id="div-retrying-mini" class="mt-2 text-lg board-theme-text-primary">Sunucu ile bağlantı kurmakta zorlanıyorum...</div>
            </div>
        </div>
     </div>

    <div class="m-5 lg:m-10">
        <div id="board-widgets" class="widgets-intro-hidden flex flex-wrap gap-5"></div>
    </div>

    <template id="tpl-now-playing">
        <NowPlaying />
    </template>
    <template id="tpl-queue">
        <Queue showControls={false} showHeader={false} />
    </template>
    <template id="tpl-lights-out">
        <LightsOut />
    </template>
    <script>
        // @ts-nocheck
        import { API_URL } from '../../lib/constants';

        /** @type {HTMLElement|null} */
        const statusEl = /** @type {HTMLElement|null} */ (document.getElementById('board-status'));
        /** @type {HTMLElement|null} */
        const errorEl = /** @type {HTMLElement|null} */ (document.getElementById('board-error'));
        /** @type {HTMLElement|null} */
        const errorInfoEl = /** @type {HTMLElement|null} */ (document.getElementById('error-info'));
        /** @type {HTMLImageElement|null} */
        const errorQrEl = /** @type {HTMLImageElement|null} */ (document.getElementById('error-qr'));
        /** @type {HTMLElement|null} */
        const widgetsEl = /** @type {HTMLElement|null} */ (document.getElementById('board-widgets'));
        /** @type {HTMLTemplateElement|null} */
        const nowPlayingTemplate = /** @type {HTMLTemplateElement|null} */ (document.getElementById('tpl-now-playing'));
        /** @type {HTMLTemplateElement|null} */
        const queueTemplate = /** @type {HTMLTemplateElement|null} */ (document.getElementById('tpl-queue'));
        /** @type {HTMLTemplateElement|null} */
        const lightsOutTemplate = /** @type {HTMLTemplateElement|null} */ (document.getElementById('tpl-lights-out'));
        /** @type {HTMLElement|null} */
        const authWarningEl = /** @type {HTMLElement|null} */ (document.getElementById('board-auth-warning'));
        /** @type {HTMLElement|null} */
        const authLogoutEl = /** @type {HTMLElement|null} */ (document.getElementById('board-auth-logout'));
        /** @type {HTMLElement|null} */
        const errorFixedEl = /** @type {HTMLElement|null} */ (document.getElementById('board-error-fixed'));
        /** @type {HTMLElement|null} */
        const retryingEl = /** @type {HTMLElement|null} */ (document.getElementById('div-retrying'));
        /** @type {HTMLElement|null} */
        const retryingMiniEl = /** @type {HTMLElement|null} */ (document.getElementById('div-retrying-mini'));
        /** @type {HTMLElement|null} */
        const errorMiniEl = /** @type {HTMLElement|null} */ (document.getElementById('board-error-mini'));
        /** @type {HTMLButtonElement|null} */
        const qrToggleEl = /** @type {HTMLButtonElement|null} */ (document.getElementById('board-qr-toggle'));
        /** @type {HTMLElement|null} */
        const qrOverlayEl = /** @type {HTMLElement|null} */ (document.getElementById('board-qr-overlay'));
        /** @type {HTMLImageElement|null} */
        const qrImgEl = /** @type {HTMLImageElement|null} */ (document.getElementById('board-qr-img'));
        /** @type {HTMLElement|null} */
        const qrLabelEl = /** @type {HTMLElement|null} */ (document.getElementById('board-qr-label'));
        /** @type {HTMLElement|null} */
        const qrHideEl = /** @type {HTMLElement|null} */ (document.getElementById('board-qr-hide'));
        /** @type {HTMLElement|null} */
        const themeBackdropEl = /** @type {HTMLElement|null} */ (document.getElementById('board-theme-backdrop'));
        const hideQrButtonKey = 'board.hideQrButton';
        let qrReady = false;
        let qrAutoHideTimer = null;
        let confettiCanvas = null;
        let confettiActive = false;
        let lastConfettiId = null;
        let lastThemeKey = null;
        let lastBackgroundKey = null;
        let lastBackdropBlur = null;
        let lastCardBlur = null;
        let themeConfettiColors = null;
        let initialConfettiShown = false;
        const restartStorageKey = 'board.restartTriggerId';
        let lastRestartId = sessionStorage.getItem(restartStorageKey);
        const redirectStorageKey = 'board.redirectTriggerId';
        let lastRedirectId = sessionStorage.getItem(redirectStorageKey);
        const INACTIVITY_RESET_MS = 10 * 60 * 1000;
        let inactivityTimer = null;

        function trackBoardAction(event, props = {}) {
            if (window.posthog?.capture) {
                window.posthog.capture(event, props);
            }
        }

        function scheduleInactivityReset() {
            if (inactivityTimer) {
                clearTimeout(inactivityTimer);
            }
            inactivityTimer = setTimeout(() => {
                window.posthog?.reset();
            }, INACTIVITY_RESET_MS);
        }

        function startInactivityWatcher() {
            scheduleInactivityReset();
            const events = ['pointerdown', 'pointermove', 'keydown', 'touchstart', 'wheel', 'scroll'];
            const handler = () => scheduleInactivityReset();
            events.forEach((event) => window.addEventListener(event, handler, { passive: true }));
        }

        function handleRestartTrigger(data) {
            const restartId = data?.restart_trigger?.id;
            if (!restartId) {
                return false;
            }
            if (!lastRestartId) {
                lastRestartId = restartId;
                sessionStorage.setItem(restartStorageKey, restartId);
                return false;
            }
            if (restartId !== lastRestartId) {
                lastRestartId = restartId;
                sessionStorage.setItem(restartStorageKey, restartId);
                if (window.boardShowRestartSplash) {
                    window.boardShowRestartSplash(500);
                } else {
                    location.reload();
                }
                return true;
            }
            return false;
        }

        function handleRedirectTrigger(data) {
            const triggerId = data?.redirect_trigger?.id;
            if (!triggerId) {
                return false;
            }
            const path = data?.redirect_trigger?.path;
            if (!lastRedirectId) {
                lastRedirectId = triggerId;
                sessionStorage.setItem(redirectStorageKey, triggerId);
            }
            if (triggerId === lastRedirectId) {
                return false;
            }
            lastRedirectId = triggerId;
            sessionStorage.setItem(redirectStorageKey, triggerId);
            if (typeof path === 'string' && path.trim()) {
                const target = path.trim();
                if (location.pathname !== target) {
                    location.href = target;
                    return true;
                }
            }
            return false;
        }


        const mailtoConfig = {
            email: 'cinar@cinarcecen.dev',
            subject: 'Tahta hatası #74100',
            body: 'Eğer bu hata hakkında bilgiye sahipseniz lütfen aşağıdaki çizginin altına yazın. Değilseniz böyle da gönderebilirsiniz. Teşekkürler.\n----------'
        };

        function buildMailto(extraInfo = '') {
            const details = extraInfo ? `${extraInfo}\n\n` : '';
            const body = `${details}${mailtoConfig.body}`;
            return `mailto:${mailtoConfig.email}?subject=${encodeURIComponent(mailtoConfig.subject)}&body=${encodeURIComponent(body)}`;
        }

        async function renderErrorQr(extraInfo = '') {
            if (!errorQrEl) return;
            try {
                const { default: QRCode } = await import('qrcode');
                const dataUri = await QRCode.toDataURL(buildMailto(extraInfo));
                // show error info on screen
                if (errorInfoEl) {
                    errorInfoEl.textContent = extraInfo;
                }
                // sorry for the delay, but i spent a while on the loading svg so i HAVE to show it off
                setTimeout(() => {
                    errorQrEl.src = dataUri;
                }, 1500);
            } catch (err) {
                errorQrEl.removeAttribute('src');
            }
        }

        renderErrorQr();

        const typeLabels = {
            'controls': 'Kontroller',
            'now-playing': 'Şimdi Çalıyor',
            'search': 'Ara',
            'queue': 'Kuyruk',
            'text-block': 'Metin',
            'clock': 'Saat',
            'lights-out': 'Işıklar'
        };

        const displayTypes = new Set(['now-playing', 'queue', 'text-block', 'poll', 'clock', 'controls', 'lights-out']);

        let boardData = null;
        let lastUpdatedAt = null;
        let lastWidgetStamp = null;
        let voteCooldownUntil = 0;
        let refreshTimer = null;
        let retryTimer = null;
        let hideErrorTimer = null;
        let errorVisible = false;
        let consecutiveFailures = 0;
        let firstFailureAt = null;
        const miniRetryStages = [
            { tryAfter: 1, text: 'Sunucuya bağlanılıyor...' },
            { tryAfter: 3, text: 'Sunucuya bağlanılamıyor...?' },
            { tryAfter: 5, text: 'Hâla bağlanmayı deniyorum.' },
            { tryAfter: 6, text: 'Hâla bağlanmayı deniyorum..' },
            { tryAfter: 7, text: 'Hâla bağlanmayı deniyorum...' },
            { tryAfter: 9, text: 'Sunucuya bağlanabileceğimize inanıyorum.' },
            { tryAfter: 11, text: 'Sunucu? Neredesin??' },
            { tryAfter: 12, text: 'Sunucuya bağlanacağız. Umudum yüksek.' },
            { tryAfter: 14, text: 'Sunucuya bağlanacağız. Umudum yüksek (değil)' },
            { tryAfter: 16, text: 'Sayın sunucu lütfen kapıyı açar mısınız?' },
            { tryAfter: 18, text: 'Son birkaç kere daha bağlanmayı deneyelim.' },
            { tryAfter: 20, text: 'Son 3...' },
            { tryAfter: 21, text: 'Son 2...' },
            { tryAfter: 22, text: 'Son 1...' },
            { tryAfter: 23, text: '' }
        ];
        const bigErrorThreshold = 24; // when to switch to the big error card (inclusive)

        function getMiniRetryText(count) {
            if (!Array.isArray(miniRetryStages) || miniRetryStages.length === 0) {
                return 'Sunucu ile bağlantı kurmakta zorlanıyorum...';
            }
            // find stages where the current count is above the stage.tryAfter
            const candidates = miniRetryStages.filter(s => Number(count) > Number(s.tryAfter || 0));
            if (candidates.length) {
                // pick the candidate with the largest tryAfter
                candidates.sort((a, b) => Number(b.tryAfter) - Number(a.tryAfter));
                return candidates[0].text;
            }
            // nothing matched (count is not above any listed try value) => use the first stage as default
            return miniRetryStages[0].text;
        }

        let clockTimers = [];
        let widgetIntroRendered = false;
        let widgetIntroHidden = false;

        function clearClockTimers() {
            clockTimers.forEach((timerId) => clearInterval(timerId));
            clockTimers = [];
        }

        function formatClockTime(now, showSeconds) {
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            if (!showSeconds) {
                return `${hours}:${minutes}`;
            }
            const seconds = String(now.getSeconds()).padStart(2, '0');
            return `${hours}:${minutes}:${seconds}`;
        }

        function formatClockDate(now) {
            return now.toLocaleDateString('tr-TR', {
                weekday: 'long',
                day: '2-digit',
                month: 'long',
                year: 'numeric'
            });
        }

        function setVoteCooldown(ms) {
            voteCooldownUntil = Date.now() + ms;
            updateVoteButtons();
            setTimeout(updateVoteButtons, ms + 50);
        }

        function updateVoteButtons() {
            const disabled = Date.now() < voteCooldownUntil;
            document.querySelectorAll('[data-poll-vote]')
                .forEach((btn) => {
                    btn.disabled = disabled;
                    btn.classList.toggle('opacity-50', disabled);
                });
        }

        async function voteOnOption(widgetKey, optionId) {
            if (Date.now() < voteCooldownUntil) {
                return;
            }
            setVoteCooldown(5000);

            // Optimistic update
            if (boardData) {
                const widget = boardData.widgets.find(w => w.key === widgetKey && w.type === 'poll');
                if (widget && widget.options) {
                    const option = widget.options.find(o => o.id === optionId);
                    if (option) {
                        option.votes = (option.votes || 0) + 1;
                        renderBoard();
                    }
                }
            }

            try {
                const res = await fetch(`${API_URL}/board/poll/vote`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ widget_key: widgetKey, option_id: optionId })
                });
                if (!res.ok) {
                    throw new Error();
                }
                // We don't strictly need to refreshBoard() here anymore because the next interval will sync us,
                // but let's keep it to ensure we stay in sync with the server's final count immediately.
                await refreshBoard();
            } catch (err) {
                showStatus('Oy verilemedi.', true);
                // Optionally rollback on error
                await refreshBoard();
            }
        }

        async function triggerBoardRestart() {
            trackBoardAction('board_control_clicked', { action: 'board-restart' });
            const token = localStorage.getItem('jwt_token');
            if (!token) return;
            try {
                const res = await fetch(`${API_URL}/board/restart`, {
                    method: 'POST',
                    headers: { 'X-Session-ID': token }
                });
                if (res.ok) {
                    const data = await res.json();
                    if (data.trigger?.id) {
                        lastRestartId = data.trigger.id;
                        sessionStorage.setItem(restartStorageKey, lastRestartId);
                    }
                    if (window.boardShowRestartSplash) {
                        window.boardShowRestartSplash(500);
                    } else {
                        location.reload();
                    }
                }
            } catch (err) {}
        }

        async function triggerConfetti() {
            trackBoardAction('board_control_clicked', { action: 'board-confetti' });
            const token = localStorage.getItem('jwt_token');
            if (!token) return;
            const config = {
                particleCount: 100,
                sizeScale: 4,
                spread: 0.5,
                durationMs: 3000,
                spawnDurationMs: 1200,
                upwardBoost: 2
            };

            // Pop locally immediately for instant feedback
            popConfetti(config);

            try {
                const res = await fetch(`${API_URL}/board/confetti`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-Session-ID': token },
                    body: JSON.stringify(config)
                });
                if (res.ok) {
                    const data = await res.json();
                    if (data.trigger?.id) {
                        lastConfettiId = data.trigger.id; // Sync ID so the next poll doesn't double-pop
                    }
                }
            } catch (err) {}
        }

        async function pickRandomTheme() {
            trackBoardAction('board_control_clicked', { action: 'board-theme-random' });
            if (!boardData) return;
            const token = localStorage.getItem('jwt_token');
            if (!token) return;
            const presets = Array.isArray(boardData.theme_presets) ? boardData.theme_presets : [];
            if (!presets.length) return;
            const currentKey = boardData.theme_key || boardData.theme?.key || '';
            const choices = presets.filter((preset) => preset.key !== currentKey);
            const list = choices.length ? choices : presets;
            const pick = list[Math.floor(Math.random() * list.length)];
            if (!pick) return;

            // Apply locally immediately
            applyTheme(pick, boardData?.background_image_url || null);
            lastThemeKey = pick.key;

            try {
                await fetch(`${API_URL}/board`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'X-Session-ID': token },
                    body: JSON.stringify({ theme_key: pick.key })
                });
            } catch (err) {}
        }

        function showStatus(message, isError = false) {
            if (!statusEl) return
            statusEl.textContent = message;
            statusEl.classList.remove('hidden');
            statusEl.classList.toggle('border-red-400', isError);
            statusEl.classList.toggle('bg-red-50', isError);
        }

        // Update the retrying text in both the big error card and the mini overlay
        function updateRetryingText() {
            const countText = consecutiveFailures > 0 ? ` (${consecutiveFailures})` : '';
            if (retryingEl) {
                retryingEl.innerHTML = `<img src="/loading.svg" alt="loading" class="w-10 inline" /> Bağlanmaya çalışıyorum...${countText}`;
            }
            // Update the small mini overlay text according to progressive stages (no count appended)
            if (retryingMiniEl) {
                retryingMiniEl.textContent = getMiniRetryText(consecutiveFailures);
            }
        }

        function showMiniError() {
            if (errorMiniEl) errorMiniEl.classList.remove('hidden');
            const errorCardEl = document.getElementById('board-error-card');
            if (errorCardEl) errorCardEl.classList.add('hidden');
            if (errorEl) errorEl.classList.add('hidden'); // keep big outer wrapper hidden when using mini
        }

        function showBigError() {
            if (errorMiniEl) errorMiniEl.classList.add('hidden');
            if (errorEl) errorEl.classList.remove('hidden');
            const errorCardEl = document.getElementById('board-error-card');
            if (errorCardEl) errorCardEl.classList.remove('hidden');
        }

        function hideAllErrorUis() {
            if (errorMiniEl) errorMiniEl.classList.add('hidden');
            if (errorEl) errorEl.classList.add('hidden');
            const errorCardEl = document.getElementById('board-error-card');
            if (errorCardEl) errorCardEl.classList.add('hidden');
        }

        function showLonelyText(extraInfo = '') {
            if (!document) return;
            // track consecutive failures so we can switch between a minimal and a full error UI
            consecutiveFailures = (consecutiveFailures || 0) + 1;
            if (!firstFailureAt) firstFailureAt = Date.now();

            const wasVisible = errorVisible;
            errorVisible = true;
            if (hideErrorTimer) {
                clearTimeout(hideErrorTimer);
                hideErrorTimer = null;
            }

            updateRetryingText();

            // First show the small minimal overlay; after a threshold of failed requests show the full error card
            if (!wasVisible) {
                if (consecutiveFailures < bigErrorThreshold) {
                    showMiniError();
                } else {
                    showBigError();
                }
            } else {
                // if already visible, and we've crossed the threshold, ensure the big card is shown
                if (consecutiveFailures >= bigErrorThreshold) {
                    showBigError();
                }
            }

            renderErrorQr(extraInfo);
            if (!refreshTimer && !retryTimer) {
                retryTimer = setInterval(refreshBoard, 5000);
            }
        }

        function scheduleReloadAfterRecovery() {
            // Always restart shortly after recovery. Clear any existing scheduled reload
            // and set a fresh timer for 1.5s so the page reloads every time a network error
            // is resolved.
            if (hideErrorTimer) {
                clearTimeout(hideErrorTimer);
                hideErrorTimer = null;
            }
            if (errorFixedEl) {
                errorFixedEl.classList.remove('hidden');
            }
            if (retryingEl) {
                retryingEl.textContent = 'Bağlantı kuruldu.';
            }
            // hide the minimal overlay if it was shown
            if (errorMiniEl) errorMiniEl.classList.add('hidden');
            popConfetti();
            hideErrorTimer = setTimeout(() => {
                // Use location.reload to ensure a full page reload after recovery
                location.reload();
            }, 1500);
        }

        function clearStatus() {
            if (!statusEl) return;
            statusEl.classList.add('hidden');
            statusEl.textContent = '';
            statusEl.classList.remove('border-red-400', 'bg-red-50');
        }

        async function loadBoard() {
            const res = await fetch(`${API_URL}/board`);
            if (!res.ok) {
                throw new Error(`Board load failed (${res.status})`);
            }
            return await res.json();
        }

        function renderBoard() {
            if (!widgetsEl || !boardData) return;
            clearClockTimers();
            widgetsEl.innerHTML = '';

            if (!widgetIntroHidden) {
                widgetIntroHidden = true;
                widgetsEl.classList.add('widgets-intro-hidden');
            }

            const pinned = boardData.widgets.filter((widget) => widget.pinned);
            const unpinned = boardData.widgets.filter((widget) => !widget.pinned);
            const ordered = [...pinned, ...unpinned].filter((widget) => displayTypes.has(widget.type));


            ordered.forEach((widget) => {
                const card = document.createElement('div');
                card.className = 'board-card border p-4 flex-1 min-w-[16rem] max-w-[26rem]';
                if (widget.pinned) {
                    card.classList.add('board-card-pinned');
                }

                const header = document.createElement('div');
                header.className = 'flex items-start justify-between gap-2';

                const title = document.createElement('div');
                title.className = 'font-semibold board-theme-text-primary';
                title.textContent = widget.title || widget.type || widget.key;

                const badge = document.createElement('span');
                badge.className = 'text-xs board-card-badge px-2 py-0.5';
                badge.textContent = widget.pinned ? 'Sabitli' : 'Widget';
                if (!widget.pinned) {
                    badge.classList.add('hidden');
                }

                header.appendChild(title);
                header.appendChild(badge);
                card.appendChild(header);


                const body = document.createElement('div');
                body.className = 'mt-2';

                if (widget.type === 'now-playing') {
                    body.appendChild(nowPlayingTemplate?.content.cloneNode(true));
                } else if (widget.type === 'queue') {
                    body.appendChild(queueTemplate?.content.cloneNode(true));
                } else if (widget.type === 'lights-out') {
                    body.appendChild(lightsOutTemplate?.content.cloneNode(true));
                } else if (widget.type === 'text-block') {
                    body.classList.add('text-sm', 'board-theme-text-secondary', 'whitespace-pre-line');
                    body.textContent = widget.content || '';
                } else if (widget.type === 'poll') {
                    const question = document.createElement('div');
                    question.className = 'font-semibold board-theme-text-primary';
                    question.textContent = widget.question || 'Anket';
                    body.appendChild(question);

                    const optionsWrap = document.createElement('div');
                    optionsWrap.className = 'mt-2 flex flex-col gap-2';
                    (widget.options || []).forEach((option) => {
                        const row = document.createElement('div');
                        row.className = 'flex items-center justify-between gap-2';

                        const label = document.createElement('div');
                        label.className = 'text-sm board-theme-text-secondary';
                        label.textContent = option.label || 'Seçenek';

                        const voteBtn = document.createElement('button');
                        voteBtn.className = 'border border-slate-300 px-2 py-1 text-xs';
                        voteBtn.textContent = `Oy ver (${option.votes || 0})`;
                        voteBtn.dataset.pollVote = 'true';
                        voteBtn.addEventListener('click', () => voteOnOption(widget.key, option.id));

                        row.appendChild(label);
                        row.appendChild(voteBtn);
                        optionsWrap.appendChild(row);
                    });
                    body.appendChild(optionsWrap);
                } else if (widget.type === 'clock') {
                    const showDate = widget.show_date !== false;
                    const showSeconds = Boolean(widget.show_seconds);

                    const clockWrap = document.createElement('div');
                    clockWrap.className = 'flex flex-col items-center justify-center py-4 gap-2';

                    const timeEl = document.createElement('div');
                    timeEl.className = 'text-6xl font-bold board-theme-text-primary tabular-nums';

                    const dateEl = document.createElement('div');
                    dateEl.className = 'text-xl board-theme-text-secondary';
                    if (!showDate) {
                        dateEl.classList.add('hidden');
                    }

                    clockWrap.appendChild(timeEl);
                    clockWrap.appendChild(dateEl);
                    body.appendChild(clockWrap);

                    const updateClock = () => {
                        const now = new Date();
                        timeEl.textContent = formatClockTime(now, showSeconds);
                        if (showDate) {
                            dateEl.textContent = formatClockDate(now);
                        }
                    };

                    updateClock();
                    const intervalMs = showSeconds ? 1000 : 30000;
                    clockTimers.push(setInterval(updateClock, intervalMs));
                } else if (widget.type === 'controls') {
                    const wrap = document.createElement('div');
                    wrap.className = 'flex flex-wrap gap-2';

                    const displayText = widget.display_text !== false;

                    const createBtn = (label, iconSvg, handler, action) => {
                        const btn = document.createElement('button');
                        btn.className = 'flex items-center gap-2 border board-card-badge px-3 py-2 hover:bg-black/5 active:scale-95 transition-transform';
                        if (action) {
                            btn.dataset.action = action;
                        }
                        btn.innerHTML = `${iconSvg}${displayText ? `<span>${label}</span>` : ''}`;
                        btn.addEventListener('click', handler);
                        return btn;
                    };

                    const confettiIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5.8 11.3 2 22l10.7-3.8M4 3h.01M22 8h.01M15 2h.01M22 20h.01M22 2h.01M18 7h.01M10 10l-1.5 1.5"/><circle cx="11" cy="9" r="2"/><path d="M18 2h.01M15 7h.01"/></svg>`;
                    const themeIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.281-.477-.672-.477-1.187 0-1.032.82-1.875 1.875-1.875h1.39c3.1 0 5.5-2.5 5.5-5.5 0-4.5-4.5-8.5-9.5-8.5z"/></svg>`;
                    const reloadIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>`;

                    if (widget.show_confetti !== false) wrap.appendChild(createBtn('Konfeti patlat', confettiIcon, triggerConfetti, 'board-confetti'));
                    if (widget.show_theme !== false) wrap.appendChild(createBtn('Rastgele tema', themeIcon, pickRandomTheme, 'board-theme-random'));
                    if (widget.show_reload !== false) wrap.appendChild(createBtn('Yeniden başlat', reloadIcon, triggerBoardRestart, 'board-restart'));

                body.appendChild(wrap);
            } else {
                body.classList.add('text-xs', 'board-theme-text-secondary');
                body.textContent = widget.type ? `Widget content goes here. (${widget.type})` : 'Widget content goes here.';
            }

                card.appendChild(body);
                widgetsEl.appendChild(card);
            });

            updateVoteButtons();
            if (!widgetIntroRendered && widgetsEl.children.length) {
                widgetIntroRendered = true;
                window.dispatchEvent(new Event('boardWidgetsRendered'));
            }
        }

        async function refreshBoard() {
            try {
                const data = await loadBoard();
                // reset failure counters on successful request
                consecutiveFailures = 0;
                firstFailureAt = null;
                const widgetStamp = JSON.stringify(data.widgets || []);
                const stamp = data.updated_at || widgetStamp;
                const themeKey = data?.theme_key || data?.theme?.key || null;
                const backgroundKey = data?.background_image_key || data?.background_image_url || null;
                const backdropBlur = Number.isFinite(Number(data?.backdrop_blur_px)) ? Number(data?.backdrop_blur_px) : 0;
                const cardBlur = Number.isFinite(Number(data?.card_blur_px)) ? Number(data?.card_blur_px) : 12;
                if (boardData && widgetStamp === lastWidgetStamp && themeKey === lastThemeKey && backgroundKey === lastBackgroundKey && backdropBlur === lastBackdropBlur && cardBlur === lastCardBlur) {
                    clearStatus();
                    if (errorVisible) {
                        scheduleReloadAfterRecovery();
                    }
                    if (data?.confetti_trigger?.id && data.confetti_trigger.id !== lastConfettiId) {
                        lastConfettiId = data.confetti_trigger.id;
                        popConfetti(data.confetti_trigger.config || {});
                    }
                    handleRedirectTrigger(data);
                    if (handleRestartTrigger(data)) {
                        return;
                    }
                    return;
                }
                lastUpdatedAt = stamp;
                lastWidgetStamp = widgetStamp;
                boardData = data;
                lastThemeKey = themeKey;
                lastBackgroundKey = backgroundKey;
                lastBackdropBlur = backdropBlur;
                lastCardBlur = cardBlur;
                applyTheme(data?.theme || null, data?.background_image_url || null, backdropBlur, cardBlur);
                renderBoard();
                clearStatus();
                if (errorVisible) {
                    scheduleReloadAfterRecovery();
                }
                if (data?.confetti_trigger?.id && data.confetti_trigger.id !== lastConfettiId) {
                    lastConfettiId = data.confetti_trigger.id;
                    popConfetti(data.confetti_trigger.config || {});
                }
                handleRedirectTrigger(data);
                if (handleRestartTrigger(data)) {
                    return;
                }
                if (retryTimer && !refreshTimer) {
                    // keep retry timer running only if there is no main refresh loop
                } else if (retryTimer) {
                    clearInterval(retryTimer);
                    retryTimer = null;
                }
            } catch (err) {
                const info = [
                    `error: ${err?.message || 'board load failed'}`,
                    `page: ${location.href}`,
                    `agent: ${navigator.userAgent}`,
                    `time: ${new Date().toISOString()}`
                ].join('\n');
                showLonelyText(info);
            }
        }

        function ensureConfettiCanvas() {
            if (confettiCanvas) return confettiCanvas;
            const canvas = document.createElement('canvas');
            canvas.id = 'board-confetti-canvas';
            // put confetti behind the cards: low z-index
            canvas.className = 'fixed inset-0 pointer-events-none z-0';
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            document.body.appendChild(canvas);
            confettiCanvas = canvas;
            window.addEventListener('resize', () => {
                if (!confettiCanvas) return;
                confettiCanvas.width = window.innerWidth;
                confettiCanvas.height = window.innerHeight;
            });
            return canvas;
        }

        function popConfetti(options = {}) {
            const opts = typeof options === 'number' ? { particleCount: options } : options;
            const {
                durationMs = 4000,
                particleCount = 200,
                spread = 0.55,
                sizeScale = 4.0,
                spawnDurationMs = 1200,
                upwardBoost = 1.5,
                colors: overrideColors = null
            } = opts;
            if (confettiActive) return;
            confettiActive = true;
            const canvas = ensureConfettiCanvas();
            const ctx = canvas.getContext('2d');
            if (!ctx) {
                confettiActive = false;
                return;
            }
            const colors = Array.isArray(overrideColors)
                ? overrideColors
                : (Array.isArray(themeConfettiColors) ? themeConfettiColors : ['#22c55e', '#16a34a', '#a3e635', '#86efac', '#4ade80', '#10b981']);
            const particles = Array.from({ length: particleCount }, () => ({
                x: canvas.width * (0.05 + Math.random() * 0.9),
                y: canvas.height * (0.78 + Math.random() * 0.18),
                vx: (Math.random() - 0.5) * canvas.width * spread * 0.002,
                vy: (Math.random() * -0.9 - 0.4) * canvas.height * 0.0025 * upwardBoost,
                size: (10 + Math.random() * 16) * sizeScale,
                rot: Math.random() * Math.PI,
                vr: (Math.random() - 0.5) * 0.7,
                color: colors[Math.floor(Math.random() * colors.length)],
                delay: Math.random() * spawnDurationMs
            }));
            const gravity = 0.0016 * canvas.height;
            const start = performance.now();

            function tick(now) {
                const elapsed = now - start;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particles.forEach((p) => {
                    if (elapsed < p.delay) {
                        return;
                    }
                    p.vy += gravity * 0.025;
                    p.x += p.vx * 16;
                    p.y += p.vy * 16;
                    p.rot += p.vr;
                    ctx.save();
                    ctx.translate(p.x, p.y);
                    ctx.rotate(p.rot);
                    ctx.fillStyle = p.color;
                    ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 0.75);
                    ctx.restore();
                });
                if (elapsed < durationMs) {
                    requestAnimationFrame(tick);
                } else {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    confettiActive = false;
                }
            }
            requestAnimationFrame(tick);
        }

        window.popConfetti = popConfetti;
        const initialConfettiPreset = {
            particleCount: 100,
            durationMs: 3000,
            spawnDurationMs: 500,
            spread: 0.3,
            sizeScale: 3.5,
            upwardBoost: 2
        };

        function applyTheme(theme, backgroundImageUrl = null, backdropBlur = 0, cardBlur = 12) {
            const colors = theme?.colors || {};
            const style = document.documentElement.style;
            style.setProperty('--board-text-primary', colors.textPrimary || '#0f172a');
            style.setProperty('--board-text-secondary', colors.textSecondary || '#475569');
            style.setProperty('--board-background', colors.background || '#f8fafc');
            style.setProperty('--board-card-bg', colors.cardBackground || '#ffffff');
            style.setProperty('--board-card-border', colors.cardBorder || '#cbd5f5');
            // keep the original pinned color var (may be used elsewhere)
            style.setProperty('--board-card-pinned-bg', colors.cardPinnedBackground || '#ecfdf5');
            // compute an rgba variant for a subtle tint overlay so we can preserve blur while tinting
            const pinned = colors.cardPinnedBackground || '#10b981';
            // a slightly stronger tint by default so pinned cards read as tinted
            const pinnedRgba = hexToRgba(pinned, 0.12);
             style.setProperty('--board-card-pinned-bg-rgba', pinnedRgba);
            style.setProperty('--board-card-pinned-border', colors.cardPinnedBorder || '#6ee7b7');
            style.setProperty('--board-qr-bg', colors.qrButtonBackground || '#ffffff');
            style.setProperty('--board-qr-border', colors.qrButtonBorder || '#cbd5f5');
            style.setProperty('--board-qr-text', colors.qrButtonText || '#0f172a');
            const cardBlurPx = Number.isFinite(Number(cardBlur)) ? Math.max(0, Math.min(30, Number(cardBlur))) : 12;
            style.setProperty('--board-card-blur', `${cardBlurPx}px`);
            if (themeBackdropEl) {
                themeBackdropEl.style.backgroundColor = colors.background || '#f8fafc';
                const imageUrl = typeof backgroundImageUrl === 'string' ? backgroundImageUrl.trim() : '';
                if (imageUrl) {
                    const safeUrl = imageUrl.replace(/"/g, '\\"');
                    themeBackdropEl.style.backgroundImage = `url("${safeUrl}")`;
                    themeBackdropEl.style.backgroundSize = 'cover';
                    themeBackdropEl.style.backgroundPosition = 'center center';
                    themeBackdropEl.style.backgroundRepeat = 'no-repeat';
                    themeBackdropEl.style.backgroundAttachment = 'fixed';
                } else {
                    themeBackdropEl.style.backgroundImage = 'none';
                    themeBackdropEl.style.backgroundSize = '';
                    themeBackdropEl.style.backgroundPosition = '';
                    themeBackdropEl.style.backgroundRepeat = '';
                    themeBackdropEl.style.backgroundAttachment = '';
                }
                const blurPx = Number.isFinite(Number(backdropBlur)) ? Math.max(0, Math.min(40, Number(backdropBlur))) : 0;
                themeBackdropEl.style.filter = blurPx > 0 ? `blur(${blurPx}px)` : '';
                themeBackdropEl.style.transform = blurPx > 0 ? 'scale(1.04)' : '';
            }
            themeConfettiColors = Array.isArray(colors.confettiColors) ? colors.confettiColors : null;
            if (!initialConfettiShown) {
                initialConfettiShown = true;
                popConfetti(initialConfettiPreset);
            }
        }

        // Helper: convert hex (or rgb(a) token) to rgba string with given alpha. Fallback returns rgba(16,185,129,alpha)
        function hexToRgba(input, alpha = 0.06) {
            try {
                const s = String(input || '').trim();
                // if already rgba or rgb, return with alpha applied if needed
                if (s.startsWith('rgba')) return s;
                if (s.startsWith('rgb')) return s.replace('rgb', 'rgba').replace(')', `, ${alpha})`);
                // hex shorthand or full
                const hex = s.replace('#', '');
                if (hex.length === 3) {
                    const r = parseInt(hex[0] + hex[0], 16);
                    const g = parseInt(hex[1] + hex[1], 16);
                    const b = parseInt(hex[2] + hex[2], 16);
                    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
                }
                if (hex.length === 6) {
                    const r = parseInt(hex.slice(0, 2), 16);
                    const g = parseInt(hex.slice(2, 4), 16);
                    const b = parseInt(hex.slice(4, 6), 16);
                    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
                }
            } catch (e) {}
            return `rgba(16,185,129,${alpha})`;
        }

        // Decode a JWT payload safely (no validation) and return the parsed object or null
        function parseJwtPayload(token) {
            try {
                const parts = String(token || '').split('.');
                if (parts.length < 2) return null;
                // base64url -> base64
                let payload = parts[1].replace(/-/g, '+').replace(/_/g, '/');
                // Pad base64 if necessary
                while (payload.length % 4) payload += '=';
                const decoded = atob(payload);
                // Percent-encode to support multi-byte characters
                const json = decodeURIComponent(Array.from(decoded).map((c) => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join(''));
                return JSON.parse(json);
            } catch (e) {
                return null;
            }
        }

        async function checkBoardAuth() {
            // Only check the locally-stored JWT payload to confirm it's for the board user (sub: 100000).
            // Do NOT call the server here — if the server is down we want the auth page to show the auth error,
            // not the board page to show a server-down error and wipe the token.
            const token = localStorage.getItem('jwt_token');
            if (!token) {
                location.href = '/board/auth';
                return false;
            }
            const payload = parseJwtPayload(token);
            if (!payload) {
                // malformed token; fall back to auth flow
                location.href = '/board/auth';
                return false;
            }
            // Accept sub as string or number; also tolerate common claim names if needed
            const sub = String(payload.sub ?? payload.user_id ?? payload.id ?? '');
            const isBoardUser = sub === '100000';
            if (authWarningEl) {
                authWarningEl.classList.toggle('hidden', isBoardUser);
            }
            if (!isBoardUser) {
                // If not a board token, send to auth so the user can obtain a board JWT.
                location.href = '/board/auth';
                return false;
            }
            return true;

        }

        if (authLogoutEl) {
            authLogoutEl.addEventListener('click', () => {
                localStorage.removeItem('jwt_token');
                location.href = '/board/auth';
            });
        }

        (async () => {
            const ok = await checkBoardAuth();
            if (!ok) {
                return;
            }
            startInactivityWatcher();
            refreshBoard();
            refreshTimer = setInterval(refreshBoard, 2000);
        })();

        function getBoardDomain() {
            return window.location.host;
        }

        function updateQrToggleLabel() {
            if (!qrToggleEl || !qrOverlayEl) return;
            const isHidden = qrOverlayEl.classList.contains('hidden');
            qrToggleEl.textContent = isHidden ? 'QR kodu göster' : 'Gizle';
        }

        async function ensureBoardQr() {
            if (!qrImgEl || qrReady) return;
            try {
                const { default: QRCode } = await import('qrcode');
                const dataUri = await QRCode.toDataURL(getBoardDomain());
                qrImgEl.src = dataUri;
                qrReady = true;
            } catch (err) {
                qrImgEl.removeAttribute('src');
            }
            if (qrLabelEl) {
                qrLabelEl.textContent = getBoardDomain();
            }
        }

        function showBoardQr() {
            if (!qrOverlayEl) return;
            qrOverlayEl.classList.remove('hidden');
            updateQrToggleLabel();
            ensureBoardQr();
            trackBoardAction('board_qr_toggled', { state: 'shown', reason: 'manual' });
            if (qrAutoHideTimer) {
                clearTimeout(qrAutoHideTimer);
            }
            qrAutoHideTimer = setTimeout(() => hideBoardQr('timeout'), 120000);
        }

        function hideBoardQr(reason = 'manual') {
            if (!qrOverlayEl) return;
            qrOverlayEl.classList.add('hidden');
            updateQrToggleLabel();
            trackBoardAction('board_qr_toggled', { state: 'hidden', reason });
            if (qrAutoHideTimer) {
                clearTimeout(qrAutoHideTimer);
                qrAutoHideTimer = null;
            }
        }

        function toggleBoardQr() {
            if (!qrOverlayEl) return;
            if (qrOverlayEl.classList.contains('hidden')) {
                showBoardQr();
            } else {
                hideBoardQr('manual');
            }
        }

        function setQrButtonHidden(hidden) {
            if (!qrToggleEl) return;
            qrToggleEl.classList.toggle('hidden', hidden);
            if (hidden) {
                hideBoardQr('manual');
            }
        }

        if (qrToggleEl) {
            updateQrToggleLabel();
            qrToggleEl.addEventListener('click', toggleBoardQr);
        }

        const storedHideQr = localStorage.getItem(hideQrButtonKey) === 'true';
        setQrButtonHidden(storedHideQr);

        window.addEventListener('boardQrButtonVisibilityChange', (event) => {
            const hidden = Boolean(event?.detail?.hidden);
            setQrButtonHidden(hidden);
        });
    </script>

    <style>
        :root {
            --board-text-primary: #0f172a;
            --board-text-secondary: #475569;
            --board-background: #f8fafc;
            --board-card-bg: #ffffff;
            --board-card-border: #cbd5f5;
            --board-card-pinned-bg: #ecfdf5;
            /* default rgba tint for pinned cards (used as a fallback before JS runs) */
            --board-card-pinned-bg-rgba: rgba(16,185,129,0.12);
            --board-card-pinned-border: #6ee7b7;
            --board-card-blur: 12px;
            --board-qr-bg: #ffffff;
            --board-qr-border: #cbd5f5;
            --board-qr-text: #0f172a;
        }

        :global(.widgets-intro-hidden .board-card) {
            opacity: 0;
            transform: translateY(28px);
        }

        :global(.board-theme-text-primary) {
            color: var(--board-text-primary);
        }

        :global(.board-theme-text-secondary) {
            color: var(--board-text-secondary);
        }

        /* Make the widget cards frosted glass so they blend with the backdrop */
        :global(.board-card) {
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(var(--board-card-blur, 12px)) saturate(120%);
            -webkit-backdrop-filter: blur(var(--board-card-blur, 12px)) saturate(120%);
            border: 1px solid rgba(255,255,255,0.08);
            color: var(--board-text-primary);
            flex: 1 0 22rem;
            min-width: 22rem;
            box-shadow: 0 6px 18px rgba(2,6,23,0.06);
            /* ensure cards sit above the confetti canvas */
            position: relative;
            z-index: 10;
        }

        /* Slightly tinted frosted glass for pinned cards */
        :global(.board-card-pinned) {
            /* use a subtle rgba tint derived from theme while keeping the frosted backdrop */
            background: var(--board-card-pinned-bg-rgba, rgba(16,185,129,0.06));
            backdrop-filter: blur(var(--board-card-blur, 12px)) saturate(120%);
            -webkit-backdrop-filter: blur(var(--board-card-blur, 12px)) saturate(120%);
            border-color: var(--board-card-pinned-border);
            overflow: hidden; /* contain tint overlay */
        }

        /* overlay tint to ensure the themed color reads well while retaining backdrop-filter */
        :global(.board-card-pinned::before) {
            content: '';
            position: absolute;
            inset: 0;
            background: var(--board-card-pinned-bg-rgba, rgba(16,185,129,0.12));
            pointer-events: none;
            mix-blend-mode: normal;
            z-index: 0;
        }

        /* ensure the card contents stay above the tint overlay */
        :global(.board-card-pinned > *) {
            position: relative;
            z-index: 1;
        }

        :global(.board-card-badge) {
            border: 1px solid var(--board-card-border);
            color: var(--board-text-secondary);
        }

        :global(.board-qr-button) {
            border: 1px solid var(--board-qr-border);
            background: var(--board-qr-bg);
            color: var(--board-qr-text);
        }

        :global(.board-qr-card) {
            border: 1px solid var(--board-card-border);
            background: var(--board-card-bg);
            color: var(--board-text-primary);
        }
    </style>

    <script>
        import { gsap } from 'gsap';
        import { SplitText } from 'gsap/SplitText';
        gsap.registerPlugin(SplitText)

        let widgetIntroReady = false;
        let widgetIntroPlayed = false;

        const playWidgetIntro = () => {
            if (widgetIntroPlayed) return false;
            const widgets = document.querySelectorAll('#board-widgets .board-card');
            if (!widgets.length) return false;
            const widgetsWrap = document.getElementById('board-widgets');
            if (widgetsWrap) {
                widgetsWrap.classList.remove('widgets-intro-hidden');
            }
            widgetIntroPlayed = true;
            gsap.from(widgets, {
                opacity: 0,
                y: 28,
                duration: 0.8,
                ease: 'power3.out',
                stagger: 0.25
            });
            return true;
        };

        window.addEventListener('boardWidgetsRendered', () => {
            if (!widgetIntroReady) return;
            playWidgetIntro();
        });

        const startAnimations = () => {
            gsap.set("#title", { perspective: 400 });

            let splitBartin = SplitText.create("#tap-bartin", {type: "words, chars"});
            let splitLisesi = SplitText.create("#tap-lisesi", {type: "words, chars"});
            let splitTitle = SplitText.create("#title", {type: "words, chars"});

            const tl = gsap.timeline({
                delay: 1.5
            });

            tl.from(splitBartin.chars, {
                y: -200,
                duration: 2,
                rotation: 360,
                stagger: 0.05,
                ease: "bounce.inout"
            });

            tl.from(splitLisesi.chars, {
                opacity: 0,
                rotationX: -90,
                z: -200,
                stagger: 0.05,
                duration: 1.2,
                ease: "expo.out",
                transformOrigin: "50% 50% -100" // Pivot point behind the letter
            }, "-=0.5");


            tl.add(() => {
                if (!playWidgetIntro()) {
                    widgetIntroReady = true;
                }
            });

            tl.from("#board-qr-toggle", {
                opacity: 0,
                x: -500,
                y: -200,
                duration: 1,
                ease: "back.out(1.7)" // 1.7 is the "strength" of the overshoot
            }, "+=3");

        }
        // If the DOM is already ready, run it. Otherwise, wait for it.
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', startAnimations);
        } else {
            startAnimations();
        }
    </script>
</Layout>
