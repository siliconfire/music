---
import Layout from '../../layouts/Layout.astro';
import BoardThemeLoader from '../../components/BoardThemeLoader.astro';
---

<Layout title="Ekran Yönetimi">
    <BoardThemeLoader />

    <h1 class="text-2xl board-theme-text-primary mt-10 mx-10" id="title">Ekran kontrolleri</h1>
    <a href="/" class="mb-10 mx-10 inline-block text-sm board-theme-text-secondary hover:underline">
        (ana sayfaya geri dön)
    </a>

    <div class="m-5 lg:m-10">
        <div id="board-permission" class="hidden m-5 lg:m-10">
            <fieldset class="p-5 border border-red-400 bg-red-50">
                <legend class="text-red-700 font-bold">Yetki Hatası</legend>
                <p id="board-permission-message" class="text-red-700 text-sm">Bu sayfayı düzenlemek için yetkiniz yok.</p>
            </fieldset>
        </div>

        <div id="board-editor-root">
            <div class="m-5 lg:m-10">
                <div id="board-status" class="hidden border board-theme-border board-theme-card p-3 text-sm"></div>
            </div>

            <div class="m-5 lg:m-10">
                <div id="board-widgets" class="flex flex-wrap gap-5"></div>
            </div>
            <hr class="border board-theme-border">
            <div class="m-5 lg:m-10">
                <fieldset class="p-5 border board-theme-border board-theme-card inline-block w-full">
                    <legend class="board-theme-text-primary">Seçenekler</legend>
                        <select id="board-add-select" class="border board-theme-border p-2">
                            <option value="">Seç...</option>
                            <option value="now-playing">Şimdi Çalıyor</option>
                            <option value="queue">Kuyruk</option>
                            <option value="text-block">Metin</option>
                            <option value="poll">Anket</option>
                            <option value="clock">Saat</option>
                            <option value="controls">Kontroller</option>
                        </select>
                        <button id="board-add-btn" class="border board-theme-border p-2">Ekle</button>
                        <div class="mt-4"></div>
                        <button id="board-save-btn" class="border board-theme-border p-2 board-card-bg">Herşeyi kaydet</button>
                    <details class="m-2 p-3 border board-theme-border inline-block">
                    <summary class="board-theme-text-primary">Nasıl Kullanılır</summary>
                    <ul class="board-theme-text-secondary">
                        <li>Birşey eklemek için "Seç..." menüsünden istediğinizi seçin ve "Ekle" tuşuna basın.</li>
                        <li>Birşeyi taşımak için ↑/↓ ok tuşlarını kullanın.</li>
                        <li>Birşeyi silmek için "Kaldır" tuşuna basın. Sabitli öğeler kaldırılamaz.</li>
                        <li>Birşeyin başlığını değiştirmek için başlığının üzerine tıklayın.</li>
                    </ul>
                    </details>
                </fieldset>
                <fieldset class="p-5 border board-theme-border board-theme-card inline-block w-full mt-10">
                    <legend class="board-theme-text-primary">Tema</legend>
                    <div class="flex flex-wrap gap-2 items-center">
                        <button id="board-theme-random" class="border board-theme-border p-2">Rastgele seç</button>
                    </div>
                    <div id="board-theme-list" class="mt-3 grid gap-3 sm:grid-cols-2 xl:grid-cols-3"></div>
                </fieldset>
                <fieldset class="p-5 border board-theme-border board-theme-card inline-block w-full mt-10">
                    <legend class="board-theme-text-primary">Konfeti</legend>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <input id="confetti-count" class="border board-theme-border p-2 text-xs" type="number" min="10" max="5000" placeholder="Partikül sayısı (3000)" />
                        <input id="confetti-size" class="border board-theme-border p-2 text-xs" type="number" step="0.1" min="0.2" max="10" placeholder="Partikül boyutu (4)" />
                        <input id="confetti-spread" class="border board-theme-border p-2 text-xs" type="number" step="0.05" min="0.05" max="2" placeholder="Yayılım miktarı (0.5)" />
                        <input id="confetti-duration" class="border board-theme-border p-2 text-xs" type="number" min="200" max="10000" placeholder="Toplam süre (10000)" />
                        <input id="confetti-spawn" class="border board-theme-border p-2 text-xs" type="number" min="0" max="5000" placeholder="Dağılım süresi (1500)" />
                        <input id="confetti-up" class="border board-theme-border p-2 text-xs" type="number" step="0.1" min="0.2" max="4" placeholder="Yukarı itiş (1.5)" />
                    </div>
                    <br>
                    <button id="board-confetti-btn" class="border board-theme-border p-2 ml-2">Konfeti Gönder</button>

                    <details class="m-2 p-3 border board-theme-border inline-block">
                        <summary class="board-theme-text-primary">Yardım</summary>
                        <ul class="board-theme-text-secondary">
                            <li>Partikül sayısı: Uçurulacak konfeti adeti.</li>
                            <li>Partikül boyutu: Her konfetinin boyutu.</li>
                            <li>Yayılım miktarı: Konfeti parçalarının sağa/sola yayılma miktarı.</li>
                            <li>Toplam süre (ms): Animasyonun toplam süresi (milisaniye).</li>
                            <li>Dağılım süresi (ms): Konfeti parçalarının yayılma süresi (parçalar bu süreye yayılarak uçarlar, 0 = hepsi aynı anda) (Milisaniye).</li>
                            <li>Yukarı itiş: Konfetileri yukarı iten güç.</li>
                        </ul>
                        <br>
                        <span class="board-theme-text-secondary">Parantez içinde hepsi için önerilen değerler verilmiştir, önce onları girip sonra yavaş yavaş değerler ile oynamanız önerilir.</span>
                    </details>
                </fieldset>
                <fieldset class="p-5 border board-theme-border board-theme-card inline-block w-full mt-10">
                    <legend class="board-theme-text-primary">Yeniden başlat</legend>
                    <button id="board-restart-btn" class="border board-theme-border p-2 board-card-bg ml-2">Ekranı yeniden başlat</button>
                    <p class="mx-3 mt-4 text-sm board-theme-text-secondary">Yardımcı olur mu bilmiyorum ama eğer ekran çok garip bir duruma girerse belki denemek işe yarayabilir.</p>
                </fieldset>
                <fieldset class="p-5 border board-theme-border board-theme-card inline-block w-full mt-10">
                    <legend class="board-theme-text-primary">Debug</legend>
                    <button id="board-debug-screen-btn" class="border board-theme-border p-2 board-card-bg ml-2">Dokunmatik kontrolü başlat</button>
                    <p class="mx-3 mt-4 text-sm board-theme-text-secondary">Ekranı kontrol etmek için kullanabilirsiniz. Bir zararı yok.</p>
                </fieldset>
                <fieldset class="p-5 border board-theme-border board-theme-card inline-block w-full mt-10">
                    <legend class="board-theme-text-primary">Yardım</legend>
                    <a href="/help/" class="m-2 p-3 border board-theme-border board-card-bg inline-block align-top max-w-sm">Tüm yardım başlıklarını oku</a>
                    <a href="/help/board-pinned" class="m-2 p-3 border board-theme-border inline-block align-top max-w-sm">"Sabitli" ne demek?</a>
                </fieldset>
            </div>
        </div>
    </div>
    <script>
        import { API_URL } from '../../lib/constants';

        const token = localStorage.getItem("jwt_token");
        if (!token) {
            window.location.href = '/login';
        }

        const ranks = ['music', 'musicpermanent', 'moderator', 'admin', 'superadmin', 'dev'];
        const allWidgets = {
            'controls': 'Kontroller',
            'now-playing': 'Şimdi Çalıyor',
            'search': 'Ara',
            'queue': 'Kuyruk',
            'text-block': 'Metin',
            'poll': 'Anket',
            'clock': 'Saat'
        };

        const displayTypes = new Set(['now-playing', 'queue', 'text-block', 'poll', 'clock', 'controls']);

        let boardData = null;
        let canEdit = false;
        let canPin = false;

        const statusEl = document.getElementById('board-status');
        const widgetsEl = document.getElementById('board-widgets');
        const permissionEl = document.getElementById('board-permission');
        const permissionMessageEl = document.getElementById('board-permission-message');
        const editorRootEl = document.getElementById('board-editor-root');
        const addSelectEl = document.getElementById('board-add-select');
        const addBtnEl = document.getElementById('board-add-btn');
        const saveBtnEl = document.getElementById('board-save-btn');
        const moderatorHelpEl = document.getElementById('moderator-help');
        const confettiBtnEl = document.getElementById('board-confetti-btn');
        const confettiCountEl = document.getElementById('confetti-count');
        const confettiSizeEl = document.getElementById('confetti-size');
        const confettiSpreadEl = document.getElementById('confetti-spread');
        const confettiDurationEl = document.getElementById('confetti-duration');
        const confettiSpawnEl = document.getElementById('confetti-spawn');
        const confettiUpEl = document.getElementById('confetti-up');
        const restartBtnEl = document.getElementById('board-restart-btn');
        const themeRandomEl = document.getElementById('board-theme-random');
        const themeListEl = document.getElementById('board-theme-list');
        const debugScreenBtnEl = document.getElementById('board-debug-screen-btn');

        function showPermissionError(message) {
            if (editorRootEl) editorRootEl.classList.add('hidden');
            if (permissionEl) permissionEl.classList.remove('hidden');
            if (permissionMessageEl) permissionMessageEl.textContent = message;
        }

        function showStatus(message, isError = false) {
            if (!statusEl) return;
            statusEl.textContent = message;
            statusEl.classList.remove('hidden');
            statusEl.classList.toggle('border-red-400', isError);
            statusEl.classList.toggle('bg-red-50', isError);
        }

        function clearStatus() {
            if (!statusEl) return;
            statusEl.classList.add('hidden');
            statusEl.textContent = '';
            statusEl.classList.remove('border-red-400', 'bg-red-50');
        }

        // Remove previous field-level error UI
        function clearFieldErrors() {
            // remove error messages
            document.querySelectorAll('.field-error-msg').forEach((el) => el.remove());
            // remove error classes from inputs
            document.querySelectorAll('[data-field]').forEach((el) => {
                el.classList.remove('border-red-500');
                el.classList.remove('bg-red-50');
            });
        }

        function markFieldError(detail) {
            if (!detail || !detail.widget) return;
            const widgetKey = detail.widget;
            const field = detail.field;
            const rule = detail.rule;
            const message = detail.message || 'Gönderdiğiniz içerik engellendi.';
            let el = null;
            const widgetSelector = `[data-widget-key="${widgetKey}"]`;
            if (field === 'title') {
                el = document.querySelector(`${widgetSelector} [data-field=title]`);
            } else if (field === 'content') {
                el = document.querySelector(`${widgetSelector} [data-field=content]`);
            } else if (field === 'question') {
                el = document.querySelector(`${widgetSelector} [data-field=question]`);
            } else if (field === 'poll_option') {
                const optId = detail.option_id;
                el = document.querySelector(`${widgetSelector} [data-field=poll_option][data-option-id="${optId}"]`);
            }

            if (el) {
                // highlight
                el.classList.add('border-red-500');
                // insert message
                const msg = document.createElement('div');
                msg.className = 'text-xs text-red-600 field-error-msg mt-1';
                msg.textContent = `${message} (kural: ${rule})`;
                if (el.parentNode) {
                    // insert after the input/textarea
                    if (el.nextSibling) el.parentNode.insertBefore(msg, el.nextSibling);
                    else el.parentNode.appendChild(msg);
                }
                try {
                    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    if (typeof el.focus === 'function') el.focus();
                } catch (e) {
                    // ignore
                }
            } else {
                // fallback to status message
                showStatus(message + (rule ? ` (rule: ${rule})` : ''), true);
            }
        }

        function hasRank(permissions) {
            return permissions.some((perm) => ranks.includes(perm));
        }

        function highestRankIndex(permissions) {
            let highest = -1;
            (permissions || []).forEach((perm) => {
                const idx = ranks.indexOf(perm);
                if (idx > highest) {
                    highest = idx;
                }
            });
            return highest;
        }

        function createWidgetKey(widgetType) {
            const suffix = Math.random().toString(36).slice(2, 7);
            return `${widgetType}-${Date.now().toString(36)}-${suffix}`;
        }

        async function loadBoard() {
            const res = await fetch(`${API_URL}/board`);
            if (res.status === 403) {
                throw new Error('permission');
            }
            if (!res.ok) {
                throw new Error('board yüklenme hatası');
            }
            return await res.json();
        }

        function normalizeOrder() {
            if (!boardData) return;
            const pinned = boardData.widgets.filter((widget) => widget.pinned);
            const unpinned = boardData.widgets.filter((widget) => !widget.pinned);
            boardData.widgets = [...pinned, ...unpinned];
        }

        function moveWidget(widgetKey, delta) {
            if (!boardData) return;
            const target = boardData.widgets.find((widget) => widget.key === widgetKey);
            if (!target) return;

            const group = target.pinned ? 'pinned' : 'unpinned';
            if (group === 'pinned' && !canPin) return;

            const pinned = boardData.widgets.filter((widget) => widget.pinned);
            const unpinned = boardData.widgets.filter((widget) => !widget.pinned);
            const list = group === 'pinned' ? pinned : unpinned;
            const index = list.findIndex((widget) => widget.key === widgetKey);
            const nextIndex = index + delta;
            if (nextIndex < 0 || nextIndex >= list.length) return;

            const temp = list[index];
            list[index] = list[nextIndex];
            list[nextIndex] = temp;

            boardData.widgets = [...pinned, ...unpinned];
            renderBoard();
        }

        function removeWidget(widgetKey) {
            if (!boardData) return;
            const target = boardData.widgets.find((widget) => widget.key === widgetKey);
            if (!target || target.pinned) return;
            boardData.widgets = boardData.widgets.filter((widget) => widget.key !== widgetKey);
            renderBoard();
        }

        function togglePin(widgetKey) {
            if (!boardData || !canPin) return;
            const target = boardData.widgets.find((widget) => widget.key === widgetKey);
            if (!target) return;
            target.pinned = !target.pinned;
            normalizeOrder();
            renderBoard();
        }

        function addWidget(widgetType) {
            if (!boardData || !canEdit) return;
            if (!allWidgets[widgetType] || !displayTypes.has(widgetType)) return;
            const widget = {
                key: createWidgetKey(widgetType),
                type: widgetType,
                title: allWidgets[widgetType],
                pinned: false
            };
            if (widgetType === 'text-block') {
                widget.content = '';
            }
            if (widgetType === 'poll') {
                widget.question = 'Başlık';
                widget.options = [];
            }
            if (widgetType === 'clock') {
                widget.show_date = true;
                widget.show_seconds = false;
            }
            if (widgetType === 'controls') {
                widget.show_confetti = true;
                widget.show_theme = true;
                widget.show_reload = false;
                widget.display_text = true;
            }
            boardData.widgets.push(widget);
            normalizeOrder();
            renderBoard();
        }

        async function saveBoard() {
            if (!boardData) return;
            clearStatus();
            const payload = {
                widgets: boardData.widgets
                    .filter((widget) => displayTypes.has(widget.type))
                    .map((widget) => {
                        const entry = {
                            key: widget.key,
                            type: widget.type,
                            pinned: widget.pinned,
                            title: widget.title || ''
                        };
                        if (widget.type === 'text-block') {
                            entry.content = widget.content || '';
                        }
                        if (widget.type === 'poll') {
                            entry.question = widget.question || '';
                            entry.options = (widget.options || []).map((option) => ({
                                id: option.id,
                                label: option.label || '',
                                votes: typeof option.votes === 'number' ? option.votes : 0
                            }));
                        }
                        if (widget.type === 'clock') {
                            entry.show_date = widget.show_date !== false;
                            entry.show_seconds = Boolean(widget.show_seconds);
                        }
                        if (widget.type === 'controls') {
                            entry.show_confetti = widget.show_confetti !== false;
                            entry.show_theme = widget.show_theme !== false;
                            entry.show_reload = Boolean(widget.show_reload);
                            entry.display_text = widget.display_text !== false;
                        }
                        return entry;
                    }),
                theme_key: boardData.theme_key || null
            };
            const res = await fetch(`${API_URL}/board`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Session-ID': token
                },
                body: JSON.stringify(payload)
            });
            if (res.status === 403) {
                showPermissionError('Düzenlemek için yetkiniz yok.');
                return;
            }
            if (!res.ok) {
                // Try to show the server-provided error detail (e.g. blocked rule message)
                let errMsg = 'Save failed.';
                try {
                    const body = await res.json();
                    if (body && body.detail) {
                        // backend now returns structured detail object
                        const detail = body.detail;
                        clearFieldErrors();
                        if (typeof detail === 'object') {
                            // mark offending field and show message
                            markFieldError(detail);
                            errMsg = detail.message || errMsg;
                        } else {
                            errMsg = detail;
                        }
                    }
                } catch (e) {
                    // ignore JSON parse errors, keep generic message
                }
                showStatus(errMsg, true);
                return;
            }
            boardData = await res.json();
            clearFieldErrors();
            renderBoard();
            renderThemeOptions();
            showStatus('Saved.');
        }

        function addPollOption(widget) {
            const optionId = `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 7)}`;
            widget.options = widget.options || [];
            widget.options.push({ id: optionId, label: 'Seçenek', votes: 0 });
            renderBoard();
        }

        function removePollOption(widget, optionId) {
            widget.options = (widget.options || []).filter((option) => option.id !== optionId);
            renderBoard();
        }

        function renderBoard() {
            if (!widgetsEl || !boardData) return;
            widgetsEl.innerHTML = '';

            boardData.widgets
                .filter((widget) => displayTypes.has(widget.type))
                .forEach((widget) => {
                    const card = document.createElement('div');
                    card.className = 'border board-theme-border board-theme-card p-4 flex-1 min-w-[16rem] max-w-[26rem]';
                    if (widget.pinned) {
                        card.classList.add('bg-green-50', 'border-green-300');
                    }

                    const header = document.createElement('div');
                    header.className = 'flex items-start justify-between gap-2';

                    const title = document.createElement('input');
                    title.className = 'font-semibold board-theme-text-primary text-sm border board-theme-border px-2 py-1 w-full';
                    title.value = widget.title || allWidgets[widget.type] || widget.type;
                    // mark field for error lookup
                    title.dataset.field = 'title';
                    title.addEventListener('input', (event) => {
                        widget.title = event.target.value;
                    });

                    const badge = document.createElement('span');
                    badge.className = 'text-xs border board-theme-border px-2 py-0.5 board-theme-text-secondary';
                    badge.textContent = widget.pinned ? 'Sabitli' : 'Widget';
                    if (!widget.pinned) {
                        badge.classList.add('hidden');
                    }

                    header.appendChild(title);
                    header.appendChild(badge);
                    card.appendChild(header);

                    const typeLine = document.createElement('div');
                    typeLine.className = 'text-xs board-theme-text-secondary mt-1';
                    typeLine.textContent = allWidgets[widget.type] || widget.type || '';
                    card.appendChild(typeLine);

                    const body = document.createElement('div');
                    body.className = 'text-xs board-theme-text-secondary mt-2';
                    if (widget.type === 'text-block') {
                        const textarea = document.createElement('textarea');
                        textarea.className = 'w-full border board-theme-border p-2 text-sm board-theme-text-primary';
                        textarea.rows = 4;
                        textarea.value = widget.content || '';
                        textarea.dataset.field = 'content';
                        textarea.addEventListener('input', (event) => {
                            widget.content = event.target.value;
                        });
                        body.appendChild(textarea);
                    } else if (widget.type === 'poll') {
                        const question = document.createElement('input');
                        question.className = 'w-full border board-theme-border p-2 text-sm board-theme-text-primary';
                        question.value = widget.question || '';
                        question.placeholder = 'Soru';
                        question.dataset.field = 'question';
                        question.addEventListener('input', (event) => {
                            widget.question = event.target.value;
                        });
                        body.appendChild(question);

                        const optionsWrap = document.createElement('div');
                        optionsWrap.className = 'mt-2 flex flex-col gap-2';
                        (widget.options || []).forEach((option) => {
                            const row = document.createElement('div');
                            row.className = 'flex flex-wrap gap-2 items-center';

                            const optionInput = document.createElement('input');
                            optionInput.className = 'flex-1 min-w-[12rem] border board-theme-border p-2 text-sm board-theme-text-primary';
                            optionInput.value = option.label || '';
                            optionInput.dataset.field = 'poll_option';
                            optionInput.dataset.optionId = option.id;
                            optionInput.addEventListener('input', (event) => {
                                 option.label = event.target.value;
                            });

                            const removeBtn = document.createElement('button');
                            removeBtn.className = 'border board-theme-border px-2 py-1 text-xs whitespace-nowrap';
                            removeBtn.textContent = 'Sil';
                            removeBtn.addEventListener('click', () => removePollOption(widget, option.id));

                            row.appendChild(optionInput);
                            row.appendChild(removeBtn);
                            optionsWrap.appendChild(row);
                        });
                        body.appendChild(optionsWrap);

                        const addOptionBtn = document.createElement('button');
                        addOptionBtn.className = 'mt-2 border board-theme-border px-2 py-1 text-xs';
                        addOptionBtn.textContent = 'Seçenek ekle';
                        addOptionBtn.addEventListener('click', () => addPollOption(widget));
                        body.appendChild(addOptionBtn);
                    } else if (widget.type === 'clock') {
                        const showDateLabel = document.createElement('label');
                        showDateLabel.className = 'flex items-center gap-2 text-xs board-theme-text-secondary';

                        const showDateInput = document.createElement('input');
                        showDateInput.type = 'checkbox';
                        showDateInput.checked = widget.show_date !== false;
                        showDateInput.addEventListener('change', (event) => {
                            widget.show_date = event.target.checked;
                        });

                        const showDateText = document.createElement('span');
                        showDateText.textContent = 'Tarihi göster';

                        showDateLabel.appendChild(showDateInput);
                        showDateLabel.appendChild(showDateText);
                        body.appendChild(showDateLabel);

                        const showSecondsLabel = document.createElement('label');
                        showSecondsLabel.className = 'mt-2 flex items-center gap-2 text-xs board-theme-text-secondary';

                        const showSecondsInput = document.createElement('input');
                        showSecondsInput.type = 'checkbox';
                        showSecondsInput.checked = Boolean(widget.show_seconds);
                        showSecondsInput.addEventListener('change', (event) => {
                            widget.show_seconds = event.target.checked;
                        });

                        const showSecondsText = document.createElement('span');
                        showSecondsText.textContent = 'Saniyeyi göster';

                        showSecondsLabel.appendChild(showSecondsInput);
                        showSecondsLabel.appendChild(showSecondsText);
                        body.appendChild(showSecondsLabel);
                    } else if (widget.type === 'controls') {
                        const createCheckbox = (label, key) => {
                            const wrap = document.createElement('label');
                            wrap.className = 'flex items-center gap-2 text-xs board-theme-text-secondary mb-2';
                            const input = document.createElement('input');
                            input.type = 'checkbox';
                            input.checked = Boolean(widget[key]);
                            if (key !== 'show_reload' && widget[key] === undefined) input.checked = true;
                            input.addEventListener('change', (e) => {
                                widget[key] = e.target.checked;
                            });
                            const text = document.createElement('span');
                            text.textContent = label;
                            wrap.appendChild(input);
                            wrap.appendChild(text);
                            return wrap;
                        };

                        body.appendChild(createCheckbox('Konfeti butonu', 'show_confetti'));
                        body.appendChild(createCheckbox('Tema butonu', 'show_theme'));
                        body.appendChild(createCheckbox('Yeniden yükle butonu', 'show_reload'));
                        body.appendChild(createCheckbox('Yazıları göster', 'display_text'));
                    }
                    card.appendChild(body);

                    if (canEdit) {
                        const controls = document.createElement('div');
                        controls.className = 'flex flex-wrap gap-2 mt-3';

                        const upBtn = document.createElement('button');
                        upBtn.className = 'border board-theme-border px-2 py-1 text-xs';
                        upBtn.textContent = '↑';
                        upBtn.addEventListener('click', () => moveWidget(widget.key, -1));
                        if (widget.pinned && !canPin) {
                            upBtn.disabled = true;
                            upBtn.classList.add('opacity-50');
                        }

                        const downBtn = document.createElement('button');
                        downBtn.className = 'border board-theme-border px-2 py-1 text-xs';
                        downBtn.textContent = '↓';
                        downBtn.addEventListener('click', () => moveWidget(widget.key, 1));
                        if (widget.pinned && !canPin) {
                            downBtn.disabled = true;
                            downBtn.classList.add('opacity-50');
                        }

                        const removeBtn = document.createElement('button');
                        removeBtn.className = 'border board-theme-border px-2 py-1 text-xs';
                        removeBtn.textContent = 'Kaldır';
                        removeBtn.addEventListener('click', () => removeWidget(widget.key));
                        if (widget.pinned) {
                            removeBtn.disabled = true;
                            removeBtn.classList.add('opacity-50');
                        }

                        controls.appendChild(upBtn);
                        controls.appendChild(downBtn);
                        controls.appendChild(removeBtn);

                        if (canPin) {
                            const pinBtn = document.createElement('button');
                            pinBtn.className = 'border board-theme-border px-2 py-1 text-xs';
                            pinBtn.textContent = widget.pinned ? 'Sabitlemeyi kaldır' : 'Sabitle';
                            pinBtn.addEventListener('click', () => togglePin(widget.key));
                            controls.appendChild(pinBtn);
                        }

                        if (controls.children.length > 0) {
                            card.appendChild(controls);
                        }
                    }

                    // tag the card so we can find fields by widget key
                    card.dataset.widgetKey = widget.key;

                    widgetsEl.appendChild(card);
                });
        }

        function renderThemeOptions() {
            if (!themeListEl || !boardData) return;
            const presets = Array.isArray(boardData.theme_presets) ? boardData.theme_presets : [];
            const currentKey = boardData.theme_key || boardData.theme?.key || '';
            themeListEl.innerHTML = '';

            presets.forEach((preset) => {
                const card = document.createElement('button');
                card.type = 'button';
                card.className = 'text-left border board-theme-border p-3 board-theme-card focus:outline-none focus:ring-2 focus:ring-slate-400';
                if (preset.key === currentKey) {
                    card.classList.add('ring-2', 'ring-slate-500');
                }

                const header = document.createElement('div');
                header.className = 'text-sm font-semibold board-theme-text-primary';
                header.textContent = preset.label || preset.key;
                card.appendChild(header);

                const swatchWrap = document.createElement('div');
                swatchWrap.className = 'mt-2 flex flex-wrap gap-2';
                const colors = preset.colors || {};
                const swatches = [
                    { label: 'Arkaplan', background: colors.background, color: colors.textPrimary, border: colors.cardBorder },
                    { label: 'Kart', background: colors.cardBackground, color: colors.textPrimary, border: colors.cardBorder },
                    { label: 'Metin', background: colors.background, color: colors.textPrimary, border: colors.cardBorder },
                    { label: 'İkincil', background: colors.background, color: colors.textSecondary, border: colors.cardBorder }
                ];

                swatches.forEach((swatch) => {
                    const box = document.createElement('div');
                    box.className = 'text-xs px-2 py-1 rounded border board-theme-border';
                    box.textContent = swatch.label;
                    box.style.background = swatch.background || '#ffffff';
                    box.style.color = swatch.color || '#0f172a';
                    box.style.borderColor = swatch.border || '#cbd5f5';
                    swatchWrap.appendChild(box);
                });

                card.appendChild(swatchWrap);

                if (Array.isArray(colors.confettiColors) && colors.confettiColors.length > 0) {
                    const confettiWrap = document.createElement('div');
                    confettiWrap.className = 'flex flex-wrap items-center gap-2 mt-2 w-full';

                    const label = document.createElement('div');
                    label.className = 'text-xs board-theme-text-secondary';
                    label.textContent = 'Konfeti:';
                    confettiWrap.appendChild(label);

                    colors.confettiColors.forEach((color) => {
                        const dot = document.createElement('span');
                        dot.className = 'inline-block w-4 h-4 rounded border board-theme-border';
                        dot.style.background = color;
                        dot.style.borderColor = colors.cardBorder || '#cbd5f5';
                        dot.title = color;
                        confettiWrap.appendChild(dot);
                    });

                    card.appendChild(confettiWrap);
                }

                card.addEventListener('click', () => {
                    boardData.theme_key = preset.key;
                    boardData.theme = preset;
                    renderThemeOptions();
                    saveTheme();
                });

                themeListEl.appendChild(card);
            });
        }

        function pickRandomTheme() {
            if (!boardData) return;
            const presets = Array.isArray(boardData.theme_presets) ? boardData.theme_presets : [];
            if (!presets.length) return;
            const currentKey = boardData.theme_key || boardData.theme?.key || '';
            const choices = presets.filter((preset) => preset.key !== currentKey);
            const list = choices.length ? choices : presets;
            const pick = list[Math.floor(Math.random() * list.length)];
            if (!pick) return;
            boardData.theme_key = pick.key;
            boardData.theme = pick;
            renderThemeOptions();
            saveTheme();
        }

        async function saveTheme() {
            if (!boardData?.theme_key) return;
            clearStatus();
            try {
                const res = await fetch(`${API_URL}/board`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Session-ID': token
                    },
                    body: JSON.stringify({ theme_key: boardData.theme_key })
                });
                if (res.status === 403) {
                    showPermissionError('Düzenlemek için yetkiniz yok.');
                    return;
                }
                if (!res.ok) {
                    showStatus('Tema kaydedilemedi.', true);
                    return;
                }
                boardData = await res.json();
                renderThemeOptions();
                showStatus('Tema kaydedildi.');
            } catch (err) {
                showStatus('Tema kaydedilemedi.', true);
            }
        }

        async function init() {
            try {
                const meRes = await fetch(`${API_URL}/me`, { headers: { 'X-Session-ID': token } });
                if (!meRes.ok) {
                    window.location.href = '/login';
                    return;
                }
                const me = await meRes.json();
                if (!me.real) {
                    window.location.href = '/login';
                    return;
                }
                if (me.banned) {
                    window.location.href = '/account';
                    return;
                }

                canEdit = hasRank(me.permissions || []);
                canPin = (me.permissions || []).includes('admin');

                if (moderatorHelpEl) {
                    const modIdx = ranks.indexOf('moderator');
                    const userHighest = highestRankIndex(me.permissions || []);
                    if (userHighest >= modIdx) {
                        moderatorHelpEl.classList.remove('hidden');
                        moderatorHelpEl.classList.add('inline-block', 'align-top', 'max-w-sm');
                    }
                }

                if (!canEdit) {
                    showPermissionError('Düzenlemek için yetkiniz yok.');
                    return;
                }

                boardData = await loadBoard();
                normalizeOrder();
                renderBoard();
                renderThemeOptions();
            } catch (err) {
                if (err && err.message === 'permission') {
                    showPermissionError('Düzenlemek için yetkiniz yok.');
                    return;
                }
                showStatus('Yüklenemedi. :(', true);
            }
        }

        addBtnEl?.addEventListener('click', () => {
            if (!addSelectEl) return;
            if (!addSelectEl.value) return;
            addWidget(addSelectEl.value);
            addSelectEl.value = '';
        });

        saveBtnEl?.addEventListener('click', saveBoard);

        if (themeRandomEl) {
            themeRandomEl.addEventListener('click', pickRandomTheme);
        }

        function buildConfettiPayload() {
            const payload = {};

            const parseNumberInput = (raw) => {
                if (!raw) return null;
                const normalized = raw.replace(',', '.');
                const value = Number(normalized);
                return Number.isFinite(value) ? value : null;
            };

            const count = parseNumberInput(confettiCountEl?.value?.trim());
            if (count !== null) {
                payload.particleCount = Math.trunc(count);
            }

            const size = parseNumberInput(confettiSizeEl?.value?.trim());
            if (size !== null) {
                payload.sizeScale = size;
            }

            const spread = parseNumberInput(confettiSpreadEl?.value?.trim());
            if (spread !== null) {
                payload.spread = spread;
            }

            const duration = parseNumberInput(confettiDurationEl?.value?.trim());
            if (duration !== null) {
                payload.durationMs = Math.trunc(duration);
            }

            const spawn = parseNumberInput(confettiSpawnEl?.value?.trim());
            if (spawn !== null) {
                payload.spawnDurationMs = Math.trunc(spawn);
            }

            const upward = parseNumberInput(confettiUpEl?.value?.trim());
            if (upward !== null) {
                payload.upwardBoost = upward;
            }

            return payload;
        }

        async function triggerConfetti() {
            try {
                const payload = buildConfettiPayload();
                const res = await fetch(`${API_URL}/board/confetti`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Session-ID': token
                    },
                    body: JSON.stringify(payload)
                });
                if (res.status === 403) {
                    showPermissionError('Düzenlemek için yetkiniz yok.');
                    return;
                }
                if (!res.ok) {
                    showStatus('Konfeti gönderilemedi.', true);
                    return;
                }
                showStatus('Konfeti gönderildi.');
            } catch (err) {
                showStatus('Konfeti gönderilemedi.', true);
            }
        }

        async function triggerBoardRestart() {
            try {
                const res = await fetch(`${API_URL}/board/restart`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Session-ID': token
                    }
                });
                if (res.status === 403) {
                    showPermissionError('Düzenlemek için yetkiniz yok.');
                    return;
                }
                if (!res.ok) {
                    showStatus('Ekran yeniden başlatılamadı.', true);
                    return;
                }
                showStatus('Ekrana yeniden başlama komutu gönderildi.');
            } catch (err) {
                showStatus('Ekran yeniden başlatılamadı.', true);
            }
        }

        async function triggerBoardDebugScreen() {
            try {
                const res = await fetch(`${API_URL}/board/redirect`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Session-ID': token
                    },
                    body: JSON.stringify({ path: '/debug/screen' })
                });
                if (res.status === 403) {
                    showPermissionError('Düzenlemek için yetkiniz yok.');
                    return;
                }
                if (!res.ok) {
                    showStatus('Yönlendirme gönderilemedi.', true);
                    return;
                }
                showStatus('Tahta yönlendirme komutu gönderildi.');
            } catch (err) {
                showStatus('Yönlendirme gönderilemedi.', true);
            }
        }

         if (confettiBtnEl) {
             confettiBtnEl.addEventListener('click', triggerConfetti);
         }

         if (restartBtnEl) {
             restartBtnEl.addEventListener('click', triggerBoardRestart);
         }

         if (debugScreenBtnEl) {
             debugScreenBtnEl.addEventListener('click', triggerBoardDebugScreen);
         }

         init();
     </script>
 </Layout>
