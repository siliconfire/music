---
import Layout from '../layouts/Layout.astro';
import BoardThemeLoader from '../components/BoardThemeLoader.astro';
import Search from '../components/Search.astro';
import Queue from '../components/Queue.astro';
import NowPlaying from '../components/NowPlaying.astro';
import Item from '../components/Item.astro';
---

<Layout title="Müzik Kontrolleri" themeLoading={true}>
	<BoardThemeLoader />
	<div class="m-5 lg:m-10">
		<h1 class="text-2xl board-theme-text-primary">Müzik Kontrolleri</h1>
		<a href="/" class="mb-10 inline-block text-sm board-theme-text-secondary hover:underline">
			(ana sayfaya geri dön)
		</a>
		<div class="flex flex-wrap gap-5 max-w-full overflow-x-hidden">
			<fieldset id="div-lockdown" class="hidden p-5 border border-red-500 bg-red-100 w-full">
					<legend class="text-red-700 font-bold">Dikkat</legend>
					<p class="text-red-700">Sistem kilitlendi.</p>
					<p class="text-red-700">Lütfen kilidin kaldırılması için bir öğretmenden yardım isteyin.</p>
			</fieldset>
			<Item title="Kontroller">
				<button id="btn-play" class="border board-theme-border p-3 mx-2">Başlat</button>
				<button id="btn-pause" class="border board-theme-border p-3 mx-2">Durdur</button>
				<button id="btn-next" class="border board-theme-border p-3 mx-2">Atla</Button>
			</Item>
			<Item title="Çalıyor" className="item-card">
				<NowPlaying />
			</Item>
			<Item title="Ara">
				<Search />
			</Item>
			<Item title="Kuyruk">
				<Queue showHeader={false} />
			</Item>
			<Item title="Cihaz seçme">
				<div id="div-devices" class="max-w-full overflow-hidden">
					<select id="select-device" class="text-sm border board-theme-border p-1 mb-2 max-w-full">
						<option value="">Cihazlar taranıyor...</option>
					</select>
					<br>
					<button id="btn-set-device" class="text-sm border board-theme-border px-2 py-1">Onayla</button>
					<hr class="board-theme-border my-3">
					<p class="text-sm mb-2">Eğer müzik çalmıyor ise, buradan cihaz seçip ardından tekrar deneyin.</p>
					<p class="text-xs board-theme-text-secondary mb-2">(Bazen spotify garip davranabiliyor.)</p>
				</div>
			</Item>
		</div>
	</div>


	<script>
		import { API_URL } from '../lib/constants';

		const token = localStorage.getItem("jwt_token");
		if (!token) {
			window.location.href = '/login';
		} else {
			handleUserInfo();
		}

		async function handleUserInfo() {
			const response = await fetch(`${API_URL}/me`, {headers: {'X-Session-ID': token}});
			const user_info = await response.json();

			if (user_info.banned) {
				window.location.href = '/account';
			}

			// Identify the user in PostHog with their ID and name (server-provided)
			if (user_info.id && String(user_info.id) !== '100000') {
				window.posthog?.identify(String(user_info.id), { name: user_info.name });
			}

			const username_el = document.getElementById("username") as HTMLSpanElement | null;
			if (username_el) {
				username_el.innerText = user_info.name;
			}

			const perms = user_info.permissions;

			if (perms.includes("music") || perms.includes("musicpermanent")) {
				fetchDevices();
			} else {
				const devWrap = document.getElementById('div-devices');
				if (devWrap) devWrap.innerHTML = '<p class="text-xs board-theme-text-error">Cihaz değiştirmek için "music" yetkisine sahip olmalısınız.</p>';
			}
		}

		async function fetchDevices() {
			const select = document.getElementById('select-device') as HTMLSelectElement;
			if (!select) return;

			try {
				const res = await fetch(`${API_URL}/admin/spotify/devices`, {
					headers: { 'X-Session-ID': token }
				});
				if (!res.ok) throw new Error();
				const data = await res.json();
				const devices = data.devices || [];

				select.innerHTML = '';
				if (devices.length === 0) {
					const opt = document.createElement('option');
					opt.value = '';
					opt.textContent = 'Aktif cihaz bulunamadı.';
					select.appendChild(opt);
				} else {
					devices.forEach((dev) => {
						const opt = document.createElement('option');
						opt.value = dev.id;
						opt.textContent = `${dev.name}${dev.is_active ? ' (Aktif)' : ''}`;
						if (dev.is_active) opt.selected = true;
						select.appendChild(opt);
					});
				}
			} catch (err) {
				select.innerHTML = '<option value="">Cihazlar alınamadı.</option>';
			}
		}

		const btnSetDevice = document.getElementById('btn-set-device');
		btnSetDevice?.addEventListener('click', async () => {
			const select = document.getElementById('select-device') as HTMLSelectElement;
			const deviceId = select.value;
			if (!deviceId) return;

			btnSetDevice.textContent = 'Değiştiriliyor...';
			try {
				const res = await fetch(`${API_URL}/admin/spotify/device?device_id=${deviceId}`, {
					method: 'POST',
					headers: { 'X-Session-ID': token }
				});
				if (res.ok) {
					alert('Cihaz başarıyla değiştirildi.');
					fetchDevices();
				} else {
					alert('Cihaz değiştirilemedi.');
				}
			} catch (err) {
				alert('Bir hata oluştu.');
			} finally {
				btnSetDevice.textContent = 'Seç';
			}
		});

		document.getElementById("btn-play")?.addEventListener("click", async () => {
			await fetch(`${API_URL}/resume`, { headers: { 'X-Session-ID': token }, method: 'POST' }
		);
			window.posthog?.capture('music_playback_resumed');
		});

		document.getElementById("btn-pause")?.addEventListener("click", async () => {
			await fetch(`${API_URL}/pause`, { headers: { 'X-Session-ID': token }, method: 'POST' }
		);
			window.posthog?.capture('music_playback_paused');
		});

		document.getElementById("btn-next")?.addEventListener("click", async () => {
			await fetch(`${API_URL}/next`, { headers: { 'X-Session-ID': token }, method: 'POST' }
		);
			window.posthog?.capture('music_track_skipped');
		});
		document.getElementById("btn-account")?.addEventListener("click", () => {
			window.location.href = '/account';
		});

		document.getElementById("btn-logout")?.addEventListener("click", () => {
			window.posthog?.capture('user_logged_out');
			window.posthog?.reset();
			localStorage.removeItem("jwt_token");
			window.location.href = '/login';
		});

		document.getElementById("btn-less-confetti")?.addEventListener("click", async () => {
			await fetch(`${API_URL}/board/confetti`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'X-Session-ID': token
				},
				body: JSON.stringify({
					particleCount: 10,
					sizeScale: 2,
					spread: 1,
					durationMs: 2000,
					spawnDurationMs: 1000,
					upwardBoost: 1
				})
			});
			window.posthog?.capture('confetti_triggered', { type: 'less' });
		});

		document.getElementById("btn-normal-confetti")?.addEventListener("click", async () => {
			await fetch(`${API_URL}/board/confetti`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'X-Session-ID': token
				},
				body: JSON.stringify({
					particleCount: 3000,
					sizeScale: 4,
					spread: 0.5,
					durationMs: 10000,
					spawnDurationMs: 1500,
					upwardBoost: 1.5
				})
			});
			window.posthog?.capture('confetti_triggered', { type: 'normal' });
		});

		document.getElementById("btn-faster-confetti")?.addEventListener("click", async () => {
			await fetch(`${API_URL}/board/confetti`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'X-Session-ID': token
				},
				body: JSON.stringify({
					particleCount: 3000,
					sizeScale: 4,
					spread: 0.5,
					durationMs: 10000,
					spawnDurationMs: 1500,
					upwardBoost: 1.5
				})
			});
			window.posthog?.capture('confetti_triggered', { type: 'faster' });
		});

		document.getElementById("btn-many-confetti")?.addEventListener("click", async () => {
			await fetch(`${API_URL}/board/confetti`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'X-Session-ID': token
				},
				body: JSON.stringify({
					particleCount: 10000,
					sizeScale: 10,
					spread: 2,
					durationMs: 8500,
					spawnDurationMs: 5000,
					upwardBoost: 3
				})
			});
			window.posthog?.capture('confetti_triggered', { type: 'many' });
		});

		document.getElementById("btn-edit")?.addEventListener("click", () => {
			window.location.href = '/board/edit';
		});
	</script>
</Layout>











