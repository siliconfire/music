---
import '../../../styles/global.css'
import Layout from '../../../layouts/Layout.astro'
import AdminBack from '../../../components/AdminBack.astro'
---

<Layout title="Yönetici - Yetki yönetimi">
    <div class="m-10">
        <h1 class="text-2xl text-slate-800 mt-10">Yetki yönetimi</h1>
        <AdminBack />

        <p>Kullanıcıların yetkilerini değiştir.</p>

        <div id="notice"></div>

        <div id="actor">Yükleniyor...</div>

        <div class="border border-slate-300 p-5 my-5 inline-block">
            <label>
                Kullanıcı IDsi
                <input id="target-id" class="border border-slate-200" placeholder="örnek: 123456" />
            </label>
            <br>
            <label>

                Yetki <select id="permission" class="border border-slate-200">
                    <option value="">(yetki seç)</option>
                </select>
            </label>

            <div class="mt-3">
                <button id="btn-grant" class="bg-green-100 p-2 mx-1">Yetki Ekle</button>
                <button id="btn-revoke" class="bg-red-100 p-2 mx-1">Yetki Kaldır</button>
            </div>
        </div>

        <div id="result">...</div>
    </div>

    <script type="module">
        const API_URL = "http://127.0.0.1:8000";
        const RANKS = ["music", "musicpermanent", "moderator", "admin", "superadmin", "dev"];

        document.addEventListener('DOMContentLoaded', () => {
            const actorDiv = document.getElementById('actor');
            const noticeDiv = document.getElementById('notice');
            const resultDiv = document.getElementById('result');
            const targetInput = document.getElementById('target-id');
            const permissionSelect = document.getElementById('permission');
            const grantBtn = document.getElementById('btn-grant');
            const revokeBtn = document.getElementById('btn-revoke');

            if (!actorDiv || !noticeDiv || !resultDiv || !targetInput || !permissionSelect || !grantBtn || !revokeBtn) {
                return;
            }

            let actor = null;
            let lookupTimer = null;
            let lookupAbort = null;

            function highestRankIndex(perms) {
                const idx = perms.map(p => RANKS.indexOf(p)).filter(i => i >= 0);
                return idx.length ? Math.max(...idx) : -1;
            }

            function showNotice(msg, type = 'info') {
                noticeDiv.innerHTML = `<div class="p-3 rounded border ${type === 'error' ? 'bg-red-100 border-red-300 text-red-700' : 'bg-green-100 border-green-300 text-green-700'}">${msg}</div>`;
                setTimeout(() => { if (noticeDiv.innerHTML) noticeDiv.innerHTML = ''; }, 5000);
            }

            function renderActor() {
                const actorRank = highestRankIndex(actor.permissions || []);
                const actorRankName = actorRank >= 0 ? RANKS[actorRank] : 'yok';
                actorDiv.innerHTML = `Siz: <strong>${actor.name}</strong> (${actor.id}/${actorRankName})`;

                const options = RANKS.map((r, idx) => {
                    const allowDevToDev = actorRank === RANKS.indexOf('dev') && r === 'dev';
                    const disabled = idx >= actorRank && !allowDevToDev;
                    return `<option value="${r}" ${disabled ? 'disabled' : ''}>${r}${disabled ? ' (yasak)' : ''}</option>`;
                }).join('');

                permissionSelect.innerHTML = `<option value="">-- yetki seç --</option>${options}`;
            }

            async function loadActor() {
                const token = localStorage.getItem('jwt_token');
                if (!token) {
                    window.location.href = '/login';
                    return;
                }

                try {
                    const meRes = await fetch(`${API_URL}/me`, { headers: { 'X-Session-ID': token } });
                    if (!meRes.ok) {
                        window.location.href = '/login';
                        return;
                    }

                    actor = await meRes.json();
                    const actorRank = highestRankIndex(actor.permissions || []);

                    if (actorRank < RANKS.indexOf('admin')) {
                        actorDiv.innerHTML = 'baybay...';
                        grantBtn.disabled = true;
                        revokeBtn.disabled = true;
                        return;
                    }

                    renderActor();
                    grantBtn.disabled = false;
                    revokeBtn.disabled = false;
                } catch (err) {
                    console.error(err);
                    actorDiv.innerHTML = 'Sunucuya bağlanırken hata oluştu.';
                    showNotice('Sunucuya bağlanırken hata oluştu.', 'error');
                    grantBtn.disabled = true;
                    revokeBtn.disabled = true;
                }
            }

            function renderLookupPlaceholder() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(kullanıcı bilgilerini görmek için yukarıya ID numarasını girin...)</div>';
            }

            function renderNotFound() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(böyle bir kullanıcı bulunamadı.)</div>';
            }

            function renderLoading() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(kullanıcı aranıyor...)</div>';
            }

            function renderUser(user) {
                resultDiv.innerHTML = `
                    <div class="p-3 border rounded bg-white">
                        <div class="font-medium">${user.name || 'Kullanıcı'} <span class="text-sm text-slate-600">(ID: ${user.id || targetInput.value.trim()})</span></div>
                        <div class="mt-1">Yetkiler: ${user.permissions?.join(', ') || 'yok'}</div>
                    </div>
                `;
            }

            async function lookupUser() {
                const targetId = targetInput.value.trim();
                if (!targetId) {
                    renderLookupPlaceholder();
                    return;
                }

                const token = localStorage.getItem('jwt_token');
                if (!token) {
                    return;
                }

                if (lookupAbort) {
                    lookupAbort.abort();
                }
                lookupAbort = new AbortController();

                try {
                    renderLoading();
                     const res = await fetch(`${API_URL}/admin/users/${encodeURIComponent(targetId)}`, {
                         headers: { 'X-Session-ID': token },
                         signal: lookupAbort.signal
                     });

                     if (res.status === 404) {
                         renderNotFound();
                         return;
                     }

                     if (!res.ok) {
                         renderLookupPlaceholder();
                         return;
                     }

                     const data = await res.json();
                     if (data?.user) {
                         renderUser(data.user);
                     } else {
                         renderNotFound();
                     }
                 } catch (err) {
                     if (err?.name !== 'AbortError') {
                         renderLookupPlaceholder();
                     }
                 }
            }

            function scheduleLookup() {
                if (lookupTimer) {
                    clearTimeout(lookupTimer);
                }
                const targetId = targetInput.value.trim();
                if (!targetId) {
                    renderLookupPlaceholder();
                    return;
                }
                renderLoading();
                lookupTimer = setTimeout(lookupUser, 300);
            }

            async function submit(action) {
                const token = localStorage.getItem('jwt_token');
                if (!token) { window.location.href = '/login'; return; }

                if (!actor) {
                    showNotice('Önce kullanıcı bilgileri yüklenmeli. Lütfen bekleyin.', 'error');
                    return;
                }

                const targetId = targetInput.value.trim();
                const permission = permissionSelect.value;

                if (!targetId) {
                    showNotice('kullanıcı IDsini niye girmedin? :(', 'error');
                    return;
                }
                if (!permission) {
                    showNotice('peki niye yetki seçmedin? :(', 'error');
                    return;
                }

                const actorRank = highestRankIndex(actor.permissions || []);
                const permIndex = RANKS.indexOf(permission);
                const allowDevToDev = actorRank === RANKS.indexOf('dev') && permission === 'dev';
                if (permIndex >= actorRank && !allowDevToDev) {
                    showNotice('Bunu yapmaya yetkiniz yok.', 'error');
                    return;
                }

                const url = `${API_URL}/admin/users/${encodeURIComponent(targetId)}/permissions?permission=${encodeURIComponent(permission)}`;
                const method = action === 'grant' ? 'POST' : 'DELETE';

                try {
                    const res = await fetch(url, { method, headers: { 'X-Session-ID': token } });
                    const data = await res.json().catch(() => ({}));

                    if (!res.ok) {
                        showNotice(data.detail || 'İşlem başarısız.', 'error');
                        return;
                    }

                    showNotice(action === 'grant' ? 'Yetki eklendi.' : 'Yetki kaldırıldı.');

                    if (data.user) {
                        renderUser(data.user);
                     }
                } catch (err) {
                    console.error(err);
                    showNotice('Sunucu hatası. :( bunu okuyorsan siteyi kapatıp en baştan tekrar açmayı dene, yine de olmuyorsa sıkıntı bende demektir.', 'error');
                }
            }

            grantBtn.disabled = true;
            revokeBtn.disabled = true;
            grantBtn.addEventListener('click', () => submit('grant'));
            revokeBtn.addEventListener('click', () => submit('revoke'));
            targetInput.addEventListener('input', scheduleLookup);

            renderLookupPlaceholder();
            loadActor();
        });
    </script>
</Layout>
