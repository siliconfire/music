---
import '../../../styles/global.css'
import Layout from '../../../layouts/Layout.astro'
import AdminBack from '../../../components/AdminBack.astro'
---

<Layout title="Admin Console">
    <div class="m-10">
        <h1 class="text-2xl text-slate-800 mt-10">Hesap Kapatma</h1>
        <AdminBack />

        <p>Kullanıcıların hesaplarını kapatın veya açın.</p>

        <div id="notice"></div>

        <div id="actor">Yukleniyor...</div>

        <div class="border border-slate-300 p-5 my-5 inline-block">
            <label>
                Kullanici IDsi
                <input id="target-id" class="border border-slate-200" placeholder="örnek: 123456" />
            </label>
            <br><br>
            <label>
                Sebep (isteğe bağlı) (kişiye gösterilecek)
                <textarea id="reason" class="border border-slate-200 w-full" rows="3" placeholder="sebep girin..."></textarea>
            </label>

            <div class="mt-3">
                <button id="btn-ban" class="bg-red-100 p-2 mx-1">Hesabını kapat</button>
                <button id="btn-unban" class="bg-green-100 p-2 mx-1">Hesabını aç</button>
            </div>
        </div>

        <div id="result">...</div>
    </div>

    <script type="module">
        const API_URL = "http://127.0.0.1:8000";
        const RANKS = ["music", "musicpermanent", "moderator", "admin", "superadmin", "dev"];

        document.addEventListener('DOMContentLoaded', () => {
            const actorDiv = document.getElementById('actor');
            const noticeDiv = document.getElementById('notice');
            const resultDiv = document.getElementById('result');
            const targetInput = document.getElementById('target-id');
            const reasonInput = document.getElementById('reason');
            const banBtn = document.getElementById('btnEl-ban');
            const unbanBtn = document.getElementById('btnEl-unban');

            if (!actorDiv || !noticeDiv || !resultDiv || !targetInput || !reasonInput || !banBtn || !unbanBtn) {
                return;
            }

            let actor = null;
            let lastUser = null;
            let lookupTimer = null;
            let lookupAbort = null;

            function highestRankIndex(perms) {
                const idx = perms.map(p => RANKS.indexOf(p)).filter(i => i >= 0);
                return idx.length ? Math.max(...idx) : -1;
            }

            function showNotice(msg, type = 'info') {
                noticeDiv.innerHTML = `<div class="p-3 rounded border ${type === 'error' ? 'bg-red-100 border-red-300 text-red-700' : 'bg-green-100 border-green-300 text-green-700'}">${msg}</div>`;
                setTimeout(() => { if (noticeDiv.innerHTML) noticeDiv.innerHTML = ''; }, 5000);
            }

            function renderActor() {
                const actorRank = highestRankIndex(actor.permissions || []);
                const actorRankName = actorRank >= 0 ? RANKS[actorRank] : 'yok';
                actorDiv.innerHTML = `Siz: <strong>${actor.name}</strong> (${actor.id}/${actorRankName})`;
            }

            async function loadActor() {
                const token = localStorage.getItem('jwt_token') || '';

                try {
                    const meRes = await fetch(`${API_URL}/me`, { headers: { 'X-Session-ID': token } });
                    if (!meRes.ok) {
                        throw new Error('me request failed');
                    }

                    actor = await meRes.json();
                    renderActor();
                    banBtn.disabled = false;
                    unbanBtn.disabled = false;
                } catch (err) {
                    console.error(err);
                    actorDiv.innerHTML = 'Sunucuya bağlanırken hata olustu.';
                    showNotice('Sunucuya bağlanırken hata olustu.', 'error');
                    banBtn.disabled = true;
                    unbanBtn.disabled = true;
                }
            }

            function renderLookupPlaceholder() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(kullanıcı bilgilerini görmek için yukarıya ID numarasını girin...)</div>';
            }

            function renderNotFound() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(boyle bir kullanıcı bulunamadı.)</div>';
            }

            function renderLoading() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(kullanıcı aranıyor...)</div>';
            }

            function renderUser(user) {
                lastUser = user;
                const bannedText = user.banned ? 'evet' : 'hayır';
                const reasonText = user.reason ? user.reason : '-';
                const banBanner = user.banned
                    ? `<p class="mt-3 p-3 bg-red-50 border border-red-200 text-red-700 font-medium">Bu hesap kullanıma kapatıldı.</p>`
                    : '';
                resultDiv.innerHTML = `
                    <div class="p-3 border rounded bg-white">
                        <div class="font-medium">${user.name || 'Kullanici'} <span class="text-sm text-slate-600">(ID: ${user.id || targetInput.value.trim()})</span></div>
                        <div class="mt-1">Yetkiler: ${user.permissions?.join(', ') || 'yok'}</div>
                        <div class="mt-1">Hesabı kapalı?: ${bannedText}</div>
                        <div class="mt-1">Sebep: ${reasonText}</div>
                        ${banBanner}
                    </div>
                `;
            }

            async function lookupUser() {
                const targetId = targetInput.value.trim();
                if (!targetId) {
                    renderLookupPlaceholder();
                    return;
                }

                const token = localStorage.getItem('jwt_token') || '';

                if (lookupAbort) {
                    lookupAbort.abort();
                }
                lookupAbort = new AbortController();

                try {
                    renderLoading();
                    const res = await fetch(`${API_URL}/admin/users/${encodeURIComponent(targetId)}`, {
                        headers: { 'X-Session-ID': token },
                        signal: lookupAbort.signal
                    });

                    if (res.status === 404) {
                        renderNotFound();
                        lastUser = null;
                        return;
                    }

                    if (!res.ok) {
                        renderLookupPlaceholder();
                        lastUser = null;
                        return;
                    }

                    const data = await res.json();
                    if (data?.user) {
                        renderUser(data.user);
                    } else {
                        renderNotFound();
                        lastUser = null;
                    }
                } catch (err) {
                    if (err?.name !== 'AbortError') {
                        renderLookupPlaceholder();
                        lastUser = null;
                    }
                }
            }

            function scheduleLookup() {
                if (lookupTimer) {
                    clearTimeout(lookupTimer);
                }
                const targetId = targetInput.value.trim();
                if (!targetId) {
                    renderLookupPlaceholder();
                    return;
                }
                renderLoading();
                lookupTimer = setTimeout(lookupUser, 300);
            }

            async function submit(action) {
                const token = localStorage.getItem('jwt_token') || '';

                if (!actor) {
                    showNotice('Sakin, daha kullanıcı bilgilerini çekemedim bile. eğer ', 'error');
                    return;
                }

                const targetId = targetInput.value.trim();
                const reason = reasonInput.value.trim();

                if (!targetId) {
                    showNotice('Kullanici IDsi girseniz sevinirdim :(', 'error');
                    return;
                }

                if (String(actor.id) === String(targetId) && action === 'ban') {
                    showNotice('hayır. eğer gerçekten kendi hesabınızı kapatmak istiyorsanız beni bulun.', 'error');
                    return;
                }

                if (lastUser) {
                    const actorRank = highestRankIndex(actor.permissions || []);
                    const targetRank = highestRankIndex(lastUser.permissions || []);
                    if (actorRank <= targetRank) {
                        showNotice('bunu yapmaya yetkiniz yok.', 'error');
                        return;
                    }
                }

                const query = action === 'ban' && reason ? `?reason=${encodeURIComponent(reason)}` : '';
                const url = `${API_URL}/admin/users/${encodeURIComponent(targetId)}/ban${query}`;
                const method = action === 'ban' ? 'POST' : 'DELETE';

                try {
                    const res = await fetch(url, { method, headers: { 'X-Session-ID': token } });
                    const data = await res.json().catch(() => ({}));

                    if (!res.ok) {
                        showNotice(data.detail || 'hata. :(', 'error');
                        return;
                    }

                    showNotice(action === 'ban' ? 'Hesabı kapatıldı.' : 'Hesabı geri açıldı.');

                    if (data.user) {
                        renderUser(data.user);
                    } else {
                        lookupUser();
                    }
                } catch (err) {
                    console.error(err);
                    showNotice('Sunucu hatasi.', 'error');
                }
            }

            banBtn.disabled = true;
            unbanBtn.disabled = true;
            banBtn.addEventListener('click', () => submit('ban'));
            unbanBtn.addEventListener('click', () => submit('unban'));
            targetInput.addEventListener('input', scheduleLookup);

            renderLookupPlaceholder();
            loadActor();
        });
    </script>
</Layout>
