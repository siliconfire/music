---
import '../../../styles/global.css'
import Layout from '../../../layouts/Layout.astro'
import AdminBack from '../../../components/AdminBack.astro'
---

<Layout title="Yönetici - Giriş Kodu">
    <div class="m-10">
        <h1 class="text-2xl text-slate-800 mt-10">Giriş Kodu</h1>
        <AdminBack />

        <p>Kullanıcılar için giriş kodları oluştur. Zaten olan bir kodu girer</p>

        <div id="notice"></div>
        <div id="actor">Yükleniyor...</div>

        <div class="border border-slate-300 p-5 my-5 inline-block">
            <label>
                Kullanıcı ID'si
                <input id="target-id" class="border border-slate-200" placeholder="örnek: 123456" />
            </label>
            <br>
            <label>
                Kod (74 ile başlamalı)
                <input id="code" class="border border-slate-200" placeholder="örnek: 74123456" />
            </label>
            <button id="btn-generate" class="border border-slate-200 px-2 py-1 text-xs">Kod Üret</button>
            <br>
            <details class="mt-3">
                <summary class="cursor-pointer text-sm text-slate-600">Gelişmiş</summary>
                <div class="mt-3">
                    <label>
                        Kalan kullanım
                        <input id="remaining" type="number" min="-1" value="-1" class="border border-slate-200 w-24" />
                        (sınırsız için -1)
                    </label>
                    <br>
                    <label>
                        Şifre yönlendirmesi
                        <select id="set-password" class="border border-slate-200">
                            <option value="disabled">yok</option>
                            <option value="nudge">bildir</option>
                            <option value="forced">zorla</option>
                        </select>
                    </label>
                    <br>
                    <label>
                        Geçerlilik (opsiyonel)
                        <input id="valid-until" type="datetime-local" class="border border-slate-200" />
                    </label>
                </div>
            </details>

            <div class="mt-3">
                <button id="btn-save" class="bg-green-100 p-2 mx-1">Kodu Kaydet</button>
            </div>
        </div>

        <div id="result">...</div>
    </div>

    <script type="module">
        const API_URL = "http://127.0.0.1:8000";
        const RANKS = ["music", "musicpermanent", "moderator", "admin", "superadmin", "dev"];

        document.addEventListener('DOMContentLoaded', () => {
            const actorDiv = document.getElementById('actor');
            const noticeDiv = document.getElementById('notice');
            const resultDiv = document.getElementById('result');
            const targetInput = document.getElementById('target-id');
            const codeInput = document.getElementById('code');
            const remainingInput = document.getElementById('remaining');
            const setPasswordSelect = document.getElementById('set-password');
            const validUntilInput = document.getElementById('valid-until');
            const saveBtn = document.getElementById('btn-save');
            const generateBtn = document.getElementById('btn-generate');

            if (!actorDiv || !noticeDiv || !resultDiv || !targetInput || !codeInput || !remainingInput || !setPasswordSelect || !validUntilInput || !saveBtn || !generateBtn) {
                return;
            }

            let actor = null;
            let lookupTimer = null;
            let lookupAbort = null;

            function highestRankIndex(perms) {
                const idx = perms.map(p => RANKS.indexOf(p)).filter(i => i >= 0);
                return idx.length ? Math.max(...idx) : -1;
            }

            function showNotice(msg, type = 'info') {
                noticeDiv.innerHTML = `<div class="p-3 rounded border ${type === 'error' ? 'bg-red-100 border-red-300 text-red-700' : 'bg-green-100 border-green-300 text-green-700'}">${msg}</div>`;
                setTimeout(() => { if (noticeDiv.innerHTML) noticeDiv.innerHTML = ''; }, 5000);
            }

            function renderActor() {
                const actorRank = highestRankIndex(actor.permissions || []);
                const actorRankName = actorRank >= 0 ? RANKS[actorRank] : 'yok';
                actorDiv.innerHTML = `Siz: <strong>${actor.name}</strong> (${actor.id}/${actorRankName})`;
            }

            async function loadActor() {
                const token = localStorage.getItem('jwt_token') || '';

                try {
                    const meRes = await fetch(`${API_URL}/me`, { headers: { 'X-Session-ID': token } });
                    if (!meRes.ok) {
                        throw new Error('me request failed');
                    }

                    actor = await meRes.json();
                    renderActor();
                    saveBtn.disabled = false;
                } catch (err) {
                    console.error(err);
                    actorDiv.innerHTML = 'Sunucuya bağlanırken hata oluştu.';
                    showNotice('Sunucuya bağlanırken hata oluştu.', 'error');
                    saveBtn.disabled = true;
                }
            }

            function renderLookupPlaceholder() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(kullanıcı bilgilerini görmek için yukarıya ID numarasını girin...)</div>';
            }

            function renderNotFound() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(böyle bir kullanıcı bulunamadı.)</div>';
            }

            function renderLoading() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(kullanıcı aranıyor...)</div>';
            }

            function renderUser(user) {
                resultDiv.innerHTML = `
                    <div class="p-3 border rounded bg-white">
                        <div class="font-medium">${user.name || 'Kullanıcı'} <span class="text-sm text-slate-600">(ID: ${user.id || targetInput.value.trim()})</span></div>
                        <div class="mt-1">Yetkiler: ${user.permissions?.join(', ') || 'yok'}</div>
                        <div class="mt-1">Hesabı Kapalı?: ${user.banned ? 'evet' : 'hayır'}</div>
                    </div>
                `;
            }

            async function lookupUser() {
                const targetId = targetInput.value.trim();
                if (!targetId) {
                    renderLookupPlaceholder();
                    return;
                }

                const token = localStorage.getItem('jwt_token') || '';

                if (lookupAbort) {
                    lookupAbort.abort();
                }
                lookupAbort = new AbortController();

                try {
                    renderLoading();
                    const res = await fetch(`${API_URL}/admin/users/${encodeURIComponent(targetId)}`, {
                        headers: { 'X-Session-ID': token },
                        signal: lookupAbort.signal
                    });

                    if (res.status === 404) {
                        renderNotFound();
                        return;
                    }

                    if (!res.ok) {
                        renderLookupPlaceholder();
                        return;
                    }

                    const data = await res.json();
                    if (data?.user) {
                        renderUser(data.user);
                    } else {
                        renderNotFound();
                    }
                } catch (err) {
                    if (err?.name !== 'AbortError') {
                        renderLookupPlaceholder();
                    }
                }
            }

            function scheduleLookup() {
                if (lookupTimer) {
                    clearTimeout(lookupTimer);
                }
                const targetId = targetInput.value.trim();
                if (!targetId) {
                    renderLookupPlaceholder();
                    return;
                }
                renderLoading();
                lookupTimer = setTimeout(lookupUser, 300);
            }

            function generateCode() {
                const buffer = new Uint32Array(1);
                crypto.getRandomValues(buffer);
                const random = buffer[0] % 1000000;
                const suffix = String(random).padStart(6, '0');
                codeInput.value = `74${suffix}`;
            }

            async function submit() {
                const token = localStorage.getItem('jwt_token') || '';

                const targetId = targetInput.value.trim();
                const code = codeInput.value.trim();
                const remaining = Number(remainingInput.value);
                const setPassword = setPasswordSelect.value;
                const validUntil = validUntilInput.value ? validUntilInput.value : null;

                if (!targetId) {
                    showNotice('Kullanıcı ID\'si gerekli.', 'error');
                    return;
                }
                if (!code) {
                    showNotice('Kod gerekli.', 'error');
                    return;
                }
                if (!code.startsWith('74')) {
                    showNotice('Kodlar 74 ile başlamalı.', 'error');
                    return;
                }
                if (!Number.isInteger(remaining) || (remaining < 1 && remaining !== -1)) {
                    showNotice('Kalan kullanım en az 1 veya -1 olmalı.', 'error');
                    return;
                }

                try {
                    const res = await fetch(`${API_URL}/admin/users/${encodeURIComponent(targetId)}/login-code`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Session-ID': token
                        },
                        body: JSON.stringify({
                            code,
                            remaining_usage: remaining,
                            set_password: setPassword,
                            valid_until: validUntil
                        })
                    });
                    const data = await res.json().catch(() => ({}));

                    if (!res.ok) {
                        showNotice(data.detail || 'Kod kaydedilemedi.', 'error');
                        return;
                    }

                    showNotice('Kod kaydedildi.');
                } catch (err) {
                    showNotice('Sunucu hatası.', 'error');
                }
            }

            saveBtn.disabled = true;
            saveBtn.addEventListener('click', submit);
            generateBtn.addEventListener('click', generateCode);
            targetInput.addEventListener('input', scheduleLookup);

            renderLookupPlaceholder();
            loadActor();
        });
    </script>
</Layout>
