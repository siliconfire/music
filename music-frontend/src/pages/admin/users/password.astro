---
import '../../../styles/global.css'
import Layout from '../../../layouts/Layout.astro'
import AdminBack from '../../../components/AdminBack.astro'
---

<Layout title="Yönetici - Şifre Değiştir">
    <div class="m-10">
        <h1 class="text-2xl text-slate-800 mt-10">Şifre Değiştir</h1>
        <AdminBack />

        <p>Kullanıcıların şifresini değiştir.</p>

        <div id="notice"></div>
        <div id="actor">Yükleniyor...</div>

        <div class="border border-slate-300 p-5 my-5 inline-block">
            <label>
                Kullanıcı ID'si
                <input id="target-id" class="border border-slate-200" placeholder="örnek: 123456" />
            </label>
            <br>
            <label>
                Yeni şifre
                <input id="password" type="password" class="border border-slate-200" placeholder="yeni şifre" />
            </label>
            <br>
            <label>
                Yeni şifre (tekrar)
                <input id="password-confirm" type="password" class="border border-slate-200" placeholder="tekrar" />
            </label>

            <div class="mt-3">
                <button id="btn-save" class="bg-green-100 p-2 mx-1">Şifreyi Güncelle</button>
            </div>
        </div>

        <div id="result">...</div>
    </div>

    <script type="module">
        const API_URL = "http://127.0.0.1:8000";
        const RANKS = ["music", "musicpermanent", "moderator", "admin", "superadmin", "dev"];

        document.addEventListener('DOMContentLoaded', () => {
            const actorDiv = document.getElementById('actor');
            const noticeDiv = document.getElementById('notice');
            const resultDiv = document.getElementById('result');
            const targetInput = document.getElementById('target-id');
            const passwordInput = document.getElementById('password');
            const confirmInput = document.getElementById('password-confirm');
            const saveBtn = document.getElementById('btnEl-save');

            if (!actorDiv || !noticeDiv || !resultDiv || !targetInput || !passwordInput || !confirmInput || !saveBtn) {
                return;
            }

            let actor = null;
            let lookupTimer = null;
            let lookupAbort = null;

            function highestRankIndex(perms) {
                const idx = perms.map(p => RANKS.indexOf(p)).filter(i => i >= 0);
                return idx.length ? Math.max(...idx) : -1;
            }

            function showNotice(msg, type = 'info') {
                noticeDiv.innerHTML = `<div class="p-3 rounded border ${type === 'error' ? 'bg-red-100 border-red-300 text-red-700' : 'bg-green-100 border-green-300 text-green-700'}">${msg}</div>`;
                setTimeout(() => { if (noticeDiv.innerHTML) noticeDiv.innerHTML = ''; }, 5000);
            }

            function renderActor() {
                const actorRank = highestRankIndex(actor.permissions || []);
                const actorRankName = actorRank >= 0 ? RANKS[actorRank] : 'yok';
                actorDiv.innerHTML = `Siz: <strong>${actor.name}</strong> (${actor.id}/${actorRankName})`;
            }

            async function loadActor() {
                const token = localStorage.getItem('jwt_token') || '';

                try {
                    const meRes = await fetch(`${API_URL}/me`, { headers: { 'X-Session-ID': token } });
                    if (!meRes.ok) {
                        throw new Error('me request failed');
                    }

                    actor = await meRes.json();
                    renderActor();
                    saveBtn.disabled = false;
                } catch (err) {
                    console.error(err);
                    actorDiv.innerHTML = 'Sunucuya bağlanırken hata oluştu.';
                    showNotice('Sunucuya bağlanırken hata oluştu.', 'error');
                    saveBtn.disabled = true;
                }
            }

            function renderLookupPlaceholder() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(kullanıcı bilgilerini görmek için yukarıya ID numarasını girin...)</div>';
            }

            function renderNotFound() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(böyle bir kullanıcı bulunamadı.)</div>';
            }

            function renderLoading() {
                resultDiv.innerHTML = '<div class="text-slate-400 italic">(kullanıcı aranıyor...)</div>';
            }

            function renderUser(user) {
                resultDiv.innerHTML = `
                    <div class="p-3 border rounded bg-white">
                        <div class="font-medium">${user.name || 'Kullanıcı'} <span class="text-sm text-slate-600">(ID: ${user.id || targetInput.value.trim()})</span></div>
                        <div class="mt-1">Yetkiler: ${user.permissions?.join(', ') || 'yok'}</div>
                        <div class="mt-1">Hesabı kapalı?: ${user.banned ? 'evet' : 'hayır'}</div>
                    </div>
                `;
            }

            async function lookupUser() {
                const targetId = targetInput.value.trim();
                if (!targetId) {
                    renderLookupPlaceholder();
                    return;
                }

                const token = localStorage.getItem('jwt_token') || '';

                if (lookupAbort) {
                    lookupAbort.abort();
                }
                lookupAbort = new AbortController();

                try {
                    renderLoading();
                    const res = await fetch(`${API_URL}/admin/users/${encodeURIComponent(targetId)}`, {
                        headers: { 'X-Session-ID': token },
                        signal: lookupAbort.signal
                    });

                    if (res.status === 404) {
                        renderNotFound();
                        return;
                    }

                    if (!res.ok) {
                        renderLookupPlaceholder();
                        return;
                    }

                    const data = await res.json();
                    if (data?.user) {
                        renderUser(data.user);
                    } else {
                        renderNotFound();
                    }
                } catch (err) {
                    if (err?.name !== 'AbortError') {
                        renderLookupPlaceholder();
                    }
                }
            }

            function scheduleLookup() {
                if (lookupTimer) {
                    clearTimeout(lookupTimer);
                }
                const targetId = targetInput.value.trim();
                if (!targetId) {
                    renderLookupPlaceholder();
                    return;
                }
                renderLoading();
                lookupTimer = setTimeout(lookupUser, 300);
            }

            async function submit() {
                const token = localStorage.getItem('jwt_token') || '';

                const targetId = targetInput.value.trim();
                const password = passwordInput.value.trim();
                const confirm = confirmInput.value.trim();

                if (!targetId) {
                    showNotice('Kullanıcı ID\'si gerekli.', 'error');
                    return;
                }
                if (!password) {
                    showNotice('Yeni şifre boş olamaz.', 'error');
                    return;
                }
                if (password !== confirm) {
                    showNotice('Şifreler eşleşmiyor.', 'error');
                    return;
                }

                try {
                    const res = await fetch(`${API_URL}/admin/users/${encodeURIComponent(targetId)}/password`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Session-ID': token
                        },
                        body: JSON.stringify({ password, confirm })
                    });
                    const data = await res.json().catch(() => ({}));

                    if (!res.ok) {
                        showNotice(data.detail || 'Şifre güncellenemedi.', 'error');
                        return;
                    }

                    passwordInput.value = '';
                    confirmInput.value = '';
                    showNotice('Şifre güncellendi.');
                } catch (err) {
                    showNotice('Sunucu hatası.', 'error');
                }
            }

            saveBtn.disabled = true;
            saveBtn.addEventListener('click', submit);
            targetInput.addEventListener('input', scheduleLookup);

            renderLookupPlaceholder();
            loadActor();
        });
    </script>
</Layout>
