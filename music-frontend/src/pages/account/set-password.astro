---
import '../../styles/global.css'
import Layout from '../../layouts/Layout.astro'
import SetPasswordPanel from '../../components/SetPasswordPanel.astro'
---

<Layout title="Şifre Belirle">
    <div class="m-10">
        <h1 class="text-2xl text-slate-800">Şifre belirle</h1>
        <p class="text-slate-600" id="prompt-text">Bu sayfada yeni bir şifre belirleyebilirsin.</p>

        <div id="choice-panel" class="mt-4 border border-slate-300 rounded p-4 inline-block">
            <div class="font-medium">Şifre oluşturmak ister misin?</div>
            <label class="block mt-2">
                <input type="radio" name="set-password-choice" value="yes" />
                Evet
            </label>
            <label class="block mt-2">
                <input type="radio" name="set-password-choice" value="no" />
                Hayır
            </label>
            <button id="btn-done-before" class="hidden mt-3 text-sm text-slate-600 underline">
                Bunu daha once yaptim!!
            </button>
        </div>

        <div id="panel-container" class="hidden">
            <SetPasswordPanel mode="silent" title="Şifre belirle" dismissHref="/" showSave={false} />
            <br>

            <div class="mt-4 border border-slate-300 rounded p-4 inline-block">
                <div class="font-medium">Girmek için kullandığınız, 74 ile başlayan koda ne olsun?</div>
                <label class="block mt-2">
                    <input type="radio" name="kill-code-choice" value="2h" checked />
                    Bir süre daha kalabilir
                </label>
                <label class="block mt-2">
                    <input type="radio" name="kill-code-choice" value="now" />
                    Hemen devre dışı bırak (hesabıma girmeye çalışan insanlar var)
                </label>
            </div>
        </div>

        <button id="btn-proceed" class="hidden mt-4 border border-slate-400 rounded px-4 py-2">Devam et</button>
    </div>

    <script>
        import { API_URL } from '../../lib/constants';

        const params = new URLSearchParams(window.location.search);
        const mode = params.get('mode') || 'normal';
        const choicePanel = document.getElementById('choice-panel');
        const panelContainer = document.getElementById('panel-container');
        const promptText = document.getElementById('prompt-text');
        const proceedBtn = document.getElementById('btn-proceed');
        const choiceInputs = document.querySelectorAll('input[name="set-password-choice"]');
        const panelEl = document.querySelector('.set-password-panel');
        const doneBeforeBtn = document.getElementById('btn-done-before');

        function showPanel(show) {
            if (!panelContainer) {
                return;
            }
            panelContainer.classList.toggle('hidden', !show);
        }

        function showProceed(show) {
            if (!proceedBtn) {
                return;
            }
            proceedBtn.classList.toggle('hidden', !show);
        }

        function showDoneBefore(show) {
            if (!doneBeforeBtn) {
                return;
            }
            doneBeforeBtn.classList.toggle('hidden', !show);
        }

        function applyMode() {
            if (mode === 'forced') {
                if (choicePanel) {
                    choicePanel.classList.add('hidden');
                }
                if (promptText) {
                    promptText.textContent = 'Devam etmek için bir şifre belirlemeniz gerekiyor.';
                }
                showPanel(true);
                showProceed(true);
                showDoneBefore(false);
            } else if (mode === 'nudge') {
                if (promptText) {
                    promptText.textContent = 'Bir giriş kodu kullandınız. İsterseniz şimdi bir şifre belirleyebilirsiniz.';
                }
                showPanel(false);
                showProceed(false);
                showDoneBefore(false);
            } else {
                if (choicePanel) {
                    choicePanel.classList.add('hidden');
                }
                showPanel(true);
                showProceed(true);
                showDoneBefore(false);
            }
        }

        function handleChoice(value) {
            if (mode !== 'nudge') {
                return;
            }
            if (value === 'yes') {
                showPanel(true);
                showProceed(true);
            } else if (value === 'no') {
                showPanel(false);
                showProceed(true);
            }
        }

        async function loadLoginCodeInfo() {
            if (mode !== 'nudge') {
                return;
            }
            const token = localStorage.getItem('jwt_token');
            if (!token) {
                return;
            }
            try {
                const res = await fetch(`${API_URL}/me/login-code`, { headers: { 'X-Session-ID': token } });
                const data = await res.json().catch(() => ({}));
                if (!res.ok || !data?.has_code) {
                    return;
                }

                const validUntil = data?.login_code?.valid_until;
                if (!validUntil) {
                    return;
                }

                const expiresAt = new Date(validUntil);
                if (Number.isNaN(expiresAt.getTime())) {
                    return;
                }

                const now = Date.now();
                const diffMs = expiresAt.getTime() - now;
                if (diffMs > 0 && diffMs <= 2 * 60 * 60 * 1000) {
                    showDoneBefore(true);
                }
            } catch (err) {
                // ignore
            }
        }

        async function killCode(modeValue) {
            const token = localStorage.getItem('jwt_token');
            if (!token) {
                return;
            }
            await fetch(`${API_URL}/me/login-code/kill`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Session-ID': token
                },
                body: JSON.stringify({ mode: modeValue })
            });
        }

        function waitForPasswordSubmit() {
            return new Promise((resolve) => {
                if (!panelEl) {
                    resolve(false);
                    return;
                }
                const onSuccess = () => {
                    panelEl.removeEventListener('set-password:error', onError);
                    resolve(true);
                };
                const onError = () => {
                    panelEl.removeEventListener('set-password:success', onSuccess);
                    resolve(false);
                };
                panelEl.addEventListener('set-password:success', onSuccess, { once: true });
                panelEl.addEventListener('set-password:error', onError, { once: true });
                panelEl.dispatchEvent(new CustomEvent('set-password:submit'));
            });
        }

        async function handleProceed() {
            const killChoice = document.querySelector('input[name="kill-code-choice"]:checked')?.value || '2h';
            const wantsPassword = !panelContainer?.classList.contains('hidden');

            if (mode === 'forced' || wantsPassword) {
                const ok = await waitForPasswordSubmit();
                if (!ok) {
                    return;
                }
            }

            await killCode(killChoice);
            window.location.href = '/';
        }

        choiceInputs.forEach((input) => {
            input.addEventListener('change', (event) => {
                handleChoice(event.target.value);
            });
        });

        doneBeforeBtn?.addEventListener('click', () => {
            const noInput = document.querySelector('input[name="set-password-choice"][value="no"]');
            if (noInput) {
                noInput.checked = true;
            }
            handleChoice('no');
        });

        proceedBtn?.addEventListener('click', handleProceed);

        applyMode();
        loadLoginCodeInfo();
    </script>
</Layout>
