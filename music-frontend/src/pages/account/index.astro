---
import '../../styles/global.css'
import Layout from '../../layouts/Layout.astro'
import SetPasswordPanel from '../../components/SetPasswordPanel.astro'
import BoardThemeLoader from '../../components/BoardThemeLoader.astro'
---

<Layout title="Hesabım" themeLoading={true}>
    <BoardThemeLoader />
    <div id="account-container" class="m-5 lg:m-10 account-themed">
        <h1 class="text-2xl board-theme-text-primary mt-10">Hesap bilgileri</h1>
        <a href="/" class="inline-block text-sm board-theme-text-secondary hover:underline">
            (ana sayfaya geri dön)
        </a>

        <div id="ban-info" class="mt-4"></div>

        <div class="flex flex-wrap gap-5 mt-4 max-w-full overflow-x-hidden">
            <div id="user-info" class="border board-theme-border board-theme-card p-5 inline-block min-w-[18rem] board-theme-text-primary">Kullanıcı verileri yükleniyor...</div>

            <div class="border board-theme-border board-theme-card inline-block">
                <SetPasswordPanel themed={true} />
            </div>

            <div class="border board-theme-border board-theme-card p-5 inline-block max-w-xl">
                <div class="text-sm board-theme-text-secondary">Passkey</div>
            <div class="mt-2 flex items-center gap-2">
                <button id="passkey-enroll-btn" class="border board-theme-border px-3 py-2">Passkey oluştur</button>
            </div>
                <div id="passkey-status" class="text-sm board-theme-text-secondary"></div>
                <div id="passkey-list" class="mt-3 text-xs board-theme-text-secondary">Passkey'ler yükleniyor...</div>
                <div class="text-xs board-theme-text-secondary mt-2">Eğer cihazınız kullanımını destekliyorsa (çok büyük ihtimalle destekliyordur), giriş yaparken şifreniz yerine cihazınıza atanacak bir passkey'i kullanabilirsiniz. Başlamak için yukarıdaki "Passkey oluştur" tuşuna basın.</div>
                <div class="text-xs board-theme-text-secondary mt-2">Passkey kullanımı hakkında daha fazla bilgi için <a class="board-theme-text-primary" href="/help/passkeys">buraya</a> tıklayın.</div>
            </div>
        </div>

        <div class="mt-5">
            <button id="home-btn" class="border board-theme-border p-2 mt-3 inline-block">Ana sayfaya dön</button>
            <button id="logout-btn" class="border board-theme-border p-2 mt-3 inline-block">Çıkış yap</button>
        </div>
    </div>


    <script>
        import { API_URL } from '../../lib/constants.ts';

        function base64UrlToBytes(value) {
            const padded = value + '='.repeat((4 - (value.length % 4)) % 4);
            const base64 = padded.replace(/-/g, '+').replace(/_/g, '/');
            const binary = atob(base64);
            const bytes = new Uint8Array(binary.length);
            for (let i = 0; i < binary.length; i += 1) {
                bytes[i] = binary.charCodeAt(i);
            }
            return bytes;
        }

        function bytesToBase64Url(bytes) {
            const binary = String.fromCharCode(...bytes);
            return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
        }

        function setPasskeyStatus(message, isError = false) {
            const statusEl = document.getElementById('passkey-status');
            if (!statusEl) return;
            statusEl.textContent = message || '';
            statusEl.classList.toggle('text-red-600', isError);
            statusEl.classList.toggle('board-theme-text-secondary', !isError);
        }

        function normalizeRegistrationOptions(options) {
            const normalized = { ...options };
            normalized.challenge = base64UrlToBytes(options.challenge);
            if (normalized.user && normalized.user.id) {
                normalized.user = { ...normalized.user, id: base64UrlToBytes(normalized.user.id) };
            }
            if (Array.isArray(normalized.excludeCredentials)) {
                normalized.excludeCredentials = normalized.excludeCredentials.map((cred) => ({
                    ...cred,
                    id: base64UrlToBytes(cred.id)
                }));
            }
            return normalized;
        }

        function serializeAttestation(credential) {
            const response = credential.response;
            const transports = typeof response.getTransports === 'function' ? response.getTransports() : [];
            return {
                id: credential.id,
                rawId: bytesToBase64Url(new Uint8Array(credential.rawId)),
                type: credential.type,
                response: {
                    clientDataJSON: bytesToBase64Url(new Uint8Array(response.clientDataJSON)),
                    attestationObject: bytesToBase64Url(new Uint8Array(response.attestationObject))
                },
                meta: {
                    label: null,
                    transports: Array.isArray(transports) ? transports : [],
                    platform: String(navigator.platform || ''),
                    userAgent: String(navigator.userAgent || ''),
                    language: String(navigator.language || '')
                }
            };
        }

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/\"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function formatPasskeyId(value) {
            const raw = String(value || '');
            if (raw.length <= 12) return raw;
            return `${raw.slice(0, 8)}...${raw.slice(-4)}`;
        }

        function renderPasskeys(passkeys) {
            const listEl = document.getElementById('passkey-list');
            if (!listEl) return;

            const rows = Array.isArray(passkeys) ? passkeys : [];
            if (!rows.length) {
                listEl.innerHTML = "Henüz passkey yok.";
                return;
            }

            listEl.innerHTML = rows.map((entry, idx) => {
                const id = String(entry?.id || '');
                const encodedId = encodeURIComponent(id);
                const safeId = escapeHtml(id);
                const label = formatPasskeyId(id);
                const effectiveLabel = String(entry?.effective_label || entry?.label || entry?.default_label || label);
                const customLabel = String(entry?.label || '');
                const safeEffective = escapeHtml(effectiveLabel);
                const safeDefault = escapeHtml(String(entry?.default_label || ''));
                const safeCustom = escapeHtml(customLabel);

                return `<div class="mt-2 p-3 border board-theme-border rounded flex flex-col gap-2" data-passkey-row="${encodedId}">
                    <div class="flex items-center justify-between gap-3">
                        <div class="min-w-0 flex-1">
                            <div class="flex items-center gap-2" data-view-mode>
                                <span class="font-medium board-theme-text-primary truncate">${safeEffective}</span>
                                <button class="p-1 hover:opacity-70 transition-opacity" data-edit-trigger title="Düzenle">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="board-theme-text-secondary"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                                </button>
                            </div>
                            <div class="hidden items-center gap-2" data-edit-mode>
                                <input class="border board-theme-border px-2 py-1 text-sm board-theme-text-primary bg-transparent focus:outline-none focus:ring-1 focus:ring-slate-400 min-w-0 flex-1" 
                                       data-passkey-input maxlength="64" placeholder="Yeni etiket" value="${safeCustom}" />
                                <button class="text-xs board-theme-text-primary px-2 py-1 border board-theme-border hover:bg-black/5" data-passkey-save>Kaydet</button>
                                <button class="text-xs board-theme-text-secondary px-2 py-1" data-edit-cancel>İptal</button>
                            </div>
                            <div class="text-[10px] board-theme-text-secondary opacity-70 mt-0.5">varsayılan: ${safeDefault}</div>
                        </div>
                        <button class="border board-theme-border px-2 py-1 text-xs hover:bg-red-50 hover:text-red-600 transition-colors" data-passkey-delete>Sil</button>
                    </div>
                    <div class="text-[10px] board-theme-text-secondary truncate opacity-50">id: ${safeId}</div>
                </div>`;
            }).join('');
        }

        async function savePasskeyLabel(credentialId, label) {
            const token = localStorage.getItem('jwt_token');
            if (!token || !credentialId) return;
            setPasskeyStatus('Passkey etiketi kaydediliyor...');
            try {
                const res = await fetch(`${API_URL}/account/passkeys/${encodeURIComponent(credentialId)}`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Session-ID': token
                    },
                    body: JSON.stringify({ label: String(label || '').trim() || null })
                });
                if (!res.ok) {
                    const data = await res.json().catch(() => ({}));
                    throw new Error(data?.detail || 'Passkey etiketi kaydedilemedi.');
                }
                setPasskeyStatus('Passkey etiketi kaydedildi.');
                await loadPasskeys();
            } catch (err) {
                setPasskeyStatus(err?.message || 'Passkey etiketi kaydedilemedi.', true);
            }
        }

        async function loadPasskeys() {
            const token = localStorage.getItem('jwt_token');
            const listEl = document.getElementById('passkey-list');
            if (!listEl) return;
            if (!token) {
                listEl.textContent = 'Giriş yapmanız gerekiyor.';
                return;
            }

            try {
                const res = await fetch(`${API_URL}/account/passkeys`, {
                    headers: { 'X-Session-ID': token }
                });
                if (!res.ok) throw new Error('Passkey listesi alınamadı.');
                const data = await res.json();
                renderPasskeys(data?.passkeys || []);
            } catch (err) {
                listEl.textContent = 'Passkey listesi alınamadı.';
            }
        }

        async function deletePasskey(credentialId) {
            const token = localStorage.getItem('jwt_token');
            if (!token || !credentialId) return;
            setPasskeyStatus('Passkey siliniyor...');

            try {
                const res = await fetch(`${API_URL}/account/passkeys/${encodeURIComponent(credentialId)}`, {
                    method: 'DELETE',
                    headers: { 'X-Session-ID': token }
                });
                if (!res.ok) {
                    const data = await res.json().catch(() => ({}));
                    throw new Error(data?.detail || 'Passkey silinemedi.');
                }
                setPasskeyStatus('Passkey silindi.');
                window.posthog?.capture('passkey_deleted');
                await loadPasskeys();
            } catch (err) {
                setPasskeyStatus(err?.message || 'Passkey silinemedi.', true);
            }
        }

        async function enrollPasskey() {
            const token = localStorage.getItem('jwt_token');
            if (!token) {
                window.location.href = '/login';
                return;
            }
            if (!window.PublicKeyCredential) {
                setPasskeyStatus('Bu tarayıcı passkey desteklemiyor.', true);
                return;
            }
            const btn = document.getElementById('passkey-enroll-btn');
            if (btn) btn.disabled = true;
            setPasskeyStatus('Passkey kaydı hazırlanıyor...');
            try {
                const res = await fetch(`${API_URL}/account/passkeys/options`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Session-ID': token
                    }
                });
                if (!res.ok) {
                    const data = await res.json().catch(() => ({}));
                    throw new Error(data.detail || 'Passkey seçenekleri alınamadı.');
                }
                const data = await res.json();
                const publicKey = normalizeRegistrationOptions(data.options);
                const credential = await navigator.credentials.create({ publicKey });
                if (!credential) {
                    throw new Error('Passkey kaydı iptal edildi.');
                }
                const payload = {
                    challenge_id: data.challenge_id,
                    credential: serializeAttestation(credential)
                };
                const verifyRes = await fetch(`${API_URL}/account/passkeys/verify`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Session-ID': token
                    },
                    body: JSON.stringify(payload)
                });
                if (!verifyRes.ok) {
                    const verifyData = await verifyRes.json().catch(() => ({}));
                    throw new Error(verifyData.detail || 'Passkey kaydı doğrulanamadı.');
                }
                window.posthog?.capture('passkey_enrolled');
                setPasskeyStatus('Passkey kaydedildi.');
                await loadPasskeys();
            } catch (err) {
                window.posthog?.captureException(err);
                setPasskeyStatus(err?.message || 'Passkey kaydı başarısız.', true);
            } finally {
                if (btn) btn.disabled = false;
            }
        }

        async function loadAccount() {
            const infoDiv = document.getElementById('user-info');
            const banDiv = document.getElementById('ban-info');
            const token = localStorage.getItem('jwt_token');

            if (!token) {
                window.location.href = "/login";
                return;
            }

            try {
                const response = await fetch(`${API_URL}/me`, {
                    headers: {
                        'X-Session-ID': token
                    }
                });

                if (response.status === 403 || response.status === 401) {
                    banDiv.innerHTML = "<p>ilginç bir hata, lütfen tekrar giriş yapın.</p>(<a href='/login'>BURAYA tıkla</a>)";
                    return;
                }

                const user = await response.json();

                // check for ban
                if (user.banned) {
                    const reasonLine = user.reason ? `<div class='mt-1 text-sm'>Kapatılma sebebi: ${user.reason}</div>` : '';
                    banDiv.innerHTML = `<p class='mt-6 p-3 bg-red-50 border border-red-200 text-red-700 font-medium'>Bu hesap kullanıma kapatıldı.${reasonLine}</p>`;
                }

                // find the stronger rank
                let displayContent = `
            <p class='font-medium board-theme-text-primary'>${user.name} (ID: ${user.id})</p>
          `;

                if (user.permissions.includes('admin') || user.permissions.includes('dev')) {
                    // high perms
                    displayContent += `<p class='board-theme-text-secondary mt-1'>Yetkiler: ${user.permissions.join(', ')}</p>`;
                } else if (user.permissions.includes('music') || user.permissions.includes('musicpermanent')) {
                    // music
                    displayContent += `<p class='board-theme-text-secondary mt-1'>Müzik seçme için seçildi</p>`;
                } else {
                    // No perms
                    displayContent += `<p class='board-theme-text-secondary mt-1'>Normal kullanıcı</p>`;
                }

                infoDiv.innerHTML = displayContent;

            } catch (err) {
                infoDiv.innerHTML = "<p class='text-red-600'>Sunucuya bağlanırken hata oluştu.</p>";
            }
        }


        // buttons
        document.getElementById('logout-btn')?.addEventListener('click', () => {
            window.posthog?.capture('user_logged_out');
            window.posthog?.reset();
            localStorage.removeItem('jwt_token');
            window.location.href = "/login";
        });

        document.getElementById('home-btn')?.addEventListener('click', () => {
            window.location.href = "/";
        });

        document.getElementById('passkey-enroll-btn')?.addEventListener('click', enrollPasskey);
        document.getElementById('passkey-list')?.addEventListener('click', (event) => {
            const target = event.target as HTMLElement;
            
            // Edit trigger
            const editTrigger = target.closest('[data-edit-trigger]');
            if (editTrigger) {
                const row = editTrigger.closest('[data-passkey-row]');
                if (row) {
                    row.querySelector('[data-view-mode]')?.classList.add('hidden');
                    row.querySelector('[data-edit-mode]')?.classList.remove('hidden');
                    row.querySelector('[data-edit-mode]')?.classList.add('flex');
                    (row.querySelector('[data-passkey-input]') as HTMLInputElement | null)?.focus();
                }
                return;
            }

            // Cancel edit
            const cancelBtn = target.closest('[data-edit-cancel]');
            if (cancelBtn) {
                const row = cancelBtn.closest('[data-passkey-row]');
                if (row) {
                    row.querySelector('[data-edit-mode]')?.classList.add('hidden');
                    row.querySelector('[data-edit-mode]')?.classList.remove('flex');
                    row.querySelector('[data-view-mode]')?.classList.remove('hidden');
                }
                return;
            }

            // Save label
            const saveBtn = target.closest('[data-passkey-save]');
            if (saveBtn) {
                const row = saveBtn.closest('[data-passkey-row]');
                const credentialId = row?.getAttribute('data-passkey-row');
                if (!credentialId) return;
                const input = row?.querySelector('[data-passkey-input]') as HTMLInputElement | null;
                savePasskeyLabel(decodeURIComponent(credentialId), input?.value || '');
                return;
            }

            // Delete passkey
            const deleteBtn = target.closest('[data-passkey-delete]');
            if (deleteBtn) {
                const row = deleteBtn.closest('[data-passkey-row]');
                const credentialId = row?.getAttribute('data-passkey-row');
                if (!credentialId) return;
                if (confirm('Bu passkey\'i silmek istediğinizden emin misiniz?')) {
                    deletePasskey(decodeURIComponent(credentialId));
                }
            }
        });

        loadAccount();
        loadPasskeys();
    </script>
</Layout>
