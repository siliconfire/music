---
import '../../styles/global.css'
import Layout from '../../layouts/Layout.astro'
import BoardThemeLoader from '../../components/BoardThemeLoader.astro'
---

<Layout title="Giriş">
    <BoardThemeLoader />
    <div class="m-10">
        <div class="m-5 lg:m-10 mt-10 mb-5">
            <h1 class="text-2xl board-theme-text-primary" id="title">Lütfen giriş yap.</h1>
            <a href="/" class="inline-block text-sm board-theme-text-secondary hover:underline">
                (ana sayfaya geri dön)
            </a>
        </div>

        <div class="flex flex-wrap m-5 lg:m-10 gap-5 max-w-full overflow-x-hidden">
            <div class="border m-3 p-5 board-theme-card">
                <p id="info" class="board-theme-text-secondary"></p>
                <div id="view-no-token" style="display: none;">
                    <div id="error-box" class="hidden mb-3 p-3 border board-theme-border board-theme-text-primary rounded"></div>
                    <input type="text" id="user-id" class="mt-3 p-2 border board-theme-border w-full max-w-xs" placeholder="ID..."/>
                    <input type="password" id="password" class="mt-3 p-2 border board-theme-border w-full max-w-xs" placeholder="Şifre..."/>
                    <div>
                        <button id="btn-login" class="border board-theme-border p-2 mt-3 inline-block">Giriş yap</button>
                    </div>
                    <div class="mt-3 text-sm board-theme-text-secondary">
                        <a href="/login/code" class="underline">Benim bir giriş kodum var!</a>
                    </div>
                </div>
                <div id="view-invalid-token" style="display: none;">
                    <span class="text-xl board-theme-text-primary">Oturumunuzun süresi dolmuş.</span>
                    <div>
                        <button class="btn-logout border board-theme-border p-2 mt-3 inline-block">Çıkış yap</button>
                    </div>
                </div>
            </div>

            <div class="border m-3 p-5 board-theme-card">
                <span class="text-xl board-theme-text-primary">Yardım</span>
                <div>
                    <a href="/help" class="border board-theme-border p-2 mt-3 inline-block">Yardım sayfası</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        import {API_URL} from "../../lib/constants.ts";

        const viewNoToken = document.getElementById('view-no-token');
        const viewInvalidToken = document.getElementById('view-invalid-token');
        const info = document.getElementById('info');
        const errorBox = document.getElementById('error-box');

        function showError(message, allowHtml = false) {
            if (!errorBox) {
                return;
            }
            if (allowHtml) {
                errorBox.innerHTML = message;
            } else {
                errorBox.textContent = message;
            }
            errorBox.classList.remove('hidden');
        }

        function clearError() {
            if (!errorBox) {
                return;
            }
            errorBox.textContent = '';
            errorBox.classList.add('hidden');
        }

        async function updateUI() {
            // reset
            viewNoToken.style.display = 'none';
            viewInvalidToken.style.display = 'none';
            info.innerHTML = "";
            clearError();

            const token = localStorage.getItem('jwt_token');

            if (!token) {
                viewNoToken.style.display = 'block';
                return;
            }

            info.innerHTML = "Oturumunuz kontrol ediliyor...";
            try {
                const res = await fetch(`${API_URL}/check`, {
                    method: 'POST',
                    headers: {'X-Session-ID': token}
                });

                const data = await res.json();

                if (data.valid) {
                    info.innerHTML = "<span class='inline-flex items-center gap-2'><img src='/loading.svg' alt='Yükleniyor' class='w-4 h-4'/>Yönlendiriliyorsunuz...</span>";
                    setTimeout(() => {
                        window.location.href = '/';
                    }, 1000);

                } else {
                    // we have the users token, but backend says bullshit (most likely expired or forged)
                    viewInvalidToken.style.display = 'block';
                    info.innerHTML = "";
                }
            } catch (err) {
                // network error, backend down, cors issue, who knows really
                console.error("Connection failed", err);
                viewNoToken.style.display = 'block';
                showError("Bir hata oluştu, muhtemelen sunucuya bağlanamadım. Eğer başka cihazdan da girilmiyorsa çok büyük ihtimalle hata bende. Lütfen bunu bana bildirin.");
            }
        }

        async function handleLogin() {
            const usernameInput = document.getElementById('user-id') as HTMLInputElement;
            const passwordInput = document.getElementById('password') as HTMLInputElement;
            const user_id = usernameInput.value;
            const password = passwordInput?.value || '';

            clearError();

            if (!user_id) {
                showError("Kullanıcı ID'si gerekli.");
                return;
            }

            if (password.trim().startsWith('74')) {
                showError("Bu bir şifre değil de giriş kodu gibi duruyor. <a href='/login/code' class='underline'>Giriş kodu kullanmak için buraya tıkla</a>.", true);
                return;
            }

            try {
                // Using your specific FastAPI endpoint
                const res = await fetch(`${API_URL}/token`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ user_id, password })
                });

                const data = await res.json();

                if (res.ok) {
                    localStorage.setItem('jwt_token', data.access_token);

                    // Fetch canonical user info from server and identify PostHog with server-provided id and name
                    try {
                        const meRes = await fetch(`${API_URL}/me`, { headers: { 'X-Session-ID': data.access_token } });
                        const me = await meRes.json();
                        if (me && me.id) {
                            window.posthog?.identify(String(me.id), { name: me.name });
                        } else {
                            // fallback to input id if /me doesn't return id
                            window.posthog?.identify(String(user_id));
                        }
                    } catch (err) {
                        // If /me fails for any reason, fall back to input id
                        window.posthog?.identify(String(user_id));
                    }

                    window.posthog?.capture('user_logged_in', { method: 'password' });
                    if (data.set_password === 'forced') {
                        window.location.href = '/account/set-password?mode=forced';
                        return;
                    }
                    if (data.set_password === 'nudge') {
                        window.location.href = '/account/set-password?mode=nudge';
                        return;
                    }
                    await updateUI();
                } else {
                    if (data?.detail === 'Use /login/code for code logins') {
                        showError("Bu bir şifre değil de giriş kodu gibi duruyor. <a href='/login/code' class='underline'>Giriş kodu kullanmak için buraya tıkla</a>.", true);
                    } else {
                        showError("Giriş başarısız. " + (data.detail || "Bilinmeyen hata") + ".");
                    }
                }
            } catch (err) {
                console.error("Login fetch error:", err);
                window.posthog?.captureException(err);
                showError("Sunucu hatası. Lütfen daha sonra tekrar deneyin.");
            }
        }

        function handleLogout() {
            window.posthog?.capture('user_logged_out');
            window.posthog?.reset();
            localStorage.removeItem('jwt_token');
            updateUI();
        }

        document.getElementById('btn-login')?.addEventListener('click', handleLogin);
        const logoutButtons = document.querySelectorAll('.btn-logout');
        logoutButtons.forEach(button => {
            button.addEventListener('click', handleLogout);
        });
        const passwordInput = document.getElementById('password');
        passwordInput?.addEventListener('input', (e) => {
            const target = e.target as HTMLInputElement;
            const value = target?.value?.trim() || '';
            if (value.startsWith('74')) {
                showError("Bu bir şifre değil de giriş kodu gibi duruyor. <a href='/login/code' class='underline'>Giriş kodu kullanmak için buraya tıkla</a>.", true);
            } else if (errorBox?.classList.contains('hidden') === false) {
                clearError();
            }
        });

        updateUI()
    </script>
</Layout>

