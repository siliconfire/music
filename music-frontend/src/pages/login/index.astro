---
import '../../styles/global.css'
import Layout from '../../layouts/Layout.astro'
import BoardThemeLoader from '../../components/BoardThemeLoader.astro'
---

<Layout title="Giriş" themeLoading={true}>
    <BoardThemeLoader />
    <div class="m-10">
        <div class="m-5 lg:m-10 mt-10 mb-5">
            <h1 class="text-2xl board-theme-text-primary" id="title">Lütfen giriş yap.</h1>
            <a href="/" class="inline-block text-sm board-theme-text-secondary hover:underline">
                (ana sayfaya geri dön)
            </a>
        </div>

        <div class="flex flex-wrap m-5 lg:m-10 gap-5 max-w-full overflow-x-hidden">
            <div class="border m-3 p-5 board-theme-card">
                <p id="info" class="board-theme-text-secondary"></p>
                <div id="view-no-token" style="display: none;">
                    <div id="error-box" class="hidden mb-3 p-3 border board-theme-border board-theme-text-primary rounded"></div>
                    <input type="text" id="user-id" class="mt-3 p-2 border board-theme-border w-full max-w-xs" placeholder="ID"/>
                    <input type="password" id="credential" class="mt-3 p-2 border board-theme-border w-full max-w-xs" placeholder="Şifre veya Giriş kodu"/>
                    <div>
                        <button id="btn-login" class="border board-theme-border p-2 mt-3 inline-block">Giriş yap</button>
                    </div>
                    <div class="mt-4 pt-3 border-t board-theme-border">
                        <button id="passkey-login-btn" class="border board-theme-border p-2 inline-block">Passkey kullan</button>
                        <div id="passkey-status" class="mt-2 text-sm board-theme-text-secondary"></div>
                    </div>
                </div>
                <div id="view-invalid-token" style="display: none;">
                    <span class="text-xl board-theme-text-primary">Oturumunuzun süresi dolmuş.</span>
                    <div>
                        <button class="btn-logout border board-theme-border p-2 mt-3 inline-block">Çıkış yap</button>
                    </div>
                </div>
            </div>

            <div class="border m-3 p-5 board-theme-card">
                <span class="text-xl board-theme-text-primary">Yardım</span>
                <div>
                    <a href="/help" class="border board-theme-border p-2 mt-3 inline-block">Yardım sayfası</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        import {API_URL} from "../../lib/constants.ts";

        const viewNoToken = document.getElementById('view-no-token');
        const viewInvalidToken = document.getElementById('view-invalid-token');
        const info = document.getElementById('info');
        const errorBox = document.getElementById('error-box');
        const passkeyStatus = document.getElementById('passkey-status');

        function base64UrlToBytes(value) {
            const padded = value + '='.repeat((4 - (value.length % 4)) % 4);
            const base64 = padded.replace(/-/g, '+').replace(/_/g, '/');
            const binary = atob(base64);
            const bytes = new Uint8Array(binary.length);
            for (let i = 0; i < binary.length; i += 1) {
                bytes[i] = binary.charCodeAt(i);
            }
            return bytes;
        }

        function bytesToBase64Url(bytes) {
            const binary = String.fromCharCode(...bytes);
            return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
        }

        function setPasskeyStatus(message, isError = false) {
            if (!passkeyStatus) {
                return;
            }
            passkeyStatus.textContent = message || '';
            passkeyStatus.classList.toggle('text-red-600', isError);
            passkeyStatus.classList.toggle('board-theme-text-secondary', !isError);
        }

        function normalizeAuthenticationOptions(options) {
            const normalized = { ...options };
            normalized.challenge = base64UrlToBytes(options.challenge);
            if (Array.isArray(normalized.allowCredentials)) {
                normalized.allowCredentials = normalized.allowCredentials.map((cred) => ({
                    ...cred,
                    id: base64UrlToBytes(cred.id)
                }));
            }
            return normalized;
        }

        function serializeAssertion(credential) {
            const response = credential.response;
            return {
                id: credential.id,
                rawId: bytesToBase64Url(new Uint8Array(credential.rawId)),
                type: credential.type,
                response: {
                    clientDataJSON: bytesToBase64Url(new Uint8Array(response.clientDataJSON)),
                    authenticatorData: bytesToBase64Url(new Uint8Array(response.authenticatorData)),
                    signature: bytesToBase64Url(new Uint8Array(response.signature)),
                    userHandle: response.userHandle ? bytesToBase64Url(new Uint8Array(response.userHandle)) : null
                }
            };
        }

        function showError(message, allowHtml = false) {
            if (!errorBox) {
                return;
            }
            if (allowHtml) {
                errorBox.innerHTML = message;
            } else {
                errorBox.textContent = message;
            }
            errorBox.classList.remove('hidden');
        }

        function clearError() {
            if (!errorBox) {
                return;
            }
            errorBox.textContent = '';
            errorBox.classList.add('hidden');
        }

        async function updateUI() {
            // reset
            viewNoToken.style.display = 'none';
            viewInvalidToken.style.display = 'none';
            info.innerHTML = "";
            clearError();
            setPasskeyStatus('');

            const token = localStorage.getItem('jwt_token');

            if (!token) {
                viewNoToken.style.display = 'block';
                return;
            }

            info.innerHTML = "Oturumunuz kontrol ediliyor...";
            try {
                const res = await fetch(`${API_URL}/check`, {
                    method: 'POST',
                    headers: {'X-Session-ID': token}
                });

                const data = await res.json();

                if (data.valid) {
                    info.innerHTML = "<span class='inline-flex items-center gap-2'><img src='/loading.svg' alt='Yükleniyor' class='w-4 h-4'/>Yönlendiriliyorsunuz...</span>";
                    setTimeout(() => {
                        window.location.href = '/';
                    }, 1000);

                } else {
                    // we have the users token, but backend says bullshit (most likely expired or forged)
                    viewInvalidToken.style.display = 'block';
                    info.innerHTML = "";
                }
            } catch (err) {
                // network error, backend down, cors issue, who knows really
                console.error("Connection failed", err);
                viewNoToken.style.display = 'block';
                showError("Bir hata oluştu, muhtemelen sunucuya bağlanamadım. Eğer başka cihazdan da girilmiyorsa çok büyük ihtimalle hata bende. Lütfen bunu bana bildirin.");
            }
        }

        async function handleLogin() {
            const usernameInput = document.getElementById('user-id') as HTMLInputElement;
            const credentialInput = document.getElementById('credential') as HTMLInputElement;
            const user_id = usernameInput.value;
            const credential = credentialInput?.value || '';
            const trimmedCredential = credential.trim();
            const isCodeLogin = trimmedCredential.startsWith('74');

            clearError();

            if (!user_id) {
                showError("Kullanıcı ID'si gerekli.");
                return;
            }

            if (!trimmedCredential) {
                showError("Şifre veya kod gerekli.");
                return;
            }

            try {
                const payload = isCodeLogin
                    ? { user_id, code: trimmedCredential }
                    : { user_id, password: credential };

                const res = await fetch(`${API_URL}/token`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await res.json();

                if (res.ok) {
                    localStorage.setItem('jwt_token', data.access_token);

                    // Fetch canonical user info from server and identify PostHog with server-provided id and name
                    try {
                        const meRes = await fetch(`${API_URL}/me`, { headers: { 'X-Session-ID': data.access_token } });
                        const me = await meRes.json();
                        if (me && me.id) {
                            window.posthog?.identify(String(me.id), { name: me.name });
                        } else {
                            // fallback to input id if /me doesn't return id
                            window.posthog?.identify(String(user_id));
                        }
                    } catch (err) {
                        // If /me fails for any reason, fall back to input id
                        window.posthog?.identify(String(user_id));
                    }

                    window.posthog?.capture('user_logged_in', { method: isCodeLogin ? 'code' : 'password' });
                    if (data.set_password === 'forced') {
                        window.location.href = '/account/set-password?mode=forced';
                        return;
                    }
                    if (data.set_password === 'nudge') {
                        window.location.href = '/account/set-password?mode=nudge';
                        return;
                    }
                    await updateUI();
                } else {
                    if (data?.detail === 'Use /login/code for code logins') {
                        showError("Kod ile giriş için ayrı bir sayfa yok; kodunuzu buraya 74 ile başlayacak şekilde girin.");
                    } else {
                        showError(data.detail || "Bilinmeyen hata");
                    }
                }
            } catch (err) {
                console.error("Login fetch error:", err);
                window.posthog?.captureException(err);
                showError("Sunucu hatası. Lütfen daha sonra tekrar deneyin.");
            }
        }

        async function loginWithPasskey() {
            if (!window.PublicKeyCredential) {
                setPasskeyStatus('Bu tarayıcı passkey desteklemiyor.', true);
                return;
            }

            const btn = document.getElementById('passkey-login-btn');
            const btnEl = btn instanceof HTMLButtonElement ? btn : null;
            if (btnEl) {
                btnEl.disabled = true;
            }

            setPasskeyStatus('Passkey doğrulaması hazırlanıyor...');
            try {
                const optionsRes = await fetch(`${API_URL}/login/passkeys/options`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({})
                });
                if (!optionsRes.ok) {
                    const data = await optionsRes.json().catch(() => ({}));
                    throw new Error(data.detail || 'Passkey seçenekleri alınamadı.');
                }

                const optionsData = await optionsRes.json();
                const publicKey = normalizeAuthenticationOptions(optionsData.options);
                const credential = await navigator.credentials.get({ publicKey });
                if (!credential) {
                    throw new Error('Passkey doğrulaması iptal edildi.');
                }

                const verifyRes = await fetch(`${API_URL}/login/passkeys/verify`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        challenge_id: optionsData.challenge_id,
                        credential: serializeAssertion(credential)
                    })
                });
                if (!verifyRes.ok) {
                    const data = await verifyRes.json().catch(() => ({}));
                    throw new Error(data.detail || 'Passkey doğrulanamadı.');
                }

                const result = await verifyRes.json();
                if (!result?.access_token) {
                    throw new Error('Passkey girişi başarısız.');
                }

                localStorage.setItem('jwt_token', result.access_token);
                try {
                    const meRes = await fetch(`${API_URL}/me`, { headers: { 'X-Session-ID': result.access_token } });
                    const me = await meRes.json();
                    if (me?.id) {
                        window.posthog?.identify(String(me.id), { name: me.name });
                    }
                } catch (err) {
                    // ignore identity failures
                }

                window.posthog?.capture('user_logged_in_with_passkey', { method: 'passkey' });
                window.location.href = '/';
            } catch (err) {
                console.error('Passkey login failed:', err);
                window.posthog?.captureException(err);
                setPasskeyStatus(err?.message || 'Passkey girişi başarısız.', true);
            } finally {
                if (btnEl) {
                    btnEl.disabled = false;
                }
            }
        }

        function handleLogout() {
            window.posthog?.capture('user_logged_out');
            window.posthog?.reset();
            localStorage.removeItem('jwt_token');
            updateUI();
        }

        document.getElementById('btn-login')?.addEventListener('click', handleLogin);
        document.getElementById('passkey-login-btn')?.addEventListener('click', loginWithPasskey);
        const logoutButtons = document.querySelectorAll('.btn-logout');
        logoutButtons.forEach(button => {
            button.addEventListener('click', handleLogout);
        });
        const credentialInput = document.getElementById('credential');
        credentialInput?.addEventListener('input', () => {
            if (errorBox?.classList.contains('hidden') === false) {
                clearError();
            }
        });

        updateUI()
    </script>
</Layout>

