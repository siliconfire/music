---
import Layout from '../layouts/Layout.astro';
import BoardThemeLoader from '../components/BoardThemeLoader.astro';
---


<Layout title="Bartın Lisesi Müzik Sistemi">
    <BoardThemeLoader />
    <div class="m-10">
        <h1 class="text-2xl mt-10 board-theme-text-primary">Bartın Lisesi Müzik Sistemi</h1>
        <div class="flex flex-wrap m-5 lg:m-10 gap-5 max-w-full overflow-x-hidden">
            <!-- if logged in -->
            <div id="logged-in" class="hidden">
                <div class="border m-3 p-5 hidden board-theme-card" id="div-music-available">
                    <span class="text-xl board-theme-text-primary">Müzik Sistemi</span>
                    <br>
                    <a href="/music" class="border board-theme-border p-2 mt-3 inline-block">Müzik Kontrolleri</a>
                    <a href="/board/edit" class="border board-theme-border p-2 mt-3 inline-block">Ekran Yönetimi</a>
                </div>

                <div class="border m-3 p-5 hidden board-theme-card" id="div-music-unavailable">
                    <span class="text-xl board-theme-text-primary">Müzik Sistemi</span>
                    <br>
                    Bugün müzik sistemi için seçilmemişsiniz.
                    <br>
                    <span class="board-theme-text-secondary">İlginiz için teşekkürler.</span>
                </div>
                <div class="border m-3 p-5 board-theme-card">
                    <span class="text-xl board-theme-text-primary">Hesap bilgileri</span>
                    <span id="username">(...)</span>
                    <br>
                    <button id="btn-logout" class="border board-theme-border p-2 mt-3 inline-block">Çıkış yap</button>
                    <a href="/account" class="border board-theme-border p-2 mt-3 inline-block">Hesabım</a>
                </div>

                <div id="div-cool" class="border m-3 p-5 hidden board-theme-card">
                    <span class="text-xl board-theme-text-primary">Superman yetkilerine sahipsiniz.</span>
                    <br>
                    <button class="border board-theme-border p-2 mt-3 hidden" id="btn-mod">Moderatör Paneli</button>
                    <button class="border board-theme-border p-2 mt-3 hidden" id="btn-admin">Yönetici Paneli</button>
                </div>
            </div>

            <div id="logged-out" class="hidden">
                <div class="border m-3 p-5 board-theme-card">
                    <span class="text-xl board-theme-text-primary">Hoşgeldiniz.</span>
                    <br>
                    <a href="/login" class="border board-theme-border p-2 mt-3 inline-block">Giriş yap</a>
                    <a href="/help" class="border board-theme-border p-2 mt-3 inline-block">Yardım</a>
                </div>
            </div>

            <div id="session-invalid" class="hidden">
                <div class="border m-3 p-5 board-theme-card">
                    <span class="text-xl board-theme-text-primary">Oturumunuzun süresi dolmuş.</span>
                    <br>
                    <span class="board-theme-text-secondary">Lütfen çıkış yapıp sonra tekrar girmeyi deneyin.</span>
                    <br>
                    <a id="btn-logout-2" class="border board-theme-border p-2 mt-3 inline-block">Çıkış yap</a>
                    <a href="/help" class="border board-theme-border p-2 mt-3 inline-block">Yardım</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { API_URL } from '../lib/constants';
        const token = localStorage.getItem("jwt_token");

        async function handleUserInfo() {
            if (token) {
                document.getElementById("logged-in").classList.remove("hidden");
            } else {
                document.getElementById("logged-out").classList.remove("hidden");
                return;
            }

            const response = await fetch(`${API_URL}/me`, {headers: {'X-Session-ID': token}});
            const user_info = await response.json();

            if (!response.ok) {
                document.getElementById("logged-in").classList.add("hidden");
                document.getElementById("session-invalid").classList.remove("hidden");

                document.getElementById("btn-logout-2").addEventListener("click", () => {
                    window.posthog?.capture('user_logged_out');
                    window.posthog?.reset();
                    localStorage.removeItem("jwt_token");
                    window.location.href = '/';
                });

            }

            if (user_info.banned) {
                window.location.href = '/account';
            }

            // Identify the user in PostHog with their ID and name (server-provided)
            if (user_info.id && String(user_info.id) !== '100000') {
                window.posthog?.identify(String(user_info.id), { name: user_info.name });
            }

            const username_el = document.getElementById("username") as HTMLSpanElement;
            username_el.innerText = "(" + user_info.name + ")";

            const perms = user_info.permissions;

            if (perms.includes("moderator") || perms.includes("admin")) {
                document.getElementById("div-cool").classList.remove("hidden");
                document.getElementById("btn-mod").classList.remove("hidden");
            }
            document.getElementById("btn-mod").addEventListener("click", () => {
                window.location.href = '/mod'
            })

            if (perms.includes("admin")) {
                document.getElementById("btn-admin").classList.remove("hidden");
                document.getElementById("btn-admin").addEventListener("click", () => {
                    window.location.href = '/admin'
                })
            }

            if (perms.includes("music") || perms.includes("musicpermanent")) {
                document.getElementById("div-music-available").classList.remove("hidden");
            } else {
                document.getElementById("div-music-unavailable").classList.remove("hidden");
            }
        }

        document.getElementById("btn-logout").addEventListener("click", () => {
            window.posthog?.capture('user_logged_out');
            window.posthog?.reset();
            localStorage.removeItem("jwt_token");
            window.location.href = '/';
        });

        handleUserInfo()
    </script>
</Layout>

