---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Touch Test">
    <main class="relative h-screen w-screen overflow-hidden bg-slate-50 text-slate-900">

        <div id="ui-pane" class="fixed bottom-6 left-6 z-50 p-5 bg-white border border-slate-300 shadow-sm rounded-xl text-center min-w-[180px]">
            <div class="font-mono text-sm mb-3 text-slate-500">
                <span id="x">0</span>, <span id="y">0</span>
            </div>

            <select id="grid-select" class="w-full mb-2 bg-white border border-slate-300 p-2 text-sm cursor-pointer rounded-md outline-none focus:ring-1 focus:ring-blue-500">
                <option value="4">4x4</option>
                <option value="10" selected>10x10</option>
                <option value="20">20x20</option>
                <option value="30">30x30</option>
                <option value="50">50x50</option>
                <option value="67">67x67</option>
                <option value="100">100x100</option>
            </select>

            <button id="reset-btn" class="w-full bg-slate-100 hover:bg-red-50 text-red-600 border border-red-200 py-2 font-semibold text-lg mb-4 rounded-md transition-colors">
                Reset
            </button>

            <div id="nav-area" class="flex flex-col items-center">
                <a href="/board" id="go-back-link" class="text-sm underline text-slate-400 hover:text-slate-600">Geri dön</a>
                <a href="/board" id="go-back-btn" class="hidden bg-emerald-600 hover:bg-emerald-700 p-4 font-bold w-full text-center tracking-wide text-white no-underline rounded-md shadow-sm">
                    Bitir
                </a>
            </div>
        </div>

        <canvas id="trail-canvas" class="pointer-events-none absolute inset-0 z-20"></canvas>

        <div id="grid-container" class="absolute inset-0 z-10 grid h-full w-full"></div>

    </main>
</Layout>

<script>
    const container = document.getElementById('grid-container')!;
    const canvas = document.getElementById('trail-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d');
    const xDisplay = document.getElementById('x')!;
    const yDisplay = document.getElementById('y')!;
    const select = document.getElementById('grid-select') as HTMLSelectElement;
    const resetBtn = document.getElementById('reset-btn')!;
    const backLink = document.getElementById('go-back-link')!;
    const backBtn = document.getElementById('go-back-btn')!;

    let total = 0, count = 0;

    function init() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        const size = parseInt(select.value);
        total = size * size;
        count = 0;

        backLink.classList.remove('hidden');
        backBtn.classList.add('hidden');

        container.innerHTML = '';
        container.style.gridTemplateColumns = `repeat(${size}, 1fr)`;
        container.style.gridTemplateRows = `repeat(${size}, 1fr)`;

        for (let i = 0; i < total; i++) {
            const cell = document.createElement('div');
            // Changed cell border to a very light slate
            cell.className = 'cell border border-slate-200';
            container.appendChild(cell);
        }
    }

    function handle(e: any) {
        const cx = e.clientX || (e.touches ? e.touches[0].clientX : 0);
        const cy = e.clientY || (e.touches ? e.touches[0].clientY : 0);

        xDisplay.textContent = Math.round(cx).toString();
        yDisplay.textContent = Math.round(cy).toString();

        if (ctx) {
            // Softened the trail color to a light emerald
            ctx.fillStyle = '#10b981';
            ctx.beginPath();
            ctx.arc(cx, cy, 3, 0, Math.PI * 2);
            ctx.fill();
        }

        const elements = document.elementsFromPoint(cx, cy);
        const cell = elements.find(el => el.classList.contains('cell')) as HTMLElement | undefined;

        // Use a cleaner background fill for "completed" cells
        if (cell && !cell.classList.contains('bg-emerald-100')) {
            cell.classList.add('bg-emerald-100');
            cell.style.borderColor = '#d1fae5'; // Match light emerald border
            count++;
            if (count >= total) {
                backLink.classList.add('hidden');
                backBtn.classList.remove('hidden');
                backBtn.classList.add('block');
            }
        }
    }

    window.addEventListener('mousemove', handle);
    window.addEventListener('touchmove', (e) => {
        handle(e);
        if (e.cancelable) e.preventDefault();
    }, { passive: false });

    select.onchange = init;
    resetBtn.onclick = () => {
        ctx?.clearRect(0,0,canvas.width,canvas.height);
        init();
    };

    window.onresize = init;
    init();
</script>